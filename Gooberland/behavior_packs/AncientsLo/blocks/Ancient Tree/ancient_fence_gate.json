{
	"format_version": "1.21.20",
	"minecraft:block": {
		"description": {
			"identifier": "ancients:ancient_fence_gate",
			"menu_category": {
				"category": "construction",
				"group": "itemGroup.name.fenceGate"
			},
			"states": {
				"ancient:placed_bit": [0,1],
				"ancient:open": [false,true]
			},
			"traits": {
				"minecraft:placement_direction": {
					"enabled_states": ["minecraft:cardinal_direction"]
				}
			}
		},
		"components": {
			"tag:one_way_collidable": {},
			"minecraft:custom_components": ["ancients:fence_gate_place"],
			"minecraft:material_instances": {
				"*": {
					"texture": "ancient_planks",
					"render_method": "alpha_test"
				}
			},
			"minecraft:map_color": "#B3895C",
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 0.5
			},
			"minecraft:geometry": {
				"identifier": "geometry.custom_fence_gate",
				"bone_visibility": {
					"render": "query.block_state('ancient:placed_bit') == 0",
					"fence_gate": "query.block_state('ancient:placed_bit') == 1",
					"northsouth": "query.block_state('ancient:placed_bit') == 1 && (query.block_state('minecraft:cardinal_direction') == 'north' || query.block_state('minecraft:cardinal_direction') == 'south')",
					"nsclose": "query.block_state('ancient:placed_bit') == 1 && query.block_state('ancient:open') == false && (query.block_state('minecraft:cardinal_direction') == 'north' || query.block_state('minecraft:cardinal_direction') == 'south')",
					"nsopen_north": "query.block_state('ancient:placed_bit') == 1 && (query.block_state('ancient:open') == true && query.block_state('minecraft:cardinal_direction') == 'north')",
					"nsopen_south": "query.block_state('ancient:placed_bit') == 1 && (query.block_state('ancient:open') == true && query.block_state('minecraft:cardinal_direction') == 'south')",
					"westeast": "query.block_state('ancient:placed_bit') == 1 && (query.block_state('minecraft:cardinal_direction') == 'west' || query.block_state('minecraft:cardinal_direction') == 'east')",
					"weclose": "query.block_state('ancient:placed_bit') == 1 && query.block_state('ancient:open') == false && (query.block_state('minecraft:cardinal_direction') == 'west' || query.block_state('minecraft:cardinal_direction') == 'east')",
					"weopen_west": "query.block_state('ancient:placed_bit') == 1 && (query.block_state('ancient:open') == true && query.block_state('minecraft:cardinal_direction') == 'west')",
					"weopen_east": "query.block_state('ancient:placed_bit') == 1 && (query.block_state('ancient:open') == true && query.block_state('minecraft:cardinal_direction') == 'east')"
				}
			},
			"minecraft:light_dampening": 0,
			"minecraft:transformation": {
				"translation": [0, 0.3, 0]
			},
			"tag:wood": {},
			"tag:custom_fence": {},
            "tag:ancients:isSolid":{}
		},
		"permutations": [
			{
				"condition": "query.block_state('ancient:open') == false",
				"components": {
				}
			},
			{
				"condition": "query.block_state('ancient:open') == true",
				"components": {
					"minecraft:collision_box": false
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'north' || query.block_state('minecraft:cardinal_direction') == 'south'",
				"components": {
					"minecraft:selection_box": {
						"origin": [-8,0,-2],
						"size": [16,11,4]
					}
				}
			},
			{
				"condition": "query.block_state('ancient:open') == false && (query.block_state('minecraft:cardinal_direction') == 'north' || query.block_state('minecraft:cardinal_direction') == 'south')",
				"components": {
					"minecraft:collision_box": {
						"origin": [-8,0,-2],
						"size": [16,16,4]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'west' || query.block_state('minecraft:cardinal_direction') == 'east'",
				"components": {
					"minecraft:selection_box": {
						"origin": [-2,0,-8],
						"size": [4,11,16]
					}
				}
			},
			{
				"condition": "query.block_state('ancient:open') == false && (query.block_state('minecraft:cardinal_direction') == 'west' || query.block_state('minecraft:cardinal_direction') == 'east')",
				"components": {
					"minecraft:collision_box": {
						"origin": [-2,0,-8],
						"size": [4,16,16]
					}
				}
			}
		]
	}
}