{
    "format_version":"1.21.30",
    "minecraft:block": {
        "description": {
            "identifier": "ancients:ancient_slab",
			"menu_category": {
				"category": "construction",
				"group": "itemGroup.name.slab"
			},
			"traits": {
				"minecraft:placement_position": {
					"enabled_states": ["minecraft:vertical_half"]
				}
			},
            "states": {
                "ancients:double": [false, true],
                "ancients:waterlogged": [false,true]
            }
        },
        "components": {
			
			"minecraft:geometry": {
				"identifier": "geometry.ancients_slab",
				"bone_visibility": {
					"main": "q.block_state('minecraft:vertical_half') == 'bottom'",
					"top": "q.block_state('minecraft:vertical_half') == 'top'"
				}
			},
			"minecraft:material_instances": {
				"*": {
					"texture": "ancient_planks",
					"render_method": "opaque"
				}
			},
			"minecraft:collision_box": {
				"origin": [-8,0,-8],
				"size": [16,8,16]
			},
			"minecraft:selection_box": {
				"origin": [-8,0,-8],
				"size": [16,8,16]
			},
			"minecraft:flammable":{
				"catch_chance_modifier": 5,
				"destroy_chance_modifier": 20
			},
            "minecraft:destructible_by_mining":{
				"seconds_to_destroy": 2
			},
            "minecraft:destructible_by_explosion":{
				"explosion_resistance": 1
			},
			"tag:wood":{},
            "minecraft:map_color": "#B3895C",
            "minecraft:light_dampening": 0,
			"minecraft:light_emission": 0,
            "tag:ancients:isSolid":{},
            "tag:minecraft:is_hatchet_item_destructible":{}
        },
        "permutations": [
            {
                "condition": "q.block_state('minecraft:vertical_half') == 'bottom' && !q.block_state('ancients:double')",
                "components": {
                    "minecraft:collision_box": {
                        "origin": [-8, 0, -8],
                        "size": [16, 8, 16]
                    },
                    "minecraft:selection_box": {
                        "origin": [-8, 0, -8],
                        "size": [16, 8, 16 ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:vertical_half') == 'top' && !q.block_state('ancients:double')",
                "components": {
                    "minecraft:collision_box": {
                        "origin": [-8, 8, -8],
                        "size": [16, 8, 16]
                    },
                    "minecraft:selection_box": {
                        "origin": [-8, 8, -8],
                        "size": [16, 8, 16]
                    }
                }
            },
            {
                "condition": "q.block_state('ancients:double')",
                "components": {
                    "minecraft:geometry": "minecraft:geometry.full_block",
                    "minecraft:custom_components": ["ancients:on_player_destroy"],
					"minecraft:collision_box": true,
                    "minecraft:selection_box": true
                }
            }
        ]
    }
}