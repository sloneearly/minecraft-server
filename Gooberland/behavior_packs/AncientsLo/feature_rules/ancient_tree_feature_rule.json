{
    "format_version": "1.13.0",
    "minecraft:feature_rules": {
      "description": {
        "identifier": "ancients:ancient_tree_feature_rule",
        "places_feature": "ancients:ancient_tree_feature"
      },
      "conditions": {
        "placement_pass": "surface_pass",
        "minecraft:biome_filter": [
            {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "ocean"
            },
            {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "river"
            },
            {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "lakes"
            },
            {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "desert"
            },
            {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "birch_forest"
            },
            {
                "any_of": [
                    {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "forest"
                    },
                    {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "oak_forest"
                    },
                    {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "forest_generation"
                    },
                    {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "swamp"
                    },
                    {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "extreme_hills"
                    },
                    {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "hills"
                    }
                ]
            }
        ]
      },
      "distribution": {
        "iterations": 1,
        "coordinate_eval_order": "zxy",
        "x": {
            "extent": [0, 100],
            "distribution": "uniform"
        },
        "y": "query.heightmap(variable.worldx, variable.worldz)",
        "z": {
            "extent": [0, 100],
            "distribution": "uniform"
        },
        "scatter_chance": {
            "numerator": 1,
            "denominator": 10
        }
      }
    }
  }