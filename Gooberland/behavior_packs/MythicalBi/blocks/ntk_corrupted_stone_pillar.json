{
  "format_version": "1.26.0",
  "minecraft:block": {
    "description": {
      "identifier": "ntk:corrupted_stone_pillar",
      "menu_category": {
				"category": "construction",
				"group": "ntk:itemGroup.name.pillars",
				"is_hidden_in_commands": false
			},
			"traits": {
        "minecraft:placement_position": {
          "enabled_states": [ "minecraft:block_face" ]
        }
			}
    },
    "components": {
      "minecraft:display_name": "%tile.ntk.corrupted_stone_pillar.name",
      "minecraft:geometry": {
        "identifier": "minecraft:geometry.full_block"
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "ntk_corrupted_stone_pillar_side",
          "render_method": "opaque",
          "tint_method": "none",
          //"alpha_masked_tint": false,
          "ambient_occlusion": true,
					"face_dimming": true,
					"isotropic": false
        },
        "up": {
          "texture": "ntk_corrupted_stone_pillar_top",
          "render_method": "opaque",
          "tint_method": "none",
          //"alpha_masked_tint": false,
          "ambient_occlusion": true,
					"face_dimming": true,
					"isotropic": false
        },
        "down": {
          "texture": "ntk_corrupted_stone_pillar_bottom",
          "render_method": "opaque",
          "tint_method": "none",
          //"alpha_masked_tint": false,
          "ambient_occlusion": true,
					"face_dimming": true,
					"isotropic": false
        }
      },
      "minecraft:item_visual": {
        "geometry": {
          "identifier": "geometry.block.ntk_unit_cube"
        },
        "material_instances": {
          "*": {
            "texture": "ntk_corrupted_stone_pillar_side",
            "render_method": "opaque",
            "tint_method": "none",
            //"alpha_masked_tint": false,
            "ambient_occlusion": true,
            "face_dimming": true,
            "isotropic": false
          },
          "up": {
            "texture": "ntk_corrupted_stone_pillar_top",
            "render_method": "opaque",
            "tint_method": "none",
            //"alpha_masked_tint": false,
            "ambient_occlusion": true,
            "face_dimming": true,
            "isotropic": false
          },
          "down": {
            "texture": "ntk_corrupted_stone_pillar_bottom",
            "render_method": "opaque",
            "tint_method": "none",
            //"alpha_masked_tint": false,
            "ambient_occlusion": true,
            "face_dimming": true,
            "isotropic": false
          }
        }
      },
      "minecraft:destruction_particles": {
        "texture": "ntk_corrupted_stone_pillar_side",
        "tint_method": "none",
        "particle_count": 100
      },
      "minecraft:map_color": {
        "tint_method": "none",
        "color": "#3B3B29"
      },
      "minecraft:liquid_detection": {
        "detection_rules": [
          {
            "can_contain_liquid": false,
            "use_liquid_clipping": false,
            "liquid_type": "water",
            "on_liquid_touches": "blocking",
            "stops_liquid_flowing_out_from_direction": [
              "up", "down", "north", "south", "east", "west"
            ]
          }
        ]
      },
      "minecraft:collision_box": [
        {
          "origin": [ -8, 0, -8 ],
          "size": [ 16, 16, 16 ]
        }
      ],
      "minecraft:selection_box": {
        "origin": [ -8, 0, -8 ],
        "size": [ 16, 16, 16 ]
      },
      "minecraft:light_dampening": 15,
      "minecraft:light_emission": 0,
      "minecraft:friction": 0.4,
      "minecraft:flammable": false,
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 30.0
      },
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 1.5
      },
      "minecraft:movable": {
        "movement_type": "push_pull"
      },
      "minecraft:precipitation_interactions": {
        "precipitation_behavior": "obstruct_rain_accumulate_snow"
      },
      "minecraft:redstone_conductivity": {
        "allows_wire_to_step_down": true,
        "redstone_conductor": true
      },
      "minecraft:transformation": {
        "rotation": [ 0, 0, 0 ]
      },
      "minecraft:loot": "loot_tables/mb/blocks/ntk_corrupted_stone_pillar.json",
      // TAGS:
      "tag:ntk:blocks": {},
      "tag:ntk:pickaxe_diggable": {},
      "tag:ntk:full_block": {},
      "tag:ntk:solid_block": {},
      "tag:ntk:stones": {},
      "tag:ntk:corrupted_stone_blocks": {},
      "tag:ntk:pillar_block": {},
      "tag:ntk:corrupted_stone_pillar": {},
      // Vanilla Block Tags:
      "tag:minecraft:is_pickaxe_item_destructible": {}
    },
    "permutations": [
      // X axis:
      {
        "condition": "query.block_state('minecraft:block_face') == 'west' || query.block_state('minecraft:block_face') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 0, 90, -90 ]
          }
        }
      },
      // Y axis:
      {
        "condition": "query.block_state('minecraft:block_face') == 'down' || query.block_state('minecraft:block_face') == 'up'",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "ntk_corrupted_stone_pillar_side",
              "render_method": "opaque",
              "tint_method": "none",
              //"alpha_masked_tint": false,
              "ambient_occlusion": true,
              "face_dimming": true,
              "isotropic": false
            },
            "up": {
              "texture": "ntk_corrupted_stone_pillar_top",
              "render_method": "opaque",
              "tint_method": "none",
              //"alpha_masked_tint": false,
              "ambient_occlusion": true,
              "face_dimming": true,
              "isotropic": false
            },
            "down": {
              "texture": "ntk_corrupted_stone_pillar_top",
              "render_method": "opaque",
              "tint_method": "none",
              //"alpha_masked_tint": false,
              "ambient_occlusion": true,
              "face_dimming": true,
              "isotropic": false
            }
          },
          "minecraft:transformation": {
            "rotation": [ 0, 0, 0 ]
          }
        }
      },
      // Z axis:
      {
        "condition": "query.block_state('minecraft:block_face') == 'north' || query.block_state('minecraft:block_face') == 'south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [ 90, 0, 0 ]
          }
        }
      }
    ]
  }
}
