{
  "format_version": "1.21.40",
  "minecraft:single_block_feature": {
    "description": {
      "identifier": "ntk:mb/corrupted_forest/plant_x_corrupted_oak_sapling_x_singleblock"
    },
    "places_block": [
      {
        "block": "ntk:corrupted_oak_sapling",
        "weight": 100
      }
    ],
    "enforce_survivability_rules": false,
    "enforce_placement_rules": false,
    "randomize_rotation": false,
    "may_replace": [
      { "tags": "query.all_tags('ntk:custom_sprouts')" },
      "minecraft:air",
      // Grass:
      "minecraft:bush",
      "minecraft:fern",
      "minecraft:firefly_bush",
      "minecraft:large_fern",
      "minecraft:short_dry_grass",
      "minecraft:short_grass",
      "minecraft:tall_dry_grass",
      "minecraft:tall_grass",
      // Plants:
      "minecraft:leaf_litter",
      // Flower:
      "minecraft:wildflowers"
    ],
    "may_attach_to": {
      "auto_rotate": false,
      "min_sides_must_attach": 1,
			"bottom": [
        { "tags": "query.all_tags('ntk:stones', 'ntk:corrupted_stone', 'ntk:natural_block', 'ntk:full_block')" },
        { "tags": "query.all_tags('ntk:dirt')" },
        { "tags": "query.all_tags('ntk:moss')" },
        { "tags": "query.all_tags('ntk:mud')" },
        { "tags": "query.all_tags('ntk:bryumed_blocks')" },
			  { "tags": "query.all_tags('ntk:grassed_blocks')" },
        { "tags": "query.all_tags('ntk:mossed_blocks')" },
        { "tags": "query.all_tags('ntk:myceliated_blocks')" },
				// Stone-types:
				"minecraft:hardened_clay",
				"minecraft:stained_hardened_clay",
				// Soil:
				"minecraft:coarse_dirt",
				"minecraft:dirt",
				"minecraft:dirt_with_roots",
				"minecraft:grass_block",
				"minecraft:moss_block",
				"minecraft:mud",
        "minecraft:muddy_mangrove_roots",
				"minecraft:mycelium",
        "minecraft:pale_moss_block",
				"minecraft:podzol",
				"minecraft:red_sand",
				"minecraft:sand",
				"minecraft:suspicious_sand"
			]
		}
  }
}