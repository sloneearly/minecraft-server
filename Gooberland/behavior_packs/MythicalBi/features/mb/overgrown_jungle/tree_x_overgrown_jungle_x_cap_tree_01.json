{
  "format_version": "1.13.0",
  "minecraft:tree_feature": {
    "description": {
      "identifier": "ntk:mb/overgrown_jungle/tree_x_overgrown_jungle_x_cap_tree_01"
    },
    "acacia_trunk": {
      "trunk_block": "ntk:overgrown_jungle_log",
      "trunk_height": {
        "base": 8,
        "intervals": [ 2, 2 ]
      },
      "trunk_width": 1,
      "trunk_lean": {
        "allow_diagonal_growth": true,
        "lean_height": {
          "range_min": 1,
          "range_max": 3
        },
        "lean_steps": {
          "range_min": 0,
          "range_max": 3
        },
        "lean_length": {
					"range_min": 1,
					"range_max": 3
				}
      },
      "trunk_decoration": {
				"decoration_block": "minecraft:vine",
				"decoration_chance": 10.0,
        "num_steps": 2,
        "step_direction": "down"
			}
    },
    "acacia_canopy": {
      "leaf_block": "ntk:overgrown_jungle_leaves",
