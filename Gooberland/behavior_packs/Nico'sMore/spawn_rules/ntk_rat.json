{
  "format_version": "1.8.0",
  "minecraft:spawn_rules": {
    "description": {
      "identifier": "ntk:rat",
      "population_control": "animal"
    },
    "conditions": [
      {
        "minecraft:weight": {
          "default": 5.0
        },
        "minecraft:spawns_on_surface": {},
        
        "minecraft:biome_filter": [
          {
            "all_of": [
              {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "cold"
              },
              {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "frozen"
              },
              {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "ice"
              },
              {
                "test": "has_biome_tag",
                "operator": "!=",
                "value": "extreme_hills"
              },
              {
                "any_of": [
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "corrupted_forest"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "overgrown_jungle"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "plains"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "forest"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "flower_forest"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "pale_garden"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "taiga"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "jungle"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "swamp"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "mangrove_swamp"
                  },
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "savanna"
                  }
                ]
              }
            ]
          }
        ],
        "minecraft:brightness_filter": {
          "adjust_for_weather": false,
          "min": 0,
          "max": 8
        },
        "minecraft:difficulty_filter": {
          "min": "easy",
          "max": "hard"
        },
        "minecraft:herd": [
          {
            "min_size": 1,
            "max_size": 4
            //"event_skip_count": 0,
            //"event": ""
          }
        ],
        "minecraft:spawns_on_block_prevented_filter": [
          { "tags": "query.all_tags('ntk:fungus_block')" },
          { "tags": "query.all_tags('ntk:leaves')" },
          { "tags": "query.all_tags('ntk:log')" },
          // Leaves:
          "minecraft:acacia_leaves",
          "minecraft:azalea_leaves",
          "minecraft:azalea_leaves_flowered",
          "minecraft:birch_leaves",
          "minecraft:cherry_leaves",
          "minecraft:dark_oak_leaves",
          "minecraft:jungle_leaves",
          "minecraft:mangrove_leaves",
          "minecraft:oak_leaves",
          "minecraft:pale_oak_leaves",
          "minecraft:spruce_leaves",
          // Fungus block:
          "minecraft:brown_mushroom_block",
          "minecraft:mushroom_stem",
          "minecraft:nether_wart_block",
          "minecraft:red_mushroom_block",
          "minecraft:shroomlight",
          "minecraft:warped_wart_block"
        ]
      },
      {
        "minecraft:weight": {
          "default": 10.0
        },
        "minecraft:spawns_underground": {},
        
        "minecraft:biome_filter": [
          {
            "all_of": [
              {
                "any_of": [
                  {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "overworld"
                  }
                ]
              }
            ]
          }
        ],
        "minecraft:brightness_filter": {
          "adjust_for_weather": true,
          "min": 0,
          "max": 8
        },
        "minecraft:difficulty_filter": {
          "min": "easy",
          "max": "hard"
        },
        "minecraft:height_filter": {
          "min": -54,
          "max": "query.heightmap(variable.worldx, variable.worldz) + -32"
        },
        "minecraft:herd": [
          {
            "min_size": 1,
            "max_size": 4
            //"event_skip_count": 0,
            //"event": ""
          }
        ],
        "minecraft:spawns_on_block_prevented_filter": [
          { "tags": "query.all_tags('ntk:fungus_block')" },
          { "tags": "query.all_tags('ntk:leaves')" },
          { "tags": "query.all_tags('ntk:log')" },
          // Leaves:
          "minecraft:acacia_leaves",
          "minecraft:azalea_leaves",
          "minecraft:azalea_leaves_flowered",
          "minecraft:birch_leaves",
          "minecraft:cherry_leaves",
          "minecraft:dark_oak_leaves",
          "minecraft:jungle_leaves",
          "minecraft:mangrove_leaves",
          "minecraft:oak_leaves",
          "minecraft:pale_oak_leaves",
          "minecraft:spruce_leaves",
          // Fungus block:
          "minecraft:brown_mushroom_block",
          "minecraft:mushroom_stem",
          "minecraft:nether_wart_block",
          "minecraft:red_mushroom_block",
          "minecraft:shroomlight",
          "minecraft:warped_wart_block"
        ]
      }
    ]
  }
}