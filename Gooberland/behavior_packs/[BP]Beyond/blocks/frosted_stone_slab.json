{
    "format_version": "1.21.60",
    "minecraft:block": {
        "description": {
            "identifier": "honkit26113:frosted_stone_slab",
            "menu_category": {
                "group": "minecraft:itemGroup.name.slab",
                "category": "construction"
            },
            "states": {
                "honkit26113:placeontopside": [0, 1, 2, 3, 4, 5, 6],
                "kai:double": [ false, true ]
            },
            "traits": {
                "minecraft:placement_position": {
                    "enabled_states": [
                        "minecraft:vertical_half"
                    ]
                }
            }
        },
        "components": {
            "tag:minecraft:is_pickaxe_item_destructible": {},
            "tag:honkit26113_dig_with_pickaxe": {},
            "tag:frosted_stone": {},
            "minecraft:map_color": "#576573",
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 5,
                "item_specific_speeds": [
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_pickaxe')"
                        },
                        "destroy_speed": 1.53 // 1.15s
                    }
                ]
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 6
            },
            "minecraft:redstone_conductivity": {
                "allows_wire_to_step_down": true,
                "redstone_conductor": false
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "frosted_stone",
                    "render_method": "alpha_test"
                }
            }
        },
        "permutations": [
            // bottom slab
            {
                "condition": "(q.block_state('minecraft:vertical_half') == 'bottom' && !q.block_state('kai:double')) || q.block_state('honkit26113:placeontopside') == 0 || q.block_state('honkit26113:placeontopside') == 2 || q.block_state('honkit26113:placeontopside') == 3 || q.block_state('honkit26113:placeontopside') == 4 || q.block_state('honkit26113:placeontopside') == 5", // upright
                "components": {
                    "minecraft:custom_components": [ "honkit26113:make_double" ],
                    "minecraft:geometry": "geometry.slab_new",
                    "minecraft:selection_box": {
                        "origin": [-8,0,-8],
                        "size": [16,8,16]
                    },
                    "minecraft:collision_box": {
                        "origin": [-8,0,-8],
                        "size": [16,8,16]
                    },
                    "minecraft:liquid_detection": {
                        "detection_rules": [
                            {
                                "can_contain_liquid": true,
                                "liquid_type": "water",
                                "on_liquid_touches": "no_reaction"
                            }
                        ]
                    },
                    "minecraft:redstone_conductivity": {
                        "allows_wire_to_step_down": false,
                        "redstone_conductor": false
                    },
                    "minecraft:transformation": {
                        "rotation" : [0, 180, 0]
                    },
                    "minecraft:light_dampening": 0
                }
            },
            // top slab
            {
                "condition": "(q.block_state('minecraft:vertical_half') == 'top' && !q.block_state('kai:double')) || q.block_state('honkit26113:placeontopside') == 1.0",
                "components": {
                    "minecraft:custom_components": [ "honkit26113:make_double" ],
                    "minecraft:geometry": "geometry.slab_top_new",
                    "minecraft:selection_box": {
                        "origin": [-8,8,-8],
                        "size": [16,8,16]
                    },
                    "minecraft:collision_box": {
                        "origin": [-8,8,-8],
                        "size": [16,8,16]
                    },
                    "minecraft:liquid_detection": {
                        "detection_rules": [
                            {
                                "can_contain_liquid": true,
                                "liquid_type": "water",
                                "on_liquid_touches": "no_reaction"
                            }
                        ]
                    },
                    "minecraft:transformation": {
                        "rotation" : [0, 180, 0]
                    },
                    "minecraft:light_dampening": 0
                }
            },
            // double slab
            {
                "condition": "q.block_state('kai:double') || query.block_state('honkit26113:placeontopside') == 6.0", // full
                "components": {
                    "minecraft:geometry": "minecraft:geometry.full_block",
                    "minecraft:selection_box": {
                        "origin": [-8,0,-8],
                        "size": [16,16,16]
                    },
                    "minecraft:collision_box": {
                        "origin": [-8,0,-8],
                        "size": [16,16,16]
                    },
                    "minecraft:light_dampening": 15,
                    "minecraft:loot": "loot_tables/blocks/frosted_stone_slab_double.json"
                }
            }
        ]
    }
}