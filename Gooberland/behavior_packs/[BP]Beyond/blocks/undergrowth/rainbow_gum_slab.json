{
    "format_version": "1.21.60",
    "minecraft:block": {
        "description": {
            "identifier": "honkit26113:rainbow_gum_slab",
            "menu_category": {
                "category": "construction",
                "group": "minecraft:itemGroup.name.slab"
            },
            "traits": {
                "minecraft:placement_position": {
                    "enabled_states": [
                        "minecraft:vertical_half"
                    ]
                }
            },
            "states": {
                "kai:double": [ false, true ]
            }
        },
        "components": {
            "tag:minecraft:is_axe_item_destructible": {},
            "tag:honkit26113_dig_with_axe": {},
            "tag:is_slab": {},
            "minecraft:custom_components": [ "kai:slab_on_interact" ],
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 2, // default: 3s
                "item_specific_speeds": [
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_axe')"
                        },
                        "destroy_speed": 2 // 1.5s
                    }
                ]
            },
            "minecraft:destructible_by_explosion": {
                "explosion_resistance": 3
            },
              "minecraft:flammable": {
                "catch_chance_modifier": 20,
                "destroy_chance_modifier": 20
            },
            "minecraft:light_dampening": 0,
            "minecraft:geometry": {
                "identifier": "geometry.kai_slab",
                "bone_visibility": {
                    "bottom_slab": "q.block_state('minecraft:vertical_half') == 'bottom'",
                    "top_slab": "q.block_state('minecraft:vertical_half') == 'top'"
                }
            },
            "minecraft:liquid_detection": {
                "detection_rules": [
                    {
                        "can_contain_liquid": true,
                        "liquid_type": "water",
                        "on_liquid_touches": "no_reaction"
                    }
                ]
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "rainbow_gum_planks"
                }
            }
        },
        "permutations": [
            // Bottom Slab
            {
                "condition": "q.block_state('minecraft:vertical_half') == 'bottom' && !q.block_state('kai:double')",
                "components": {
                    "minecraft:collision_box": {
                        "origin": [-8, 0, -8],
                        "size": [16, 8, 16]
                    },
                    "minecraft:selection_box": {
                        "origin": [-8, 0, -8],
                        "size": [16, 8, 16 ]
                    }
                }
            },
            // Top Slab
            {
                "condition": "q.block_state('minecraft:vertical_half') == 'top' && !q.block_state('kai:double')",
                "components": {
                    "minecraft:collision_box": {
                        "origin": [-8, 8, -8],
                        "size": [16, 8, 16]
                    },
                    "minecraft:selection_box": {
                        "origin": [-8, 8, -8],
                        "size": [16, 8, 16]
                    }
                }
            },
            // Double Slab
            {
                "condition": "q.block_state('kai:double')",
                "components": {
                    "minecraft:geometry": "minecraft:geometry.full_block",
                    "minecraft:liquid_detection": {
                        "detection_rules": [
                            {
                                "can_contain_liquid": false
                            }
                        ]
                    }
                }
            }
        ]
    }
}