{
  "format_version": "1.21.60",
  "minecraft:block": {
    "description": {
      "identifier": "honkit26113:stem_block",
      "traits": {
        "minecraft:placement_position": {
          "enabled_states": [
            "minecraft:block_face"
          ]
        }
      }
    },
    "components": {
        "tag:minecraft:is_axe_item_destructible": {},
      "tag:honkit26113_dig_with_axe": {},
      "minecraft:geometry": "minecraft:geometry.full_block",
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 2, // default: 3s
                "item_specific_speeds": [
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_axe')"
                        },
                        "destroy_speed": 2 // 1.5s
                    }
                ]
            },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 3
      },
      "minecraft:flammable": {
          "catch_chance_modifier": 60,
          "destroy_chance_modifier": 100
      },
      "minecraft:map_color": "#629531",
      "minecraft:material_instances" : {
        "*": {
          "texture": "stem_block_side",
          "render_method" : "opaque"
        },
        "up": {
          "texture": "stem_block_top",
          "render_method" : "opaque"
        },
        "down": {
          "texture": "stem_block_top",
          "render_method" : "opaque"
        }
      }
    },
    "permutations": [
      {
        "condition": "q.block_state('minecraft:block_face') == 'north' || q.block_state('minecraft:block_face') == 'south'", // north & south
        "components": {
          "minecraft:transformation": {
            "rotation" : [90, 0, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:block_face') == 'east' || q.block_state('minecraft:block_face') == 'west'", // east & west
        "components": {
          "minecraft:transformation": {
            "rotation" : [0, 90, -90]
          }
        }
      }
    ]
  }
}