{
  "format_version": "1.12.0",
  "minecraft:entity": {
    "description": {
      "identifier": "honkit26113:thrown_slimeball",
      "runtime_identifier": "minecraft:snowball",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "honkit26113:despawn": {
        "minecraft:instant_despawn": {}
      }
    },
    "components": {
      "minecraft:collision_box": {
        "width": 0.25,
        "height": 0.25
      },
      "minecraft:projectile": {
        "on_hit": {
          "impact_damage": {
            "damage": 5,
            "knockback": true
          },
          //"remove_on_hit": {},
          "definition_event": {
            "affect_projectile": true,
            "event_trigger": {
              "target": "self",
              "event": "hit_ground"
            }
          }
        },
        //"particle": "honkit26113:thrown_slimeball_hit_particle",
        "power": 1.5,
        "gravity": 0.03,
        "angle_offset": 0.0,
        "hit_sound": "hit.slime"
      },
	    "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      }
    },
    "events": {
      "hit_ground": {
        "sequence": [
          {
            "queue_command": {
              "command": "particle honkit26113:thrown_slimeball_hit_particle ~ ~ ~"
            }
          },
          {
            "add": {
              "component_groups": [
                "honkit26113:despawn"
              ]
            }
          }
        ]
      }
    }
  }
}
