{
  "format_version": "1.13.0",
  "minecraft:tree_feature": {
    "description": {
      "identifier": "honkit26113:undergrowth/rainbow_tree_feature"
    },
    "mangrove_roots": {
      "max_root_width": 2,
      "max_root_length": 4,
      "y_offset": {
        "range_min": 1,
        "range_max": 3
      },
      "root_block": {
        "name": "honkit26113:rainbow_gum_log"
      },
      "muddy_root_block": {
        "name": "honkit26113:rainbow_gum_log"
      },
      "mud_block": {
        "name": "minecraft:air"
      },
      "above_root": {
        "above_root_block": "minecraft:red_mushroom",
        "above_root_chance": {
          "numerator": 1,
          "denominator": 4
        }
      },
      "roots_may_grow_through": [
        "minecraft:mud",
        "minecraft:muddy_mangrove_roots",
        "minecraft:mangrove_roots",
        "minecraft:moss_carpet",
        "minecraft:vine",
        "minecraft:mangrove_propagule",
        "minecraft:snow_layer",
        "honkit26113:chromatic_petals"
      ]
    },
    "mangrove_trunk": {
      "trunk_width": 1,
      "trunk_height": {
        "base": 9,
        "height_rand_a": 5,
        "height_rand_b": 7
      },
      "trunk_block": {
        "name": "honkit26113:rainbow_gum_log"
      },
      "branches": {
        "branch_chance": 60.0,
        "branch_length": {
          "range_min": 0,
          "range_max": 3
        },
        "branch_steps": {
          "range_min": 1,
          "range_max": 2
        }
      }
    },

    // canopy 
    "mangrove_canopy": {
      "canopy_height": 5,
      "canopy_radius": 5,
      "leaf_placement_attempts": 55,
      "leaf_blocks": [
        ["honkit26113:rainbow_gum_leaves", 1]
      ],/*
      "canopy_decoration": {
        "decoration_block": "minecraft:vine",
        "decoration_chance": {
          "numerator": 1,
          "denominator": 4
        },
        "num_steps": 4,
        "step_direction": "down"
      },*/
      "hanging_block": {
        "name": "honkit26113:star_jasmine"
      },
      "hanging_block_placement_chance": {
        "numerator": 1,
        "denominator": 8
      }
    },
    // Kinds of blocks the tree can be placed on.
    // We want all kinds of "dirt" blocks: dirt, grass, podzol, mud, etc.
    "may_grow_on": [
      {
        "tags": "query.any_tag('dirt')"
      },
      "honkit26113:cave_turf",
      "honkit26113:deepslate_cave_turf",
      "minecraft:stone"
    ],
    // Whatever kind of "dirt" the tree gets planted on, it will be replaced
    // by an actual Dirt block if it isn't one already.
    // NOTE: Coarse Dirt is a state of Dirt, so it will stay as Coarse Dirt.
    "base_block": [
      "minecraft:dirt",
      "honkit26113:cave_turf",
      "honkit26113:deepslate_cave_turf"
    ],
    // This is used when checking the volume the tree is going to be placed on.
    // Dirt around the placement area doesn't block the tree from being created.
    "may_grow_through": [
      {
        "tags": "query.any_tag('dirt')"
      }
    ],
    // This is used when actually building the tree (trunk and foliage).
    // Air and leaves (and snow on leaves) can be replaced.
    "may_replace": [
      "minecraft:air",
      // Sadly no tags for leaves yet
      "minecraft:leaves",
      "minecraft:leaves2",
      "minecraft:azalea_leaves",
      "minecraft:azalea_leaves_flowered",
      "minecraft:mangrove_leaves",
      "minecraft:snow_layer"
    ]
  }
}
