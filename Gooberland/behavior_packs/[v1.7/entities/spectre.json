{
	"format_version": "1.19.20",
	"minecraft:entity": {
		"description": {
			"identifier": "korbon:spectre",
			"is_spawnable": true,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"despawn": {
				"minecraft:instant_despawn": {}
			},
			"sink": {
				"minecraft:behavior.emerge": {
					"duration": 0.64,
					"on_done": {
						"target": "self",
						"event": "despawn"
					}
				}
			},
			"hostile": {
				"minecraft:behavior.nearest_attackable_target": {
					"priority": 2,
					"must_see": false,
					"reselect_targets": true,
					"within_radius": 16,
					"entity_types": [
						{
							"filters": {
								"any_of": [
									{
										"test": "is_family",
										"subject": "other",
										"value": "null"
									}
								]
							},
							"max_dist": 16
						}
					]
				},
				"minecraft:behavior.melee_attack": {
					"priority": 3,
					"on_attack": {
						"event": "lights_out_attack"
					},
					"melee_fov": 360,
					"speed_multiplier": 2.8,
					"reach_multiplier": 6
				},
				"minecraft:entity_sensor": {
					"minimum_count": 1,
					"sensor_range": 1,
					"event_filters": {
						"test": "is_family",
						"subject": "other",
						"value": "player"
					},
					"event": "jump_to_effect"
				}
			},
			"player_sensor": {
				"minecraft:entity_sensor": {
					"minimum_count": 1,
					"sensor_range": 8,
					"event_filters": {
						"test": "is_family",
						"subject": "other",
						"value": "player"
					},
					"event": "sink"
				}
			},
			"player_sensor_hostile": {
				"minecraft:entity_sensor": {
					"minimum_count": 1,
					"sensor_range": 1,
					"event_filters": {
						"test": "is_family",
						"subject": "other",
						"value": "player"
					},
					"event": "sink"
				}
			}
		},
		"components": {
			"minecraft:is_hidden_when_invisible": {},
			"minecraft:nameable": {},
			"minecraft:type_family": {
				"family": [
					"undead",
					"monster",
					"mob"
				]
			},
			"minecraft:equip_item": {},
			"minecraft:collision_box": {
				"width": 0.6,
				"height": 1.9
			},
			"minecraft:movement.basic": {},
			"minecraft:navigation.walk": {
				"is_amphibious": true,
				"can_pass_doors": true,
				"can_walk": true,
				"can_break_doors": true
			},
			"minecraft:annotation.break_door": {},
			"minecraft:jump.static": {},
			"minecraft:can_climb": {},
			"minecraft:health": {
				"value": 20,
				"max": 20
			},
			"minecraft:hurt_on_condition": {
				"damage_conditions": [
					{
						"filters": {
							"test": "in_lava",
							"subject": "self",
							"operator": "==",
							"value": true
						},
						"cause": "lava",
						"damage_per_tick": 4
					}
				]
			},
			"minecraft:breathable": {
				"total_supply": 15,
				"suffocate_time": 0,
				"breathes_air": true,
				"breathes_water": true
			},
			"minecraft:attack": {
				"damage": 3,
				"effect_name": "instant_damage",
				"effect_duration": 1
			},
			"minecraft:environment_sensor": {
				"triggers": {
					"filters": {
						"test": "is_underwater",
						"operator": "==",
						"value": true
					},
					"event": "minecraft:start_transforming"
				}
			},
			"minecraft:despawn": {
				"despawn_from_distance": {}
			},
			"minecraft:behavior.look_at_player": {
				"priority": 8,
				"look_distance": 128,
				"probability": 100
			},
			"minecraft:behavior.random_look_around": {
				"priority": 9
			},
			"minecraft:behavior.hurt_by_target": {
				"priority": 1
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": true
			},
			"minecraft:conditional_bandwidth_optimization": {},
			"minecraft:movement": {
				"value": 0.23
			},
			"minecraft:lookat": {
				"search_radius": 128,
				"set_target": false,
				"filters": {
					"test": "is_family",
					"operator": "==",
					"value": "player"
				},
				"allow_invulnerable": false,
				"look_event": {
					"event": "looked_at",
					"target": "self"
				}
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "all",
						"deals_damage": false
					}
				]
			},
			"minecraft:behavior.random_stroll": {
				"priority": 20,
				"speed_multiplier": 0.68
			},
			"minecraft:timer": {
				"looping": true,
				"time": [
					60,
					120
				],
				"time_down_event": {
					"event": "despawn",
					"target": "self"
				}
			}
		},
		"events": {
			"despawn": {
				"add": {
					"component_groups": [
						"despawn"
					]
				}
			},
			"sink": {
				"remove": {
					"component_groups": [
						"hostile"
					]
				},
				"add": {
					"component_groups": [
						"sink"
					]
				}
			},
			"hostile": {
				"add": {
					"component_groups": [
						"hostile"
					]
				},
				"remove": {
					"component_groups": [
						"player_sensor"
					]
				},
				"queue_command": {
					"command": "tp @s @p"
				}
			},
			"looked_at": {
				"randomize": [
					{
						"weight": 3,
						"trigger": "sink"
					},
					{
						"weight": 1,
						"trigger": "hostile"
					}
				]
			},
			"jump_to_effect": {
				"sequence": [
					{
						"queue_command": {
							"command": "effect @a[r=3] slowness 15 3 true"
						}
					},
					{
						"queue_command": {
							"command": "effect @a[r=3] weakness 35 0 true"
						}
					},
					{
						"queue_command": {
							"command": "effect @a[r=3] instant_damage 1 0 true"
						}
					},
					{
						"add": {
							"component_groups": [
								"player_sensor_hostile"
							]
						}
					}
				]
			},
			"minecraft:entity_spawned": {
				"add": {
					"component_groups": [
						"player_sensor"
					]
				}
			},
			"lights_out_attack": {
				"sequence": [
					{
						"queue_command": {
							"command": "playsound mob.spectre.attack @a[r=8] ~~~ 0.63"
						}
					},
					{
						"queue_command": {
							"command": "fill ~-12 ~-12 ~-12 ~12 ~12 ~12 air replace torch"
						}
					},
					{
						"trigger": "sink"
					}
				]
			}
		}
	}
}