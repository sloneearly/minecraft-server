{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.cc.delayed_attack": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "transitions": [{ "delayed_attack": "q.is_delayed_attacking" }]
        },
        "delayed_attack": {
          "on_exit": ["/event entity @s cc:delayed_attack"],
          "transitions": [{ "idle": "!q.is_delayed_attacking" }]
        }
      }
    }
  }
}
