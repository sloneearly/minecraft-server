{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.cc.crocodile.movement": {
            "initial_state": "default",
            "states": {
                "default": {
                    "on_entry": [
                        "/event entity @s cc:no_target_turn"
                    ],
                    "transitions": [
                        {
                            "has_target": "!q.is_in_water || q.modified_move_speed > 0.6"
                        }
                    ]
                },
                "has_target": {
                    "on_entry": [
                        "/event entity @s cc:has_target_turn"
                    ],
                    "transitions": [
                        {
                            "default": "q.modified_move_speed < 0.6"
                        }
                    ]
                }
            }
        }
    }
}