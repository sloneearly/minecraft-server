{
  "format_version": "1.26.0",
  "minecraft:block": {
    "description": {
      "identifier": "cc:scroll",
      "menu_category": {
        "category": "construction"
      },
      "states": {
        "cc:open": [false, true]
      },
      "traits": {
        "minecraft:placement_direction": {
          "enabled_states": ["minecraft:cardinal_direction"],
          "y_rotation_offset": 90
        }
      }
    },
    "components": {
      "minecraft:precipitation_interactions": {
        "precipitation_behavior": "none"
      },
      "minecraft:display_name": "%cc.scroll\n%cc.category.trinkets",
      "cc:interact": {},
      "tag:grass": {},
      "minecraft:destructible_by_mining": true,
      "minecraft:destructible_by_explosion": true,
      "minecraft:geometry": {
        "identifier": "geometry.cc.scroll",
        "bone_visibility": {
          "open": "q.block_state('cc:open') == 1",
          "closed": "q.block_state('cc:open') == 0"
        }
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "cc:scroll_closed",
          "render_method": "alpha_test"
        }
      },
      "minecraft:collision_box": false,
      "minecraft:selection_box": {
        "origin": [-6, 0, -2],
        "size": [12, 2, 4]
      },
      "minecraft:light_dampening": 0,
      "minecraft:map_color": "#f8eebb",
      "minecraft:liquid_detection": {
        "detection_rules": [
          {
            "can_contain_liquid": true,
            "liquid_type": "water",
            "on_liquid_touches": "no_reaction"
          }
        ]
      },
      "minecraft:support": {
        "shape": "stair"
      },
      "minecraft:connection_rule": {
        "accepts_connections_from": "none"
      }
    },
    "permutations": [
      {
        "condition": "q.block_state('cc:open') == 1",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "cc:scroll_open",
              "render_method": "alpha_test"
            }
          },
          "minecraft:selection_box": {
            "origin": [-6, 0, -6],
            "size": [12, 2, 12]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 90, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 0, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, -90, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 180, 0]
          }
        }
      }
    ]
  }
}
