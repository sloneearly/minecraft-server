{
  "format_version": "1.21.130",
  "minecraft:block": {
    "description": {
      "identifier": "cc:chicken_feast",
      "menu_category": {
        "category": "equipment",
        "group": "minecraft:itemGroup.name.cookedFood"
      },
      "states": {
        "cc:fill": [4, 3, 2, 1, 0]
      },
      "traits": {
        "minecraft:placement_direction": {
          "enabled_states": ["minecraft:cardinal_direction"],
          "y_rotation_offset": 0
        }
      }
    },
    "components": {
      "minecraft:precipitation_interactions": {
        "precipitation_behavior": "none"
      },
      "tag:cc:disable_silk_touch": {},
      "minecraft:liquid_detection": {
        "detection_rules": [
          {
            "on_liquid_touches": "popped"
          }
        ]
      },
      //      "cc:transform_block": {},
      "tag:nonsolid": {},
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.0
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 0
      },
      "minecraft:geometry": {
        "identifier": "geometry.cc.chicken_feast",
        "bone_visibility": {
          "fill_1": "q.block_state('cc:fill') > 0",
          "fill_2": "q.block_state('cc:fill') > 1",
          "fill_3": "q.block_state('cc:fill') > 2",
          "fill_4": "q.block_state('cc:fill') > 3"
        }
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "cc:chicken_feast",
          "render_method": "alpha_test"
        },
        "bowl_side": {
          "texture": "cc:bowl_side",
          "render_method": "alpha_test"
        },
        "bowl_bottom": {
          "texture": "cc:bowl_bottom",
          "render_method": "alpha_test"
        },
        "bowl_top": {
          "texture": "cc:bowl_top_chicken",
          "render_method": "alpha_test"
        },
        "down": {
          "texture": "cc:bowl_top_chicken",
          "render_method": "alpha_test"
        }
      },
      "minecraft:collision_box": {
        "origin": [-7, 0, -7],
        "size": [14, 8, 14]
      },
      "minecraft:selection_box": {
        "origin": [-7, 0, -7],
        "size": [14, 8, 14]
      },
      "minecraft:light_dampening": 0,
      "minecraft:map_color": "#8a5b3d"
    },
    "permutations": [
      {
        "condition": "query.block_state('cc:fill') < 4",
        "components": {
          "minecraft:loot": "loot_tables/cc/cooking/bowl.loot.json"
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 0, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, -90, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 180, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 90, 0]
          }
        }
      }
    ]
  }
}
