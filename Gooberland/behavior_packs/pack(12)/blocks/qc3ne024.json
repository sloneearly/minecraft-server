{
    "format_version": "1.26.0",
    "minecraft:block": {
        "description": {
            "identifier": "cc:gray_awning",
            "menu_category": {
                "category": "construction"
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": [
                        "minecraft:cardinal_direction"
                    ],
                    "y_rotation_offset": 0
                },
                "minecraft:placement_position": {
                    "enabled_states": [
                        "minecraft:vertical_half"
                    ]
                }
            }
        },
        "components": {
            "minecraft:precipitation_interactions": {
                "precipitation_behavior": "none"
            },
            "minecraft:support": {
                "shape": "stair"
            },
            "minecraft:connection_rule": {
                "accepts_connections_from": "none"
            },
            "minecraft:display_name": "%cc.gray_awning\n%cc.category.furniture",
            "minecraft:destructible_by_explosion": true,
            "minecraft:geometry": {
                "identifier": "geometry.cc.awning"
            },
            "minecraft:material_instances": {
                "*": {
                    "texture": "cc:awning_gray",
                    "render_method": "alpha_test"
                },
                "awning_wood": {
                    "texture": "cc:board_spruce",
                    "render_method": "alpha_test"
                }
            },
            "minecraft:collision_box": {
                "origin": [
                    -8,
                    0,
                    -8
                ],
                "size": [
                    16,
                    9,
                    16
                ]
            },
            "minecraft:selection_box": {
                "origin": [
                    -8,
                    0,
                    -8
                ],
                "size": [
                    16,
                    9,
                    16
                ]
            },
            "minecraft:light_dampening": 0,
            "minecraft:map_color": "#666666",
            "minecraft:liquid_detection": {
                "detection_rules": [
                    {
                        "can_contain_liquid": true,
                        "liquid_type": "water",
                        "on_liquid_touches": "no_reaction"
                    }
                ]
            },
            "tag:minecraft:is_axe_item_destructible": {},
            "minecraft:destructible_by_mining": {
                "seconds_to_destroy": 2,
                "item_specific_speeds": [
                    {
                        "item": {
                            "tags": "query.all_tags('minecraft:is_axe')"
                        },
                        "destroy_speed": 2
                    }
                ]
            }
        },
        "permutations": [
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            180,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            90,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            0,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            -90,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'north' && q.block_state('minecraft:vertical_half') == 'top'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            180,
                            0
                        ],
                        "translation": [
                            0,
                            0.5,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'east' && q.block_state('minecraft:vertical_half') == 'top'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            90,
                            0
                        ],
                        "translation": [
                            0,
                            0.5,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'south' && q.block_state('minecraft:vertical_half') == 'top'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            0,
                            0
                        ],
                        "translation": [
                            0,
                            0.5,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'west' && q.block_state('minecraft:vertical_half') == 'top'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            -90,
                            0
                        ],
                        "translation": [
                            0,
                            0.5,
                            0
                        ]
                    }
                }
            }
        ]
    }
}