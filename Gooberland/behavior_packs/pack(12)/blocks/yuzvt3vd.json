                    "minecraft:light_emission": 15,
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "cc:ice_ritual_side_active",
                            "render_method": "opaque"
                        },
                        "up": {
                            "texture": "cc:ice_ritual_top_active",
                            "render_method": "opaque"
                        },
                        "down": {
                            "texture": "cc:ice_ritual_top_active",
                            "render_method": "opaque"
                        }
                    }
