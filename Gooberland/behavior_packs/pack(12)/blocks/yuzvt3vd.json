            "menu_category": {
                "category": "nature"
            },
            "states": {
                "cc:ritual_state": [
                    "inactive",
                    "active",
                    "used"
                ]
            }
        },
        "components": {
            "tag:cc:disable_silk_touch": {},
            "tag:solid": {},
            "cc:ritual": {},
            "cc:transform_block": {},
            "minecraft:map_color": "#787471",
            "minecraft:geometry": "minecraft:geometry.full_block",
            "minecraft:material_instances": {
                "*": {
                    "texture": "cc:ice_ritual_side_inactive",
                    "render_method": "opaque"
                },
                "up": {
