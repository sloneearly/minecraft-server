{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "cc:orangutan",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false,
            "properties": {
                "cc:barter_amount": {
                    "client_sync": false,
                    "default": 0,
                    "type": "int",
                    "range": [
                        0,
                        4
                    ]
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [
                    "orangutan",
                    "mob",
                    "animal"
                ]
            },
            "minecraft:breathable": {
                "total_supply": 15,
                "suffocate_time": 0
            },
            "minecraft:navigation.walk": {
                "can_path_over_water": true,
                "avoid_water": true,
                "avoid_damage_blocks": true
            },
            "minecraft:movement.basic": {},
            "minecraft:jump.static": {},
            "minecraft:can_climb": {},
            "minecraft:collision_box": {
                "width": 0.7,
                "height": 2
            },
            "minecraft:nameable": {},
            "minecraft:health": {
                "value": 20,
                "max": 20
            },
            "minecraft:hurt_on_condition": {
                "damage_conditions": [
                    {
                        "filters": {
                            "test": "in_lava",
                            "subject": "self",
                            "operator": "==",
                            "value": true
                        },
                        "cause": "lava",
                        "damage_per_tick": 4
                    }
                ]
            },
            "minecraft:movement": {
                "value": 0.3
            },
            "minecraft:sittable": {},
            "minecraft:despawn": {
                "despawn_from_distance": {}
            },
            "minecraft:behavior.float": {
                "priority": 0
            },
            "minecraft:behavior.panic": {
                "priority": 1,
                "speed_multiplier": 1.0
            },
            "minecraft:behavior.mount_pathing": {
                "priority": 2,
                "speed_multiplier": 1.0,
                "target_dist": 0.0,
                "track_target": true
            },
            "minecraft:behavior.breed": {
                "priority": 3,
                "speed_multiplier": 1.0
            },
            "minecraft:inventory": {
                "private": true,
                "inventory_size": 1
            },
            "minecraft:behavior.tempt": {
                "priority": 4,
                "speed_multiplier": 1.0,
                "items": [
                    "cc:banana"
                ]
            },
            "minecraft:behavior.follow_parent": {
                "priority": 5,
                "speed_multiplier": 1.0
            },
            "minecraft:behavior.random_stroll": {
                "priority": 6,
                "speed_multiplier": 0.5
            },
            "minecraft:behavior.random_look_around_and_sit": {
                "priority": 4,
                "continue_if_leashed": true,
                "continue_sitting_on_reload": true,
                "min_look_count": 2,
                "max_look_count": 5,
                "min_look_time": 80,
                "max_look_time": 100,
                "min_angle_of_view_horizontal": -30,
                "max_angle_of_view_horizontal": 30,
                "random_look_around_cooldown": 5,
                "probability": 0.001
            },
            "minecraft:behavior.look_at_player": {
                "priority": 7,
                "look_distance": 6.0,
                "probability": 0.02
            },
            "minecraft:behavior.random_look_around": {
                "priority": 9
            },
            "minecraft:leashable": {
                "soft_distance": 4.0,
                "hard_distance": 6.0,
                "max_distance": 10.0
            },
            "minecraft:balloonable": {},
            "minecraft:physics": {},
            "minecraft:pushable": {
                "is_pushable": true,
                "is_pushable_by_piston": true
            },
            "minecraft:conditional_bandwidth_optimization": {},
            "minecraft:behavior.avoid_mob_type": {
                "priority": 4,
                "entity_types": [
                    {
                        "filters": {
                            "any_of": [
                                {
                                    "test": "is_family",
                                    "subject": "other",
                                    "value": "tiger"
                                }
                            ]
                        },
                        "max_dist": 10,
                        "walk_speed_multiplier": 1.0,
                        "sprint_speed_multiplier": 1.2
                    }
                ]
            }
        },
        "component_groups": {
            "minecraft:orangutan_adult": {
                "minecraft:experience_reward": {
                    "on_bred": "Math.Random(1,7)",
                    "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
                },
                "minecraft:behavior.breed": {
                    "priority": 3,
                    "speed_multiplier": 1.0
                },
                "minecraft:breedable": {
                    "require_tame": false,
                    "breed_items": "cc:banana",
                    "breeds_with": {
                        "mate_type": "cc:orangutan",
                        "baby_type": "cc:orangutan",
                        "breed_event": {
                            "event": "minecraft:entity_born",
                            "target": "baby"
                        }
                    }
                }
            },
            "minecraft:orangutan_baby": {
                "minecraft:is_baby": {},
                "minecraft:scale": {
                    "value": 0.5
                },
                "minecraft:ageable": {
                    "duration": 1200,
                    "feed_items": "cc:banana",
                    "grow_up": {
                        "event": "minecraft:ageable_grow_up",
                        "target": "self"
                    }
                },
                "minecraft:behavior.follow_parent": {
                    "priority": 6,
                    "speed_multiplier": 1.0
                }
            },
            "cc:barter": {
                "minecraft:behavior.pickup_items": {
                    "priority": 6,
                    "max_dist": 10,
                    "goal_radius": 2,
                    "speed_multiplier": 0.8,
                    "pickup_based_on_chance": false,
                    "can_pickup_any_item": false,
                    "cooldown_after_being_attacked": 20.0,
                    "can_pickup_to_hand_or_equipment": true
                },
                "minecraft:shareables": {
                    "singular_pickup": true,
                    "items": [
                        {
                            "priority": 1,
                            "item": "cc:banana",
                            "barter": true,
                            "admire": true,
                            "pickup_limit": 1
                        }
                    ]
                },
                "minecraft:behavior.admire_item": {
                    "priority": 2,
                    "admire_item_sound": "admire",
                    "sound_interval": {
                        "range_min": 2.0,
                        "range_max": 5.0
                    },
                    "on_admire_item_stop": {
                        "event": "cc:barter_loot",
                        "target": "self"
                    }
                },
                "minecraft:admire_item": {
                    "cooldown_after_being_attacked": 20,
                    "duration": 8
                }
            },
            "cc:angry": {
                "minecraft:behavior.ranged_attack": {
                    "priority": 0,
                    "charge_charged_trigger": 0.8,
                    "charge_shoot_trigger": 1.25,
                    "attack_radius": 20.0
                },
                "minecraft:shooter": {
                    "def": "cc:dummy_projectile",
                    "sound": "bow"
                },
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 2,
                    "must_see": true,
                    "reselect_targets": true,
                    "within_radius": 25.0,
                    "must_see_forget_duration": 17.0,
                    "entity_types": [
                        {
                            "filters": {
                                "any_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    }
                                ]
                            },
                            "max_dist": 35
                        }
                    ]
                }
            },
            "cc:barter_timer": {
                "minecraft:timer": {
                    "time": 60,
                    "looping": true,
                    "time_down_event": {
                        "event": "cc:lower_barter_amount",
                        "target": "self"
                    }
                }
            },
            "cc:persistence": {
                "minecraft:persistent": {}
            },
            "cc:angry_timer": {
                "minecraft:timer": {
                    "time": [
                        30,
                        60
                    ],
                    "looping": true,
                    "time_down_event": {
                        "event": "cc:calm",
                        "target": "self"
                    }
                }
            }
        },
        "events": {
            "cc:lower_barter_amount": {
                "sequence": [
                    {
                        "filters": [
                            {
                                "all_of": [
                                    {
                                        "test": "int_property",
                                        "subject": "self",
                                        "domain": "cc:barter_amount",
                                        "operator": ">",
                                        "value": 0
                                    },
                                    {
                                        "test": "int_property",
                                        "subject": "self",
                                        "domain": "cc:barter_amount",
                                        "operator": "<=",
                                        "value": 3
                                    }
                                ]
                            }
                        ],
                        "set_property": {
                            "cc:barter_amount": "q.property('cc:barter_amount') - 1"
                        }
                    }
                ]
            },
            "cc:barter_loot": {
                "sequence": [
                    {
                        "queue_command": {
                            "command": "loot spawn ~~1~ loot \"cc/animals/orangutan_barter.loot\""
                        }
                    },
                    {
                        "filters": [
                            {
                                "test": "int_property",
                                "subject": "self",
                                "domain": "cc:barter_amount",
                                "operator": "<=",
                                "value": 3
                            }
                        ],
                        "set_property": {
                            "cc:barter_amount": "q.property('cc:barter_amount') + 1"
                        }
                    },
                    {
                        "filters": [
                            {
                                "test": "int_property",
                                "subject": "self",
                                "domain": "cc:barter_amount",
                                "operator": "==",
                                "value": 4
                            }
                        ],
                        "add": {
                            "component_groups": [
                                "cc:angry",
                                "cc:angry_timer"
                            ]
                        },
                        "remove": {
                            "component_groups": [
                                "cc:barter",
                                "cc:barter_timer"
                            ]
                        }
                    }
                ]
            },
            "cc:calm": {
                "add": {
                    "component_groups": [
                        "cc:barter",
                        "cc:barter_timer"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "cc:angry",
                        "cc:angry_timer"
                    ]
                },
                "set_property": {
                    "cc:barter_amount": 0
                }
            },
            "cc:stop_riding": {},
            "minecraft:entity_spawned": {
                "randomize": [
                    {
                        "weight": 95,
                        "add": {
                            "component_groups": [
                                "minecraft:orangutan_adult",
                                "cc:barter",
                                "cc:barter_timer"
                            ]
                        }
                    },
                    {
                        "weight": 5,
                        "add": {
                            "component_groups": [
                                "minecraft:orangutan_baby"
                            ]
                        }
                    }
                ]
            },
            "minecraft:entity_born": {
                "add": {
                    "component_groups": [
                        "minecraft:orangutan_baby"
                    ]
                }
            },
            "minecraft:entity_transformed": {
                "remove": {},
                "add": {
                    "component_groups": [
                        "minecraft:orangutan_adult",
                        "cc:barter",
                        "cc:barter_timer"
                    ]
                }
            },
            "minecraft:ageable_grow_up": {
                "remove": {
                    "component_groups": [
                        "minecraft:orangutan_baby"
                    ]
                },
                "add": {
                    "component_groups": [
                        "minecraft:orangutan_adult",
                        "cc:barter",
                        "cc:barter_timer"
                    ]
                }
            },
            "cc:persistence": {
                "add": {
                    "component_groups": [
                        "cc:persistence"
                    ]
                }
            }
        }
    }
}