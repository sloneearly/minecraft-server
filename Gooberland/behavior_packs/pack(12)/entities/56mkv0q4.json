{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cc:lightning_spider",
      "spawn_category": "monster",
      "is_spawnable": true,
      "is_summonable": true,
      "properties": {
        "cc:attack_mode": {
          "client_sync": false,
          "type": "enum",
          "default": "ranged",
          "values": ["ranged", "melee"]
        }
      },
      "animations": {
        "delayed_attack": "controller.animation.cc.delayed_attack"
      },
      "scripts": {
        "animate": ["delayed_attack"]
      }
    },
    "component_groups": {
      "cc:persistence": {
        "minecraft:persistent": {}
      },
      "cc:cooldown": {
        "minecraft:timer": {
          "time": 3,
          "looping": true,
          "time_down_event": {
            "event": "cc:attack",
            "target": "self"
          }
        },
        "minecraft:behavior.melee_attack": {},
        "minecraft:attack": {
          "damage": 1
        }
      },
      "cc:attack": {
        "minecraft:behavior.delayed_attack": {
          "priority": 0,
          "attack_once": false,
          "attack_duration": 0.5,
          "hit_delay_pct": 1.0,
          "reach_multiplier": 6,
          "track_target": true
        },
        "minecraft:attack": {
          "damage": 6
        }
      }
    },
    "components": {
      "minecraft:scale": {
        "value": 0.8
      },
      "minecraft:fire_immune": {},
      "minecraft:behavior.float": {
        "priority": 1
      },
      "minecraft:navigation.climb": {
        "can_path_over_water": true
      },
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:experience_reward": {
        "on_death": 25
      },
      "minecraft:collision_box": {
        "width": 1.4,
        "height": 0.9
      },
      "minecraft:type_family": {
        "family": ["spider", "arthropod", "monster", "mob"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 1,
        "breathes_water": false
      },
      "minecraft:health": {
        "value": 16,
        "max": 16
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:loot": {
        "table": "loot_tables/entities/spider.json"
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:nameable": {},
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 1,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "operator": "!=",
              "value": "breeze"
            }
          }
        ]
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "must_see": true,
        "reselect_targets": true,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "player"
            },
            "max_dist": 24
          },
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "irongolem"
            },
            "max_dist": 24
          },
          {
            "filters": {
              "all_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "baby_turtle"
                },
                {
                  "test": "in_water",
                  "subject": "other",
                  "operator": "!=",
                  "value": true
                }
              ]
            },
            "max_dist": 24
          }
        ]
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 1
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 8
      },
      "minecraft:behavior.random_look_around": {
        "priority": 8
      },
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "trigger": "cc:attack"
      },
      "cc:delayed_attack": {
        "queue_command": {
          "command": ["scriptevent cc:entity_event ground_smash"]
        },
        "trigger": "cc:cooldown"
      },
      "cc:cooldown": {
        "add": {
          "component_groups": ["cc:cooldown"]
        },
        "remove": {
          "component_groups": ["cc:attack"]
        }
      },
      "cc:attack": {
        "add": {
          "component_groups": ["cc:attack"]
        },
        "remove": {
          "component_groups": ["cc:cooldown"]
        }
      },
      "cc:persistence": {
        "add": {
          "component_groups": [
            "cc:persistence"
          ]
        }
      }
    }
  }
}
