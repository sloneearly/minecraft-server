{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cc:fire_spider",
      "spawn_category": "monster",
      "is_spawnable": true,
      "is_summonable": true,
      "properties": {
        "cc:attack_mode": {
          "client_sync": false,
          "type": "enum",
          "default": "ranged",
          "values": [
            "ranged",
            "melee"
          ]
        }
      }
    },
    "component_groups": {
      "cc:persistence": {
        "minecraft:persistent": {}
      },
      "ranged_attack": {
        "minecraft:behavior.ranged_attack": {
          "priority": 0,
          "charge_charged_trigger": 0.75,
          "charge_shoot_trigger": 1.25,
          "attack_radius": 20.0
        },
        "minecraft:shooter": {
          "def": "cc:dummy_projectile",
          "sound": "bow"
        }
      },
      "melee_attack": {
        "minecraft:behavior.melee_box_attack": {
          "priority": 3,
          "track_target": true
        },
        "minecraft:behavior.leap_at_target": {
          "priority": 4,
          "yd": 0.4,
          "must_be_on_ground": false
        },
        "minecraft:attack": {
          "damage": 2
        }
      }
    },
    "components": {
      "minecraft:scale": {
        "value": 0.8
      },
      "minecraft:behavior.float": {
        "priority": 1
      },
      "minecraft:navigation.climb": {
        "can_path_over_water": true
      },
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:experience_reward": {
        "on_death": 25
      },
      "minecraft:collision_box": {
        "width": 1.4,
        "height": 0.9
      },
      "minecraft:type_family": {
        "family": [
          "spider",
          "arthropod",
          "monster",
          "mob"
        ]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 1,
        "breathes_water": false
      },
      "minecraft:health": {
        "value": 16,
        "max": 16
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_contact_with_water",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "drowning",
            "damage_per_tick": 2
          }
        ]
      },
      "minecraft:loot": {
        "table": "loot_tables/entities/spider.json"
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:nameable": {},
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 1,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "operator": "!=",
              "value": "breeze"
            }
          }
        ]
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "must_see": true,
        "reselect_targets": true,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "player"
            },
            "max_dist": 24
          },
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "irongolem"
            },
            "max_dist": 24
          },
          {
            "filters": {
              "all_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "baby_turtle"
                },
                {
                  "test": "in_water",
                  "subject": "other",
                  "operator": "!=",
                  "value": true
                }
              ]
            },
            "max_dist": 24
          }
        ]
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 1
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 8
      },
      "minecraft:behavior.random_look_around": {
        "priority": 8
      },
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:timer": {
        "time": 0.1,
        "looping": true,
        "time_down_event": {
          "event": "cc:mode_switcher",
          "target": "self"
        }
      },
      "minecraft:fire_immune": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "trigger": "cc:ranged_mode"
      },
      "cc:mode_switcher": {
        "sequence": [
          {
            "filters": [
              {
                "all_of": [
                  {
                    "test": "target_distance",
                    "operator": "<=",
                    "value": 6
                  },
                  {
                    "test": "enum_property",
                    "domain": "cc:attack_mode",
                    "operator": "!=",
                    "value": "melee"
                  }
                ]
              }
            ],
            "trigger": "cc:melee_mode"
          },
          {
            "filters": [
              {
                "all_of": [
                  {
                    "test": "target_distance",
                    "operator": ">",
                    "value": 6
                  },
                  {
                    "test": "enum_property",
                    "domain": "cc:attack_mode",
                    "operator": "!=",
                    "value": "ranged"
                  }
                ]
              }
            ],
            "trigger": "cc:ranged_mode"
          }
        ]
      },
      "cc:melee_mode": {
        "add": {
          "component_groups": [
            "melee_attack"
          ]
        },
        "remove": {
          "component_groups": [
            "ranged_attack"
          ]
        },
        "set_property": {
          "cc:attack_mode": "melee"
        }
      },
      "cc:ranged_mode": {
        "add": {
          "component_groups": [
            "ranged_attack"
          ]
        },
        "remove": {
          "component_groups": [
            "melee_attack"
          ]
        },
        "set_property": {
          "cc:attack_mode": "ranged"
        }
      },
      "cc:persistence": {
        "add": {
          "component_groups": [
            "cc:persistence"
          ]
        }
      }
    }
  }
}