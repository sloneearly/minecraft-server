{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cc:penguin",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "cc:holding_fish": {
          "client_sync": true,
          "default": "none",
          "type": "enum",
          "values": ["none", "cod", "salmon"]
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["penguin", "mob", "animal"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_water": true,
        "breathes_air": true,
        "generates_bubbles": true
      },
      "minecraft:home": {
      },
      "minecraft:navigation.generic": {
        "avoid_damage_blocks": false,
        "avoid_portals": false,
        "avoid_sun": false,
        "avoid_water": false,
        "blocks_to_avoid": [],
        "can_breach": false,
        "can_break_doors": false,
        "can_jump": true,
        "can_open_doors": false,
        "can_open_iron_doors": false,
        "can_pass_doors": false,
        "can_path_from_air": false,
        "can_path_over_lava": false,
        "can_path_over_water": false,
        "can_sink": false,
        "can_swim": true,
        "can_walk": true,
        "can_walk_in_lava": false,
        "is_amphibious": true
      },
      "minecraft:movement.amphibious": {
        "max_turn": 30
      },
      "minecraft:underwater_movement": {
        "value": 0.2
      },
      "minecraft:jump.static": {
        "jump_power": 0.42
      },
      "minecraft:nameable": {},
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:behavior.avoid_mob_type": {
        "priority": 1,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "seal" },
                { "test": "is_family", "subject": "other", "value": "orca" }
              ]
            },
            "max_dist": 10,
            "walk_speed_multiplier": 1,
            "sprint_speed_multiplier": 2
          }
        ]
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": { "test": "in_lava", "subject": "self", "operator": "==", "value": true },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:can_climb": {},
      "minecraft:balloonable": {},
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {}
    },
    "component_groups": {
      "cc:gather_fish": {
        "minecraft:attack": {
          "damage": 0
        },
        "minecraft:behavior.melee_attack": {},
        "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "must_see": true,
        "reselect_targets": true,
        "within_radius": 25.0,
        "must_see_forget_duration": 17.0,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "salmon" },
                { "test": "is_family", "subject": "other", "value": "cod" }
              ]
            },
            "max_dist": 35
          }
        ]
      }
      },
      "minecraft:animal_adult": {
        "minecraft:variant": { "value": 1 },
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:movement": {
          "value": 0.15
        },
        "minecraft:health": {
          "value": 5,
          "max": 5
        },
        "minecraft:behavior.look_at_player": {
          "priority": 7,
          "look_distance": 6.0,
          "probability": 0.02
        },
        "minecraft:behavior.random_look_around": {
          "priority": 9
        },
        "minecraft:leashable": {
          "soft_distance": 4.0,
          "hard_distance": 6.0,
          "max_distance": 10.0
        },
        "minecraft:behavior.random_swim": {
          "avoid_surface": false,
          "interval": 120,
          "xz_dist": 10,
          "y_dist": 7
        },
        "minecraft:behavior.follow_parent": {
          "priority": 5,
          "speed_multiplier": 1.1
        },
        "minecraft:behavior.random_stroll": {
          "priority": 6,
          "speed_multiplier": 1
        },
        "minecraft:behavior.panic": {
          "priority": 1,
          "speed_multiplier": 1.3
        },
        "minecraft:behavior.breed": {
          "priority": 3,
          "speed_multiplier": 1.0
        },
        "minecraft:behavior.tempt": {
          "priority": 2,
          "speed_multiplier": 1.8,
          "items": ["cod", "salmon"]
        },
        "minecraft:collision_box": {
          "width": 0.5,
          "height": 1.25
        },
        "minecraft:breedable": {
          "require_tame": false,
          "breed_items": ["cod", "salmon"],
          "causes_pregnancy": true,
          "breeds_with": {
            "mate_type": "cc:penguin",
            "breed_event": {
              "event": "cc:become_pregnant",
              "target": "self"
            }
          }
        },
        "minecraft:interact": {
          "interactions": [
            {
              "on_interact": {
                "filters": [
                  {
                    "all_of": [
                      {
                        "test": "enum_property",
                        "domain": "cc:holding_fish",
                        "subject": "self",
                        "operator": "!=",
                        "value": "none"
                      }
                    ]
                  }
                ],
                "target": "self",
                "event": "cc:interact"
              }
            }
          ]
        }
      },
      "minecraft:animal_baby": {
        "minecraft:variant": { "value": 2 },
        "minecraft:is_baby": {},
        "minecraft:movement": {
          "value": 0.15
        },
        "minecraft:jump.static": {},
        "minecraft:can_climb": {},
        "minecraft:nameable": {},
        "minecraft:health": {
          "value": 10,
          "max": 10
        },
        "minecraft:behavior.look_at_player": {
          "priority": 7,
          "look_distance": 6.0,
          "probability": 0.02
        },
        "minecraft:behavior.random_look_around": {
          "priority": 9
        },
        "minecraft:behavior.random_swim": {
          "avoid_surface": false,
          "interval": 120,
          "xz_dist": 10,
          "y_dist": 7
        },
        "minecraft:behavior.follow_parent": {
          "priority": 5,
          "speed_multiplier": 1.1
        },
        "minecraft:behavior.random_stroll": {
          "priority": 6,
          "speed_multiplier": 0.8
        },
        "minecraft:behavior.panic": {
          "priority": 1,
          "speed_multiplier": 1.25
        },
        "minecraft:behavior.tempt": {
          "priority": 4,
          "speed_multiplier": 1.1,
          "items": ["cod", "salmon"]
        },
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": ["cod", "salmon"],
          "grow_up": {
            "event": "minecraft:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:scale": {
          "value": 0.8
        },
        "minecraft:collision_box": {
          "width": 0.3,
          "height": 1
        }
      },
      "cc:wants_to_lay_egg": {
        "minecraft:behavior.lay_egg": {
          "goal_radius": 1.5,
          "search_height": 4,
          "search_range": 16,
          "priority": 0,
          "egg_type": "minecraft:air",
          "target_blocks": [
            "minecraft:sand",
            "minecraft:ice",
            "minecraft:snow",
            "minecraft:grass_block",
            "minecraft:packed_ice",
            "minecraft:stone",
            "minecraft:moss_block"
          ],
          "lay_egg_sound": "random.pop",
          "speed_multiplier": 0.8,
          "use_default_animation": true,          
          "on_lay": {
            "event": "cc:lay_egg",
            "target": "self"
          }
        }
      },
      "cc:persistence": {
        "minecraft:persistent": {}
      },
      "cc:pregnant": {
        "minecraft:behavior.go_home": {
          "priority": 1,
          "goal_radius": 4,
          "interval": 700,
          "speed_multiplier": 1.3,
          "on_home": {
            "target": "self",
            "event": "cc:reach_home"
          }
        }
      }
    },
    "events": {
      "cc:lay_egg": {
        "sequence": [
          {
            "queue_command": {
              "command": "setblock ~ ~ ~ cc:penguin_egg"
            }
          },
          {
            "remove": {
              "component_groups": ["cc:wants_to_lay_egg"]
            }
          }
        ]
      },
      "cc:reach_home": {
        "add": {
          "component_groups": [
            "cc:wants_to_lay_egg"
          ]
        },
        "remove": {
          "component_groups": [
            "cc:pregnant"
          ]
        }
      },
      "cc:become_pregnant": {
        "add": {
          "component_groups": [
            "cc:pregnant"
          ]
        }
      },
      "cc:interact": {
        "sequence": [
          {
            "filters": [
              {
                "test": "enum_property",
                "domain": "cc:holding_fish",
                "value": "cod"
                
              }
            ],
            "queue_command": {
              "command": "loot spawn ~ ~ ~ loot \"entities/fish\""
            }
          },
          {
            "filters": [
              {
                "test": "enum_property",
                "domain": "cc:holding_fish",
                "value": "salmon"
                
              }
            ],
            "queue_command": {
              "command": "loot spawn ~ ~ ~ loot \"entities/salmon_large\""
            }
          },
          {
            "queue_command": {
              "command": "playsound random.pop @a[r=15] ~ ~ ~ 1 1 1"
            },
            "set_property": {
              "cc:holding_fish": "none"
            },
            "trigger": "cc:gather_fish"
          }
        ]
      },
      "minecraft:ageable_grow_up": {
        "add": {
          "component_groups": ["minecraft:animal_adult", "cc:gather_fish"]
        },
        "remove": {
          "component_groups": ["minecraft:animal_baby"]
        }
      },
      "cc:gather_fish": {
        "add": {
          "component_groups": [
            "cc:gather_fish"
          ]
        }
      },
      "cc:stop_gathering_fish": {
        "remove": {
          "component_groups": [
            "cc:gather_fish"
          ]
        }
      },
      "cc:stop_riding": {},
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 90,
            "add": {
              "component_groups": ["minecraft:animal_adult", "cc:gather_fish"]
            }
          },
          {
            "weight": 10,
            "add": {
              "component_groups": ["minecraft:animal_baby"]
            }
          }
        ]
      },
      "minecraft:entity_born": {
        "add": {
          "component_groups": ["minecraft:animal_baby"]
        },
        "queue_command": {
          "command": "scriptevent cc:entity_event place_egg"
        }
      },
      "cc:entity_born": {
        "add": {
          "component_groups": [
            "minecraft:animal_baby"
          ]
        },
        "remove": {
          "component_groups": [
            "minecraft:animal_adult",
            "cc:gather_fish"
          ]
        }
      },
      "minecraft:entity_transformed": {
        "add": {
          "component_groups": ["minecraft:animal_baby"]
        }
      },
      "cc:persistence": {
        "add": {
          "component_groups": [
            "cc:persistence"
          ]
        }
      }
    }
  }
}
