{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cc:elephant",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "cc:is_chested": {
          "client_sync": false,
          "default": false,
          "type": "bool"
        },
        "cc:is_aiming": {
          "client_sync": true,
          "default": false,
          "type": "bool"
        }
      }
    },
    "components": {
      //Basics
      "minecraft:type_family": {
        "family": ["elephant", "mob", "animal"]
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:balloonable": {},
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": false,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:nameable": {},
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_water": true,
        "breathes_air": true,
        "generates_bubbles": true
      },
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:can_climb": {},
      "minecraft:leashable": {
        "soft_distance": 4.0,
        "hard_distance": 6.0,
        "max_distance": 10.0
      },
      // Look
      "minecraft:behavior.look_at_target": {
        "priority": 1,
        "look_distance": 8,
        "probability": 0.02,
        "angle_of_view_vertical": 360,
        "angle_of_view_horizontal": 360
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9
      },
      // Health
      "minecraft:health": {
        "value": 40,
        "max": 40
      },
      "minecraft:healable": {
        "force_use": false,
        "items": ["cc:peanut"]
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      // Navigation & Movement
      "minecraft:movement.basic": {},
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement": {
        "value": 0.3
      },
      "minecraft:jump.static": {
        "jump_power": 0.42
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 0.5
      },
      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.avoid_mob_type": {
        "priority": 4,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "lion"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "tiger"
                }
              ]
            },
            "max_dist": 10,
            "walk_speed_multiplier": 1.2,
            "sprint_speed_multiplier": 1.5
          }
        ]
      },
      "minecraft:behavior.mount_pathing": {
        "priority": 2,
        "speed_multiplier": 1.5,
        "target_dist": 0.0,
        "track_target": true
      },
      // Attack
      "minecraft:attack": {
        "damage": 6
      },
      "minecraft:behavior.delayed_attack": {
        "priority": 3,
        "reach_multiplier": 1.5,
        "hit_delay_pct": 0.45,
        "attack_duration": 0.79,
        "track_target": true
      },
      "minecraft:behavior.hurt_by_target": {
        "alert_same_type": true,
        "priority": 1,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "lion"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "tiger"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "player"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "villager"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "bear"
                }
              ]
            },
            "max_dist": 10,
            "walk_speed_multiplier": 1.0,
            "sprint_speed_multiplier": 1.0
          }
        ]
      },
      // Tempt
      "minecraft:behavior.tempt": {
        "priority": 4,
        "speed_multiplier": 0.8,
        "items": ["cc:peanut"]
      },
      // Misc
      "minecraft:behavior.random_look_around_and_sit": {
        "priority": 4,
        "continue_if_leashed": true,
        "continue_sitting_on_reload": true,
        "min_look_count": 2,
        "max_look_count": 5,
        "min_look_time": 80,
        "max_look_time": 100,
        "min_angle_of_view_horizontal": -30,
        "max_angle_of_view_horizontal": 30,
        "random_look_around_cooldown": 5,
        "probability": 0.001
      }
    },
    "component_groups": {
      "cc:persistence": {
        "minecraft:persistent": {}
      },
      "cc:elephant_adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:scale": {
          "value": 1.2
        },
        "minecraft:collision_box": {
          "width": 2,
          "height": 3
        },
        // Breed
        "minecraft:breedable": {
          "require_tame": false,
          "breed_items": ["cc:peanut"],
          "breeds_with": {
            "mate_type": "cc:elephant",
            "baby_type": "cc:elephant",
            "breed_event": {
              "event": "minecraft:entity_born",
              "target": "baby"
            }
          }
        },
        "minecraft:behavior.breed": {
          "priority": 1,
          "speed_multiplier": 0.8
        },
        "minecraft:tameable": {
          "probability": 0.15,
          "tame_event": {
            "event": "cc:is_tamed",
            "target": "self"
          },
          "tame_items": ["cc:peanut"]
        }
      },
      "cc:elephant_baby": {
        "minecraft:is_baby": {},
        "minecraft:collision_box": {
          "width": 1,
          "height": 1.5
        },
        "minecraft:scale": {
          "value": 0.5
        },
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": ["cc:peanut"],
          "grow_up": {
            "event": "minecraft:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 6,
          "speed_multiplier": 1.1
        }
      },
      "cc:is_tamed": {
        "minecraft:rideable": {
          "seat_count": 1,
          "interact_text": "action.interact.ride.horse",
          "seats": [
            {
              "position": [0, 2.4, 0]
            }
          ]
        },
        "minecraft:is_tamed": {},
        "minecraft:inventory": {
          "inventory_size": 3,
          "container_type": "horse",
          "additional_slots_per_strength": 3
        },
        "minecraft:interact": {
          "interactions": [
            {
              "play_sounds": "armor.equip_generic",
              "on_interact": {
                "filters": {
                  "all_of": [
                    {
                      "test": "is_family",
                      "subject": "other",
                      "value": "player"
                    },
                    {
                      "test": "has_equipment",
                      "domain": "hand",
                      "subject": "other",
                      "value": "chest"
                    },
                    {
                      "test": "bool_property",
                      "operator": "==",
                      "domain": "cc:is_chested",
                      "value": false
                    }
                  ]
                },
                "event": "cc:is_chested",
                "target": "self"
              },
              "use_item": true,
              "interact_text": "action.interact.attachchest"
            }
          ]
        },
        "minecraft:equippable": {
          "slots": [
            {
              "slot": 1,
              "item": "saddle",
              "accepted_items": ["saddle"],
              "on_equip": {
                "event": "cc:is_saddled"
              },
              "on_unequip": {
                "event": "cc:is_unsaddled"
              }
            }
          ]
        }
      },
      "cc:is_saddled": {
        "minecraft:is_saddled": {},
        "minecraft:input_ground_controlled": {},
        "minecraft:movement": {
          "value": 0.15
        },
        "minecraft:color": {
          "value": 14
        },
        "minecraft:rideable": {
          "seat_count": 1,
          "interact_text": "action.interact.ride.horse",
          "seats": [
            {
              "position": [0, 2.6, 0]
            }
          ]
        },
        "minecraft:behavior.random_stroll": {
          "priority": 6,
          "speed_multiplier": 1
        },
        "minecraft:behavior.player_ride_tamed": {},
        "minecraft:is_dyeable": {
          "interact_text": "action.interact.dye"
        },
        "minecraft:interact": {
          "interactions": [
            {
              "cooldown": 0,
              "on_interact": {
                "filters": [
                  {
                    "test": "has_equipment",
                    "subject": "other",
                    "domain": "hand",
                    "value": "cc:scroll_of_knowledge"
                  }
                ],
                "target": "self"
              }
            },
            {
              "play_sounds": "armor.equip_generic",
              "on_interact": {
                "filters": {
                  "all_of": [
                    {
                      "test": "is_family",
                      "subject": "other",
                      "value": "player"
                    },
                    {
                      "test": "has_equipment",
                      "domain": "hand",
                      "subject": "other",
                      "value": "chest"
                    },
                    {
                      "test": "bool_property",
                      "operator": "==",
                      "domain": "cc:is_chested",
                      "value": false
                    }
                  ]
                },
                "event": "cc:is_chested",
                "target": "self"
              },
              "use_item": true,
              "interact_text": "action.interact.attachchest"
            }
          ]
        }
      },
      "cc:is_chested": {
        "minecraft:is_chested": {},
        "minecraft:inventory": {
          "inventory_size": 18,
          "container_type": "horse"
        }
      }
    },
    "events": {
      "cc:stop_riding": {},
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 95,
            "add": {
              "component_groups": ["cc:elephant_adult"]
            }
          },
          {
            "weight": 5,
            "add": {
              "component_groups": ["cc:elephant_baby"]
            }
          }
        ]
      },
      "minecraft:entity_born": {
        "add": {
          "component_groups": ["cc:elephant_baby", "cc:is_tamed"]
        }
      },
      "cc:is_chested": {
        "add": {
          "component_groups": ["cc:is_chested"]
        },
        "set_property": {
          "cc:is_chested": true
        }
      },
      "cc:is_tamed": {
        "add": {
          "component_groups": ["cc:is_tamed"]
        }
      },
      "cc:is_saddled": {
        "add": {
          "component_groups": ["cc:is_saddled"]
        }
      },
      "cc:is_unsaddled": {
        "remove": {
          "component_groups": ["cc:is_saddled"]
        }
      },
      "minecraft:entity_transformed": {
        "remove": {},
        "add": {
          "component_groups": ["cc:elephant_adult"]
        }
      },
      "minecraft:ageable_grow_up": {
        "remove": {
          "component_groups": ["cc:elephant_baby"]
        },
        "add": {
          "component_groups": ["cc:elephant_adult"]
        }
      },
      "cc:persistence": {
        "add": {
          "component_groups": ["cc:persistence"]
        }
      }
    }
  }
}
