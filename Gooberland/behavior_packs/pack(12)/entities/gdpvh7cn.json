{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cc:quest_villager_spawn_marker",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false
    },
    "components": {
      "minecraft:type_family": {
        "family": ["summon"]
      },
      "minecraft:collision_box": {
        "width": 0,
        "height": 0
      },
      "minecraft:health": {
        "value": 1,
        "max": 1
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "all",
            "deals_damage": false
          }
        ]
      },
      "minecraft:physics": {
        "has_gravity": true,
        "has_collision": true
      },
      "minecraft:pushable": {
        "is_pushable": false,
        "is_pushable_by_piston": false
      },
      "minecraft:fire_immune": {},
      "minecraft:conditional_bandwidth_optimization": {}
    },
    "component_groups": {
      "cc:despawn": {
        "minecraft:instant_despawn": {}
      },
      "cc:despawn_timer": {
        "minecraft:timer": {
          "time": 1,
          "looping": true,
          "time_down_event": {
            "event": "cc:despawn",
            "target": "self"
          }
        }
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "queue_command": {
              "command": ["scriptevent cc:entity_event spawn_quest_villager"]
            }
          },
          { "add": { "component_groups": ["cc:despawn_timer"] } }
        ]
      },
      "cc:despawn": { "add": { "component_groups": ["cc:despawn"] } }
    }
  }
}
