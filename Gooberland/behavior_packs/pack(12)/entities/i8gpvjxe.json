{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "cc:eagle",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false,
            "animations": {
                "drop_rider": "animation.cc.drop_rider",
                "grab_player": "animation.cc.grab_player"
              },
			  "scripts": {
				"animate": [
					{ "drop_rider": "query.has_rider" },"grab_player"
				   ]
			  }
        },
        "components": {
          "minecraft:experience_reward": {
            "on_death": "query.last_hit_by_player ? 5 : 0"
          },
          "minecraft:type_family": {
            "family": ["mob", "eagle", "animal"]
          },
          "minecraft:nameable": {},
          "minecraft:health": {
            "value": 15,
            "max": 15
          },
          "minecraft:behavior.tempt": {
            "priority": 4,
            "speed_multiplier": 1.1,
            "items": ["beef", "pork", "mutton", "rabbit"]
          },
          "minecraft:hurt_on_condition": {
            "damage_conditions": [
              {
                "filters": {
                  "test": "in_lava",
                  "subject": "self",
                  "operator": "==",
                  "value": true
                },
                "cause": "lava",
                "damage_per_tick": 4
              }
            ]
          },
          "minecraft:physics": {
            "has_gravity": false
          },
          "minecraft:pushable": {
            "is_pushable": true,
            "is_pushable_by_piston": true
          },
          "minecraft:conditional_bandwidth_optimization": {},
          "minecraft:attack": {
            "damage": 1
          },
          "minecraft:breathable": {
            "total_supply": 15,
            "suffocate_time": 0,
            "breathes_air": true,
            "breathes_water": false
          },
          "minecraft:collision_box": {
            "width": 0.625,
            "height": 1.1875
          },
          "minecraft:movement": {
            "value": 1.8
          },
          "minecraft:movement.glide": {
            "start_speed": 0.1,
            "speed_when_turning": 0.2
          },
          "minecraft:follow_range": {
            "value": 64,
            "max": 64
          },
          "minecraft:rideable": {
            "controlling_seat": 0,
            "crouching_skip_interact": false,
            "family_types": ["meerkat", "rabbit", "egg", "player"],
            "interact_text": "",
            "pull_in_entities": true,
            "rider_can_interact": false,
            "seat_count": 1,
            "seats": [
              {
                "position": [0, -0.4, -0.5]
              }
            ]
          },
          "minecraft:behavior.avoid_mob_type": {
            "priority": 0,
            "max_dist": 16.0,
            "ignore_visibility": true,
            "entity_types": [
              {
                "filters": {
                  "any_of": [
                    {
                      "test": "is_family",
                      "subject": "other",
                      "value": "ocelot"
                    },
                    { "test": "is_family", "subject": "other", "value": "cat" }
                  ]
                },
                "max_dist": 16
              }
            ]
          },
          "minecraft:behavior.nearest_attackable_target": {
            "priority": 1,
            "reselect_targets": true,
            "scan_interval": 30,
            "within_radius": 64.0,
            "must_see_forget_duration": 2,
            "target_search_height": 80.0,

            "entity_types": [
              {
                "filters": {
                  "all_of": [
                    { "test": "rider_count", "subject": "self", "value": 0 },
                    {
                      "any_of": [
                        {
                          "test": "is_family",
                          "subject": "other",
                          "value": "rabbit"
                        },
                        {
                          "test": "is_family",
                          "subject": "other",
                          "value": "meerkat"
                        },
                        {
                          "test": "is_family",
                          "subject": "other",
                          "value": "monster"
                        },
                        {
                          "all_of": [
                            {
                              "test": "is_family",
                              "subject": "other",
                              "value": "player"
                            },
                            {
                              "test": "actor_health",
                              "subject": "other",
                              "operator": "<=",
                              "value": 10
                            }
                          ]
                        },
                        {
                          "test": "is_family",
                          "subject": "other",
                          "value": "villager"
                        }
                      ]
                    }
                  ]
                },
                "max_dist": 64,
                "reevaluate_description": true
              }
            ]
          },
          "minecraft:behavior.swoop_attack": {
            "priority": 1,
            "damage_reach": 0.2,
            "speed_multiplier": 1.0,
            "delay_range": [0.0, 20.0]
          },
          "minecraft:behavior.circle_around_anchor": {
            "priority": 3,
            "radius_change": 1.0,
            "radius_adjustment_chance": 0.004,
            "height_adjustment_chance": 0.002857,
            "goal_radius": 1.0,
            "angle_change": 15.0,
            "radius_range": [5.0, 15.0],
            "height_offset_range": [-4.0, 5.0],
            "height_above_target_range": [20.0, 40.0]
          },
          "minecraft:despawn": {
            "despawn_from_distance": {}
          }
        },
        "component_groups": {
            "cc:grab_player": {
                "minecraft:rideable": {
                    "controlling_seat": 0,
                    "crouching_skip_interact": false,
                    "family_types": ["player"],
                    "interact_text": "",
                    "pull_in_entities": true,
                    "rider_can_interact": false,
                    "seat_count": 1,
                    "seats": [
                        {
                            "position": [0, -1, -0.5]
                        }
                    ]
                }
            }
        },
        "events": {
            "cc:add_grab_player": {
                "add": {
                    "component_groups": [
                        "cc:grab_player"
                    ]
                }
            },
            "cc:remove_grab_player": {
                "remove": {
                    "component_groups": [
                        "cc:grab_player"
                    ]
                }
            }
        }
    }
}
