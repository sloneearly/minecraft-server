{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cc:scorpion",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,

      "properties": {
        "cc:is_emerging": {
          "client_sync": true,
          "default": false,
          "type": "bool"
        },
        "cc:is_vanishing": {
          "client_sync": true,
          "default": false,
          "type": "bool"
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["scorpion", "mob", "arthropod"]
      },
      "minecraft:collision_box": {
        "height": 1.0,
        "width": 1.0
      },
      "minecraft:loot": {
        "table": "loot_tables/cc/animals/scorpion.loot.json"
      },
      "minecraft:experience_reward": {
        "on_bred": "Math.Random(1,7)",
        "on_death": "query.last_hit_by_player ? Math.Random(1,1) : 0"
      },
      "minecraft:attack": {
        "damage": 1,
        "effect_name": "poison",
        "effect_duration": 3
      },
      "minecraft:behavior.delayed_attack": {
        "priority": 3,
        "attack_duration": 0.5,
        "speed_multiplier": 1.5,
        "hit_delay_pct": 0.5,
        "cooldown_time": 2.0
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 1
      },

      "minecraft:environment_sensor": {
        "triggers": [
          {
            "event": "cc:is_vanishing",
            "target": "self",
            "filters": {
              "all_of": [
                {
                  "test": "random_chance",
                  "value": 100
                },
                {
                  "test": "has_target",
                  "value": false
                }
              ]
            }
          }
        ]
      },

      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:leashable": {
        "soft_distance": 4.0,
        "hard_distance": 6.0,
        "max_distance": 10.0
      },

      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:nameable": {},
      "minecraft:health": {
        "value": 16,
        "max": 16
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.panic": {
        "priority": 1,
        "speed_multiplier": 1
      },
      "minecraft:behavior.mount_pathing": {
        "priority": 2,
        "speed_multiplier": 1.2,
        "target_dist": 0.0,
        "track_target": true
      },
      "minecraft:behavior.follow_parent": {
        "priority": 5,
        "speed_multiplier": 1.1
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 0.8
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9
      },
      "minecraft:balloonable": {},
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 5,
        "must_see": true,
        "reselect_targets": true,
        "within_radius": 25.0,
        "must_see_forget_duration": 17.0,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "spider" },
                { "test": "is_family", "subject": "other", "value": "hermit" },
                { "test": "is_family", "subject": "other", "value": "player" }
              ]
            },
            "max_dist": 10
          }
        ]
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:behavior.avoid_mob_type": {
        "priority": 4,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                { "test": "is_family", "subject": "other", "value": "meerkat" }
              ]
            },
            "max_dist": 10,
            "walk_speed_multiplier": 1.2,
            "sprint_speed_multiplier": 1.2
          }
        ]
      }
    },
    "component_groups": {
      "cc:is_vanishing": {
        "minecraft:movement": {
          "value": 0
        },
        "minecraft:timer": {
          "time": 1.8,
          "looping": true,
          "time_down_event": {
            "event": "cc:underground",
            "target": "self"
          }
        }
      },
      "cc:is_emerging": {
        "minecraft:movement": {
          "value": 0.2
        },
        "minecraft:scale": {
          "value": 1.0
        },
        "minecraft:timer": {
          "time": 1,
          "looping": true,
          "time_down_event": {
            "event": "cc:above_ground",
            "target": "self"
          }
        }
      },
      "cc:underground": {
        "minecraft:collision_box": {
          "height": 0,
          "width": 0
        },
        "minecraft:scale": {
          "value": 0.0
        },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "event": "cc:is_emerging",
              "target": "self",
              "filters": {
                "any_of": [
                  {
                    "test": "random_chance",
                    "value": 100
                  },
                  {
                    "test": "has_target",
                    "value": true
                  }
                ]
              }
            }
          ]
        }
      },
      "cc:persistence": {
        "minecraft:persistent": {}
      },
      "cc:above_ground": {
        "minecraft:collision_box": {
          "height": 1.0,
          "width": 1.0
        },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "event": "cc:is_vanishing",
              "target": "self",
              "filters": {
                "all_of": [
                  {
                    "test": "random_chance",
                    "value": 100
                  },
                  {
                    "test": "has_target",
                    "value": false
                  }
                ]
              }
            }
          ]
        }
      }
    },
    "events": {
      "cc:underground": {
        "set_property": {
          "cc:is_emerging": false,
          "cc:is_vanishing": false
        },
        "remove": {
          "component_groups": ["cc:above_ground"]
        },
        "add": {
          "component_groups": ["cc:underground"]
        }
      },

      "cc:above_ground": {
        "set_property": {
          "cc:is_emerging": false,
          "cc:is_vanishing": false
        },
        "remove": {
          "component_groups": ["cc:underground", "cc:is_emerging"]
        },
        "add": {
          "component_groups": ["cc:above_ground"]
        }
      },

      "cc:is_emerging": {
        "set_property": {
          "cc:is_emerging": true
        },
        "remove": {
          "component_groups": ["cc:underground", "cc:is_emerging"]
        },
        "add": {
          "component_groups": ["cc:is_emerging"]
        }
      },

      "cc:is_vanishing": {
        "set_property": {
          "cc:is_vanishing": true
        },
        "add": {
          "component_groups": ["cc:is_vanishing"]
        }
      },
      "cc:persistence": {
        "add": {
          "component_groups": ["cc:persistence"]
        }
      }
    }
  }
}
