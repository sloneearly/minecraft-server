          "priority": 2,
          "speed_multiplier": 2.0,
          "search_range": 30,
          "stop_distance": 50
        },
        "minecraft:timer": {
          "time": 30,
          "looping": true,
          "time_down_event": {
            "event": "start_breach",
            "target": "self"
          }
        },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "filters": {
                "all_of": [
                  {
                    "test": "on_ground",
                    "operator": "==",
                    "value": true
                  },
                  {
                    "test": "in_water",
                    "operator": "!=",
                    "value": true
                  }
                ]
              },
              "event": "navigation_on_land"
            }
          ]
        }
      },
      "breach": {
        "minecraft:behavior.rise_to_liquid_level": {
          "liquid_y_offset": -0.1,
          "rise_delta": 0.001,
          "sink_delta": 0.01
        },
        "minecraft:behavior.random_breach": {
          "priority": 1,
          "cooldown_time": 0,
          "interval": 0,
          "xz_dist": 10,
          "y_dist": 7
        },
        "minecraft:navigation.generic": {
          "is_amphibious": true,
          "can_path_over_water": false,
          "can_swim": true,
          "can_walk": false,
          "can_breach": true,
          "can_sink": false
        },
        "minecraft:underwater_movement": {
          "value": 0.033
        },
        // "minecraft:buoyant": {
        //   "base_buoyancy": 0.3,
        //   "apply_gravity": false,
        //   "drag_down_on_buoyancy_removed": 0,
        //   "liquid_blocks": ["minecraft:water"],
        //   "simulate_waves": false
        // },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "event": "breach_timer",
              "target": "self",
              "filters": {
                "test": "is_underwater",
                "value": false
              }
            }
          ]
        }
      },
      // deep dive after breach
      "breach_timer": {
        "minecraft:navigation.generic": {
          "is_amphibious": true,
          "can_path_over_water": false,
          "can_swim": true,
          "can_walk": false,
          "can_breach": true,
          "can_sink": true
        },
        "minecraft:underwater_movement": {
          "value": 0.02
        },
        "minecraft:behavior.random_swim": {
          "avoid_surface": true,
          "interval": 1,
          "xz_dist": 10,
          "y_dist": 25
        },
        "minecraft:timer": {
          "time": 3,
          "looping": true,
          "time_down_event": {
            "event": "stop_breach",
            "target": "self"
          }
        }
      },
      "whale_on_land": {
        "minecraft:navigation.generic": {
          "is_amphibious": true,
          "can_path_over_water": true,
          "can_swim": true,
          "can_walk": true,
          "can_breach": false,
          "can_jump": false
        },
        "minecraft:movement": {
          "value": 0.01
        },
        "minecraft:timer": {
          "looping": false,
          "time": 120,
          "time_down_event": {
            "event": "dried_out"
          }
        },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "filters": {
                "test": "in_water_or_rain",
                "operator": "==",
                "value": true
              },
              "event": "stop_dryingout"
            }
          ]
        }
      },
      "cc:persistence": {
        "minecraft:persistent": {}
      },
      "whale_on_land_in_rain": {
        "minecraft:navigation.generic": {
          "is_amphibious": true,
          "can_path_over_water": true,
          "can_swim": true,
          "can_walk": true,
          "can_breach": false,
          "can_jump": false
        },
        "minecraft:movement": {
          "value": 0.02
        },
        "minecraft:environment_sensor": {
          "triggers": [
            {
              "filters": {
                "test": "in_water",
                "operator": "==",
                "value": true
              },
              "event": "navigation_off_land"
            },
            {
              "filters": {
                "test": "in_water_or_rain",
                "operator": "!=",
                "value": true
              },
              "event": "start_dryingout"
            }
          ]
        }
      }
    },
    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "add": {
              "component_groups": ["cc:has_barnacles"]
            }
          },
          {
            "randomize": [
              {
                "weight": 90,
                "add": {
                  "component_groups": ["whale_adult", "whale_swimming_navigation"]
                }
              },
              {
                "weight": 10,
                "add": {
                  "component_groups": ["whale_baby", "whale_swimming_navigation"]
                }
              }
            ]
          }
        ]
      },
      "cc:start_riding": {
        "remove": {
          "component_groups": ["whale_swimming_navigation", "breach", "breach_timer"]
        },
        "add": {
          "component_groups": ["cc:has_rider"]
        }
      },
      "cc:stop_riding": {
        "remove": {
          "component_groups": ["cc:has_rider"]
        },
        "add": {
          "component_groups": ["whale_swimming_navigation", "breach", "breach_timer"]
        }
      },
      "cc:random_barnicle_state": {
        "randomize": [
          {
            "weight": 1,
            "trigger": "cc:barnicle_state_1"
          },
          {
            "weight": 1,
            "trigger": "cc:barnicle_state_2"
          },
          {
            "weight": 1,
            "trigger": "cc:barnicle_state_3"
          }
        ]
      },
      "ageable_grow_up": {
        "remove": {
          "component_groups": ["whale_baby"]
        },
        "add": {
          "component_groups": ["whale_adult"]
        }
      },
      "become_angry": {
        "add": {
          "component_groups": ["whale_angry"]
        }
      },
      "on_calm": {
        "remove": {
          "component_groups": ["whale_angry"]
        }
      },
      "start_breach": {
        "add": {
          "component_groups": ["breach"]
        },
        "remove": {
          "component_groups": ["whale_swimming_navigation"]
        }
      },
      "breach_timer": {
        "add": {
          "component_groups": ["breach_timer"]
        },
        "remove": {
          "component_groups": ["breach"]
        },
        "set_property": {
          "cc:is_breaching": true
        }
      },
      "stop_breach": {
        "remove": {
          "component_groups": ["breach_timer"]
        },
        "add": {
          "component_groups": ["whale_swimming_navigation"]
        },
        "set_property": {
          "cc:is_breaching": false
        }
      },
      "stop_dryingout": {
        "remove": {
          "component_groups": ["whale_on_land", "whale_dried"]
        },
        "add": {
          "component_groups": ["whale_on_land_in_rain"]
        }
      },
      "start_dryingout": {
        "remove": {
          "component_groups": ["whale_on_land_in_rain"]
        },
        "add": {
          "component_groups": ["whale_on_land"]
        }
      },
      "dried_out": {
        "add": {
          "component_groups": ["whale_dried"]
        }
      },
      "navigation_on_land": {
        "add": {
          "component_groups": ["whale_on_land"]
        },
        "remove": {
          "component_groups": ["whale_swimming_navigation"]
        }
      },
      "navigation_off_land": {
        "add": {
          "component_groups": ["whale_swimming_navigation"]
        },
        "remove": {
          "component_groups": ["whale_on_land_in_rain", "whale_on_land", "whale_dried"]
        }
      },
      "cc:shear_barnacles": {
        "sequence": [
          {
            "queue_command": {
              "command": ["playsound mob.sheep.shear @a[r=15] ~~~ 1 1 1", "particle cc:remove_barnacles ~~1~"]
            }
          },
          {
            "filters": [
              {
                "test": "int_property",
                "domain": "cc:barnacle_state",
                "subject": "self",
                "operator": ">",
                "value": 1
              }
            ],
            "set_property": {
              "cc:barnacle_state": "q.property('cc:barnacle_state') - 1"
            }
          },
          {
            "filters": [
              {
                "test": "int_property",
                "domain": "cc:barnacle_state",
                "subject": "self",
                "operator": "==",
                "value": 1
              }
            ],
            "set_property": {
              "cc:barnacle_state": "q.property('cc:barnacle_state') - 1"
            },
            "add": {
              "component_groups": ["cc:barnacle_state_0"]
            },
            "remove": {
              "component_groups": ["cc:has_barnacles"]
            },
            "queue_command": {
              "command": ["particle cc:whale_tamed ~~1~"]
            }
          }
        ]
      },
      "cc:persistence": {
        "add": {
          "component_groups": ["cc:persistence"]
        }
      }
    }
  }
}
