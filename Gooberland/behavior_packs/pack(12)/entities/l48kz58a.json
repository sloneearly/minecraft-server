          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/dolphin.json"
        },
        "minecraft:bribeable": {
          "bribe_items": ["fish", "salmon"]
