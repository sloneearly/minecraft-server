      },
      "cc:has_barnacles": {
        "minecraft:interact": {
          "interactions": [
            {
              "hurt_item": 1,
              "interact_text": "action.interact.shear",
              "on_interact": {
                "filters": [
                  {
                    "subject": "other",
                    "test": "has_equipment",
                    "domain": "hand",
                    "value": "shears"
                  }
