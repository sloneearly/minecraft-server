          "broadcast_anger": true,
          "broadcast_range": 16,
          "calm_event": {
            "event": "on_calm",
            "target": "self"
          }
        },
        "minecraft:on_target_acquired": {}
      },
      "whale_dried": {
        "minecraft:damage_over_time": {
          "damage_per_hurt": 1,
          "time_between_hurt": 0
        }
      },
      "whale_swimming_navigation": {
        "minecraft:navigation.generic": {
          "is_amphibious": true,
          "can_path_over_water": false,
          "can_swim": true,
          "can_walk": false,
          "can_breach": true,
          "can_sink": true
        },
        "minecraft:underwater_movement": {
          "value": 0.02
        },
        "minecraft:behavior.random_swim": {
          "priority": 5,
          "interval": 0,
          "xz_dist": 20,
          "avoid_surface": true,
          "y_dist": 3
        },
