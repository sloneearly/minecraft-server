{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "cc:moose",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "cc:graze": {
          "type": "bool",
          "default": false,
          "client_sync": true
        },
        "cc:antler_growth_state": {
          "client_sync": true,
          "default": 0,
          "range": [0, 3],
          "type": "int"
        }
      }
    },
    "components": {
      //Basics
      "minecraft:type_family": {
        "family": ["moose", "mob", "animal"]
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:balloonable": {},
      "minecraft:physics": {},
      "minecraft:pushable": {
       "is_pushable": false,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:nameable": {},
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_water": true,
        "breathes_air": true,
        "generates_bubbles": true
      },
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:can_climb": {},
      "minecraft:leashable": {
        "soft_distance": 4.0,
        "hard_distance": 6.0,
        "max_distance": 10.0
      },
      // Look
      "minecraft:behavior.look_at_target": {
        "priority": 1,
        "look_distance": 8,
        "probability": 0.02,
        "angle_of_view_vertical": 360,
        "angle_of_view_horizontal": 360
      },
      "minecraft:behavior.look_at_player": {
        "priority": 7,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9
      },
      // Health
      "minecraft:health": {
        "value": 25,
        "max": 25
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      // Navigation & Movement
      "minecraft:movement.basic": {},
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement": {
        "value": 0.3
      },
      "minecraft:jump.static": {
        "jump_power": 0.42
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 0.35
      },
      "minecraft:behavior.float": {
        "priority": 0
      },
      "minecraft:behavior.panic": {
        "priority": 5,
        "speed_multiplier": 1.25
      },
      "minecraft:behavior.mount_pathing": {
        "priority": 2,
        "speed_multiplier": 1.5,
        "target_dist": 0.0,
        "track_target": true
      },
      // Attack
      "minecraft:attack": {
        "damage": 6
      },
      "minecraft:behavior.delayed_attack": {
        "priority": 3,
        "reach_multiplier": 1.5,
        "hit_delay_pct": 0.45,
        "attack_duration": 0.79,
        "track_target": true
      },
      "minecraft:behavior.hurt_by_target": {
        "priority": 1,
        "entity_types": [
          {
            "filters": {
              "any_of": [
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "lion"
                }, // [include] lion
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "tiger"
                }, // [include] tiger
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "player"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "villager"
                },
                {
                  "test": "is_family",
                  "subject": "other",
                  "value": "bear"
                } // [include] beer
              ]
            },
            "max_dist": 10,
            "walk_speed_multiplier": 1.0,
            "sprint_speed_multiplier": 1.4
          }
        ]
      },
      // Tempt
      "minecraft:behavior.tempt": {
        "priority": 4,
        "speed_multiplier": 0.8,
        "items": ["cc:pinecone"]
      },
      // Misc
      "minecraft:behavior.random_look_around_and_sit": {
        "priority": 4,
        "continue_if_leashed": true,
        "continue_sitting_on_reload": true,
        "min_look_count": 2,
        "max_look_count": 5,
        "min_look_time": 80,
        "max_look_time": 100,
        "min_angle_of_view_horizontal": -30,
        "max_angle_of_view_horizontal": 30,
        "random_look_around_cooldown": 5,
        "probability": 0.001
      }
    },
    "component_groups": {
      "cc:grazing": {
        "minecraft:timer": {
          "time": 3,
          "looping": true,
          "time_down_event": {
            "event": "cc:stop_grazing",
            "target": "self"
          }
        }
      },
      "minecraft:moose_adult": {
        "minecraft:timer": {
          "time": [30, 60],
          "looping": true,
          "time_down_event": {
            "event": "cc:growth_tick",
            "target": "self"
          }
        },
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/animals/moose.loot.json"
        },
        "minecraft:scale": {
          "value": 1.2
        },
        "minecraft:collision_box": {
          "width": 1.15,
          "height": 1.9
        },
        // Breed
        "minecraft:breedable": {
          "require_tame": false,
          "breed_items": "cc:pinecone",
          "breeds_with": {
            "mate_type": "cc:moose",
            "baby_type": "cc:moose",
            "breed_event": {
              "event": "minecraft:entity_born",
              "target": "baby"
            }
          }
        },
        "minecraft:behavior.breed": {
          "priority": 1,
          "speed_multiplier": 0.8
        }
      },
      "minecraft:moose_baby": {
        "minecraft:is_baby": {},
        "minecraft:collision_box": {
          "width": 0.8,
          "height": 1
        },
        "minecraft:scale": {
          "value": 0.5
        },
        "minecraft:ageable": {
          "duration": 1200,
          "feed_items": "cc:pinecone",
          "grow_up": {
            "event": "minecraft:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 6,
          "speed_multiplier": 1.1
        }
      },
      "cc:fully_grown_antlers": {
        "minecraft:interact": {
          "interactions": [
            {
              "swing": true,
              "interact_text": "action.interact.shear",
              "hurt_item": 1,
              "on_interact": {
                "event": "cc:shear_antlers",
                "target": "self",
                "filters": [
                  {
                    "test": "has_equipment",
                    "subject": "other",
                    "domain": "hand",
                    "value": "shears"
                  }
                ]
              }
            }
          ]
        }
      },
      "minecraft:baby_wild": {
        "minecraft:on_target_acquired": {
          "event": "minecraft:on_scared",
          "target": "self"
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 4,
          "entity_types": [
            {
              "filters": { "test": "is_family", "subject": "other", "value": "player" },
              "max_dist": 16
            }
          ]
        }
      },
      "cc:persistence": {
        "minecraft:persistent": {}
      },
      "minecraft:baby_scared": {
        "minecraft:angry": {
          "duration": 1,
          "broadcast_anger": true,
          "broadcast_range": 41,
          "calm_event": {
            "event": "minecraft:baby_on_calm",
            "target": "self"
          }
        }
      }
    },
    "events": {
      "cc:start_grazing": {
        "add": {
          "component_groups": ["cc:grazing"]
        },
        "set_property": {
          "cc:graze": true
        }
      },
      "cc:stop_grazing": {
        "remove": {
          "component_groups": ["cc:grazing"]
        },
        "set_property": {
          "cc:graze": false
        }
      },
      "cc:stop_riding": {},
      "minecraft:entity_spawned": {
        "randomize": [
          {
            "weight": 95,
            "add": {
              "component_groups": ["minecraft:moose_adult", "cc:fully_grown_antlers"]
            },
            "set_property": {
              "cc:antler_growth_state": 3
            }
          },
          {
            "weight": 5,
            "add": {
              "component_groups": ["minecraft:moose_baby", "minecraft:baby_wild"]
            }
          }
        ]
      },
      "cc:growth_tick": {
        "sequence": [
          {
            "filters": [
              {
                "test": "int_property",
                "subject": "self",
                "domain": "cc:antler_growth_state",
                "operator": "<",
                "value": 2
              }
            ],
            "set_property": {
              "cc:antler_growth_state": "q.property('cc:antler_growth_state') + 1"
            }
          },
          {
            "filters": [
              {
                "test": "int_property",
                "subject": "self",
                "domain": "cc:antler_growth_state",
                "operator": "==",
                "value": 2
              }
            ],
            "set_property": {
              "cc:antler_growth_state": 3
            },
            "add": {
              "component_groups": ["cc:fully_grown_antlers"]
            }
          }
        ]
      },
      "cc:shear_antlers": {
        "queue_command": {
          "command": [
            "loot spawn ~ ~ ~ loot \"cc/animals/moose_antler.loot\"",
            "playsound mob.sheep.shear @a[r=15] ~~~ 1 1 1"
          ]
        },
        "set_property": {
          "cc:antler_growth_state": 0
        },
        "remove": {
          "component_groups": ["cc:fully_grown_antlers"]
        }
      },
      "minecraft:entity_born": {
        "add": {
          "component_groups": ["minecraft:moose_baby"]
        }
      },
      "minecraft:entity_transformed": {
        "remove": {},
        "add": {
          "component_groups": ["minecraft:moose_adult"]
        }
      },
      "minecraft:ageable_grow_up": {
        "remove": {
          "component_groups": [
            "minecraft:moose_baby",
            "minecraft:baby_wild",
            "minecraft:baby_scared"
          ]
        },
        "add": {
          "component_groups": ["minecraft:moose_adult"]
        }
      },
      "minecraft:on_scared": {
        "remove": {
          "component_groups": ["minecraft:baby_wild"]
        },
        "add": {
          "component_groups": ["minecraft:baby_scared"]
        }
      },
      "minecraft:baby_on_calm": {
        "remove": {
          "component_groups": ["minecraft:baby_scared"]
        },
        "add": {
          "component_groups": ["minecraft:baby_wild"]
        }
      },
      "cc:persistence": {
        "add": {
          "component_groups": [
            "cc:persistence"
          ]
        }
      }
    }
  }
}
