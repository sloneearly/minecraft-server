{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "cc:pearl_clam",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false,
            "properties": {
                "cc:open": { "type": "bool", "default": false, "client_sync": true }
            }
        },
        "components": {
            "minecraft:balloonable": {},
            "minecraft:physics": {
                "has_collision": true,
                "has_gravity": true
            },
            "minecraft:health": {
                "value": 1,
                "max": 1
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": true
            },
            "minecraft:conditional_bandwidth_optimization": {},
            "minecraft:collision_box": {
                "height": 0.0,
                "width": 0.5
            },
            "minecraft:custom_hit_test": {
                "hitboxes": [
                    {
                        "width": 1.0,
                        "height": 1.0,
                        "pivot": [
                            0,
                            1,
                            0
                        ]
                    }
                ]
            }
        },
        "component_groups": {
            "cc:close_with_loot": {
                "minecraft:interact": {
                    "interactions": [
                        {
                            "on_interact": {
                                "target": "self",
                                "event": "cc:open_with_loot"
                            },
                            "play_sounds": "enderchest.open",
                            "swing": true
                        }
                    ]
                }
            },
            "cc:open_with_loot": {
                "minecraft:interact": {
                    "interactions": [
                        {
                            "on_interact": {
                                "target": "self",
                                "event": "cc:close"
                            },
                            "play_sounds": "enderchest.closed",
                            "swing": true
                        }
                    ]
                },
                "minecraft:spawn_entity": {
                    "entities": [
                      {
                        "min_wait_time": 0,
                        "max_wait_time": 0,
                        "single_use": true,
                        "spawn_item": "cc:pearl",
                        "num_to_spawn": 1,
                        "should_leash": false
                      }
                    ]
                  }
            },
            "cc:open": {
                "minecraft:interact": {
                    "interactions": [
                        {
                            "on_interact": {
                                "target": "self",
                                "event": "cc:close"
                            },
                            "play_sounds": "enderchest.closed",
                            "swing": true
                        }
                    ]
                }
            },
            "cc:close": {
                "minecraft:interact": {
                    "interactions": [
                        {
                            "on_interact": {
                                "target": "self",
                                "event": "cc:open"
                            },
                            "play_sounds": "enderchest.open",
                            "swing": true
                        }
                    ]
                }
            }
        },
        "events": {
            "minecraft:entity_spawned": {
                "add": {
                    "component_groups": [
                        "cc:close_with_loot"
                    ]
                }
            },
            "cc:open_with_loot": {
                "remove": {
                    "component_groups": [
                        "cc:close_with_loot"
                    ]
                },
                "add": {
                    "component_groups": [
                        "cc:open_with_loot"
                    ]
                },
                "set_property": {
                    "cc:open": true
                }
            },
            "cc:open": {
                "remove": {
                    "component_groups": [
                        "cc:close"
                    ]
                },
                "add": {
                    "component_groups": [
                        "cc:open"
                    ]
                },
                "set_property": {
                    "cc:open": true
                }
            },
            "cc:close": {
                "remove": {
                    "component_groups": [
                        "cc:open", "cc:open_with_loot"
                    ]
                },
                "add": {
                    "component_groups": [
                        "cc:close"
                    ]
                },
                "set_property": {
                    "cc:open": false
                }
            }
        }
    }
}
