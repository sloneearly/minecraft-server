{
  "format_version": "1.13.0",
  "minecraft:feature_rules": {
    "description": {
      "identifier": "cc:savanna_mud_placement",
      "places_feature": "cc:savanna_mud_scatter"
    },
    "conditions": {
      "placement_pass": "surface_pass",
      "minecraft:biome_filter": [
        {
          "any_of": [
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "savanna"
            }
          ]
        }
      ]
    },

    "distribution": {
      "iterations": 3,
      "scatter_chance": 10,
      "x": {
        "distribution": "gaussian",
        "extent": [-8, 8]
      },
      "y": "query.heightmap(v.originx, v.originz)",
      "z": {
        "distribution": "gaussian",
        "extent": [-8, 8]
      }
    }
  }
}
