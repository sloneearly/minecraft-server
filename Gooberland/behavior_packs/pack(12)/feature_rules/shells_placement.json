{
  "format_version": "1.13.0",
  "minecraft:feature_rules": {
    "description": {
      "identifier": "cc:shells_placement",
      "places_feature": "cc:shells_weight"
    },
    "conditions": {
      "placement_pass": "after_surface_pass",
      "minecraft:biome_filter": [
        {
          "any_of": [
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "beach"
            },
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "ocean"
            }
          ]
        },
        {
          "none_of": [
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "frozen"
            },
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "ice"
            },
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "cold"
            }
          ]
        }
      ]
    },

    "distribution": {
      "iterations": 20,
      "scatter_chance": 50.0,
      "x": {
        "distribution": "triangle",
        "extent": [-8, 8]
      },
      "y": "q.above_top_solid(v.originx, v.originz)",
      "z": {
        "distribution": "triangle",
        "extent": [-8, 8]
      },
      "coordinate_eval_order": "zyx"
    }
  }
}
