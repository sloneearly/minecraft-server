{
  "format_version": "1.20.30",
  "minecraft:single_block_feature": {
    "description": {
      "identifier": "cc:river_grass_feature"
    },
    "places_block": "minecraft:short_grass",
    "enforce_placement_rules": true,
    "enforce_survivability_rules": true,
    "may_attach_to": {
      "bottom": ["minecraft:grass_block", "minecraft:mud", "minecraft:packed_mud", "minecraft:dirt", "minecraft:sand"]
    },
    "may_replace": ["minecraft:air","minecraft:water"]
  }
}
