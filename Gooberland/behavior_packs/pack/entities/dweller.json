					"search_height": 4,
					"avoid_block_sound": "retreat",
					"sound_interval": {
						"range_min": 5,
						"range_max": 10
					},
					"sprint_speed_modifier": 1.125,
					"walk_speed_modifier": 1.135,
					"tick_interval": 25,
