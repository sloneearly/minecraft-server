{
	"format_version": "1.21.110",
	"minecraft:entity": {
		"description": {
			"identifier": "wypnt_bab:dweller",
			"spawn_category": "monster",
			"is_spawnable": true,
			"is_summonable": true
		},
		"component_groups": {
			"wypnt_bab:dweller_calm": {
				"minecraft:on_target_acquired": {
					"event": "minecraft:become_angry",
					"target": "self"
				},
				"minecraft:movement_sound_distance_offset": {
					"value": 0.245
				}
			},
			"wypnt_bab:dweller_angry": {
