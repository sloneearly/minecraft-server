{
	"format_version": "1.21.110",
	"minecraft:entity": {
		"description": {
			"identifier": "wypnt_bab:sigiling",
			"spawn_category": "monster",
			"is_spawnable": true,
			"is_summonable": true
		},
		"component_groups": {
			"wypnt_bab:sigiling_calm": {
				"minecraft:on_target_acquired": {
					"event": "minecraft:become_angry",
					"target": "self"
				},
				"minecraft:movement": {
					"value": 0.2
				},
				"minecraft:movement_sound_distance_offset": {
					"value": 0.35
				}
			},
			"wypnt_bab:sigiling_angry": {
				"minecraft:angry": {
					"duration": 60,
					"calm_event": {
						"event": "minecraft:on_calm",
						"target": "self"
					},
					"broadcast_anger": true,
					"broadcast_anger_on_attack": true,
					"broadcast_anger_on_being_attacked": true,
					"angry_sound": "mad",
					"sound_interval": {
						"range_min": 4,
						"range_max": 4
					},
					"broadcast_filters": {
						"all_of": [
							{
								"any_of": [
									{
										"test": "is_family",
										"operator": "==",
										"value": "sigiling"
									}
								]
							}
						]
					}
				},
				"minecraft:movement": {
					"value": 0.4
				},
				"minecraft:movement_sound_distance_offset": {
					"value": 0.2
				},
				"minecraft:behavior.ranged_attack": {
					"priority": 4,
					"burst_shots": 1,
					"burst_interval": 0.7,
					"charge_charged_trigger": 0,
					"charge_shoot_trigger": 0.5,
					"attack_interval_min": 0.5,
					"attack_interval_max": 0.5,
					"attack_radius": 9,
					"speed_multiplier": 1
				},

				"minecraft:shooter": {
					"def": "wypnt_bab:sigiling_shot"
				},
				"minecraft:behavior.avoid_mob_type": {
					"entity_types": [
						{
							"filters": {
								"subject": "other",
								"test": "is_family",
								"value": "player"
							},
							"max_dist": 4,
							"sprint_speed_multiplier": 1.3,
							"walk_speed_multiplier": 1.3
						}
					],
					"priority": 3
				}
			},
				"minecraft:riding": {
        "minecraft:environment_sensor": {
          "triggers": {
            "filters": {
              "test": "is_riding", "subject": "self", "operator": "==", "value": false
            },
            "event": "minecraft:stopped_riding"
          }
        }
      },
      "minecraft:not_riding": {
        "minecraft:environment_sensor": {
          "triggers": {
            "filters": {
              "test": "is_riding", "subject": "self", "operator": "==", "value": true
            },
            "event": "minecraft:started_riding"
          }
        },
        "minecraft:teleport": {
        	"random_teleports": true,
        	"max_random_teleport_time": 30,
        	"random_teleport_cube": [ 8, 6, 8 ],
				"target_distance": 8,
				"target_teleport_chance": 0.01,
				"light_teleport_chance": 0.05,
				"min_random_teleport_time": 10
			}
      }
		},
		"components": {
			"minecraft:is_hidden_when_invisible": {},
			"minecraft:renders_when_invisible": {},
			"minecraft:experience_reward": {
				"on_death": "query.last_hit_by_player ? 5 : 0"
			},
			"minecraft:type_family": {
				"family": [ "enderman", "monster", "mob", "sigiling", "enderling" ]
			},
			"minecraft:breathable": {
				"total_supply": 15,
				"suffocate_time": 0
			},
			"minecraft:nameable": {},
			"minecraft:loot": {
				"table": "loot_tables/entities/enderman.json"
			},
			"minecraft:health": {
				"value": 65,
				"max": 65
			},
			"minecraft:hurt_on_condition": {
				"damage_conditions": [
					{
						"filters": {
							"test": "in_lava",
							"subject": "self"
						},
						"cause": "lava",
						"damage_per_tick": 4
					},
					{
						"filters": {
							"test": "in_contact_with_water"
						},
						"cause": "drowning",
						"damage_per_tick": 1
					}
				]
			},
			"minecraft:attack": {
				"damage": 7
			},
			"minecraft:follow_range": {
				"value": 32,
				"max": 32
			},
			"minecraft:collision_box": {
				"width": 1.0,
				"height": 2.0
			},
			"minecraft:looked_at": {
				"search_radius": 64.0,
				"set_target": "once_and_stop_scanning",
				"find_players_only": true,
				"min_looked_at_duration": 3.25,
				"filters": {
          "test": "has_equipment",
          "domain": "head",
          "subject": "other",
          "operator": "not",
          "value": "carved_pumpkin"
        }
			},
			"minecraft:despawn": {
            "despawn_from_distance": {},
            "filters": {
          "all_of": [
            { "test": "is_difficulty", "operator": "==", "value": "peaceful" }
          ]
        }
             },
			"minecraft:behavior.nearest_attackable_target": {
				"priority": 1,
				"must_see": true,
				"attack_interval": 1,
				"entity_types": [
					{
						"filters": {
							"test": "is_family",
							"subject": "other",
							"value": "endermite"
						},
						"max_dist": 64
					}
				]
			},
			"minecraft:navigation.walk": {
				"can_path_over_water": false,
				"avoid_water": true
			},
			"minecraft:scale": {
				"value": 1.15
			},
			"minecraft:movement.basic": {},
			"minecraft:jump.static": {},
			"minecraft:can_climb": {},
			"minecraft:behavior.float": {
				"priority": 0
			},
			"minecraft:behavior.random_stroll": {
				"priority": 7,
				"speed_multiplier": 1.0
			},
			"minecraft:behavior.look_at_player": {
				"priority": 8,
				"look_distance": 8,
				"probability": 8
			},
			"minecraft:behavior.random_look_around": {
				"priority": 8
			},
			"minecraft:behavior.hurt_by_target": {
				"priority": 3
			},
			"minecraft:physics": {},
			"minecraft:behavior.avoid_mob_type": {
				"entity_types": [
					{
						"filters": {
							"subject": "other",
							"test": "is_family",
							"value": "player"
						},
						"max_dist": 5,
						"sprint_speed_multiplier": 1.3,
						"walk_speed_multiplier": 1.3
					}
				],
				"priority": 3
			},
			"minecraft:pushable": {
				"is_pushable": true,
				"is_pushable_by_piston": true
			},
			"minecraft:variable_max_auto_step": {
            "base_value": 1.0625, // 1 block + 1 pixel
            "jump_prevented_value": 0.5625 // 0.5 blocks + 1 pixel
            },
			"minecraft:conditional_bandwidth_optimization": {
				"default_values": {
					"max_optimized_distance": 80.0,
					"max_dropped_ticks": 10,
					"use_motion_prediction_hints": true
				}
			},
			"minecraft:fire_immune": true,
			"minecraft:teleport": {
				"random_teleports": true,
				"max_random_teleport_time": 30,
				"random_teleport_cube": [
					8,
					6,
					8
				],
				"target_distance": 8,
				"target_teleport_chance": 0.01,
				"light_teleport_chance": 0.05,
				"min_random_teleport_time": 10
			}
		},
		"events": {
			"minecraft:entity_spawned": {
				"remove": {},
				"add": {
					"component_groups": [
						"wypnt_bab:sigiling_calm",
						"minecraft:not_riding"
					]
				}
			},
			"minecraft:become_angry": {
				"remove": {
					"component_groups": [
						"wypnt_bab:sigiling_calm"
					]
				},
				"add": {
					"component_groups": [
						"wypnt_bab:sigiling_angry"
					]
				}
			},
			"minecraft:on_calm": {
				"remove": {
					"component_groups": [
						"wypnt_bab:sigiling_angry"
					]
				},
				"add": {
					"component_groups": [
						"wypnt_bab:sigiling_calm"
					]
				}
			},
			 "minecraft:stopped_riding": {
        "add": {
          "component_groups": [
            "minecraft:not_riding"
          ]
        },
        "remove": {
          "component_groups": [
            "minecraft:riding"
          ]
        }
      },
      "minecraft:started_riding": {
        "add": {
          "component_groups": [
            "minecraft:riding"
          ]
        },
        "remove": {
          "component_groups": [
            "minecraft:not_riding"
          ]
        }
      }
		}
	}
}