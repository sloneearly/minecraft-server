{
	"format_version": "1.13.0",
	"minecraft:feature_rules": {
		"description": {
			"identifier": "wypnt_bab:clover_patch_feature",
			"places_feature": "wypnt_bab:scatter_clovers_feature"
		},
		"conditions": {
			"placement_pass": "final_pass",
			"minecraft:biome_filter": [
				{
					"any_of": [
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "plains"
						},
						{
							"test": "has_biome_tag",
							"operator": "==",
							"value": "prairie"
						}
					]
				},
				{
					"test": "has_biome_tag",
					"operator": "!=",
					"value": "frozen"
				}
			]
		},
		"distribution": {
			"iterations": "(query.noise((variable.originx) / 200.0, (variable.originz) / 200.0) < -0.8) ? 0 : 1",
			"scatter_chance": {
				"numerator": 1,
				"denominator": 8
			},
			"x": {
				"distribution": "uniform",
				"extent": [
					0,
					16
				]
			},
			"y": "query.heightmap(variable.worldx, variable.worldz)",
			"z": {
				"distribution": "uniform",
				"extent": [
					0,
					16
				]
			}
		}
	}
}