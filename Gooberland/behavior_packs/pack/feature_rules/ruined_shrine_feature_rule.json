{
    "format_version": "1.13.0",
    "minecraft:feature_rules": {
        "description": {
            "identifier": "wypnt_bab:ruined_shrine_feature_rule",
            "places_feature": "wypnt_bab:select_ruined_shrine_feature"
        },
        "conditions": {
            "placement_pass": "after_surface_pass",
            "minecraft:biome_filter": [
                {
                    "all_of": [
                        {
                            "test": "has_biome_tag",
                            "operator": "!=",
                            "value": "ocean"
                        },
                        {
                            "test": "has_biome_tag",
                            "operator": "!=",
                            "value": "river"
                        },
                        {
                            "any_of": [
                                { "test": "has_biome_tag", "operator": "==", "value": "forest" },
                                { "test": "has_biome_tag", "operator": "==", "value": "roofed" },
                                { "test": "has_biome_tag", "operator": "==", "value": "taiga" }
                            ]
                        }
                    ]
                },
                {
                    "none_of": [
                        { "test": "has_biome_tag", "operator": "==", "value": "frozen" },
                        { "test": "has_biome_tag", "operator": "==", "value": "mutated" },
                        { "test": "has_biome_tag", "operator": "==", "value": "cold" },
                        { "test": "has_biome_tag", "operator": "==", "value": "ice" },
                        { "test": "has_biome_tag", "operator": "==", "value": "ice_plains" },
                        { "test": "has_biome_tag", "operator": "==", "value": "ice_plains_spikes" },
                        { "test": "has_biome_tag", "operator": "==", "value": "cold_taiga" },
                        { "test": "has_biome_tag", "operator": "==", "value": "cold_beach" },
                        { "test": "has_biome_tag", "operator": "==", "value": "frozen_peaks" },
						{ "test": "has_biome_tag", "operator": "==", "value": "birch" }
                    ]
                }
            ]
        },
        "distribution": {
            "iterations": 1,
            "scatter_chance": {
                "numerator": 1,
                "denominator": 25
            },
            "x": {
                "distribution": "uniform",
                "extent": [0, 16]
            },
            "y": "query.heightmap(variable.worldx, variable.worldz) + -1",
            "z": {
                "distribution": "uniform",
                "extent": [0, 16]
            }
        }
    }
}
