{
  "format_version": "1.13.0",
  "minecraft:feature_rules": {
    "description": {
      "identifier": "wypnt_bab:tropical_trees_feature",
      "places_feature": "wypnt_bab:tropical_jungle_trees_feature"
    },
    "conditions": {
      "placement_pass": "surface_pass",
			"minecraft:biome_filter": [
				{
					"all_of": [
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "tropical_jungle"
            }
					]
				},
				{
					"test": "has_biome_tag",
					"operator": "!=",
					"value": "mutated"
				}
			]
    },
    "distribution": {
      "iterations": "math.random(12,18)",
      "x": {
        "distribution": "uniform",
        "extent": [0, 16]
      },
      "y": "query.heightmap(variable.worldx, variable.worldz)",
      "z": {
        "distribution": "uniform",
        "extent": [0, 16]
      }
    }
  }
}
