{
	"format_version": "1.13.0",
	"minecraft:tree_feature": {
		"description": {
			"identifier": "wypnt_bab:chorus_tree_feature"
		},
		"acacia_trunk": {
			"trunk_width": 1,
			"trunk_height": {
				"base": 13,
				"intervals": [
					4
				],
				"min_height_for_canopy": 7
			},
			"trunk_block": {
				"name": "wypnt_bab:chorus_log"
			},
			"trunk_lean": {
				"allow_diagonal_growth": true,
				"lean_height": {
					"range_min": 4,
					"range_max": 6
				},
				"lean_steps": {
					"range_min": 5,
					"range_max": 7
				},
				"lean_length": {
					"range_min": 3,
					"range_max": 6
				}
			},
			"branches": {
				"branch_length": {
					"range_min": 2,
					"range_max": 4
				},
				"branch_position": {
					"range_min": 7,
					"range_max": 10
				},
				"branch_chance": 100,
				"branch_canopy": {
					"fancy_canopy": {
						"height": 3,
						"radius": 3,
						"leaf_block": "wypnt_bab:chorus_leaves"
					}
				}
			}
		},
		"random_spread_canopy": {
			"canopy_height": 2,
			"canopy_radius": 3,
			"leaf_placement_attempts": 50,
			"leaf_blocks": [
				[
					"wypnt_bab:chorus_leaves",
					900
				],
				[
					"wypnt_bab:chorus_leaves",
					1
				]
			]
		},
		"base_block": [
			"wypnt_bab:void_turf"
		],
		// Kinds of blocks the tree can be placed on.
    // We want all kinds of "dirt" blocks: dirt, grass, podzol, mud, etc.
    "may_grow_on": [
      {
        "tags": "query.any_tag('dirt')"
      },
      "wypnt_bab:void_turf"
    ],
		"may_replace": [
			"minecraft:water",
			"minecraft:flowing_water",
			"minecraft:flowering_azalea",
			"minecraft:azalea",
			"wypnt_bab:chorus_sapling",
      "minecraft:air",
      "minecraft:snow_layer",
      // Sadly no tags for vanilla leaves yet
      "minecraft:acacia_leaves",
      "minecraft:azalea_leaves",
      "minecraft:azalea_leaves_flowered",
      "minecraft:birch_leaves",
      "minecraft:cherry_leaves",
      "minecraft:dark_oak_leaves",
      "minecraft:jungle_leaves",
      "minecraft:mangrove_leaves",
      "minecraft:oak_leaves",
      "minecraft:pale_oak_leaves",
      "minecraft:spruce_leaves",
	// Tag to list all custom leaves		
      {
        "tags": "query.any_tag('wypnt_bab:custom_leaves')"
      },
	// Plants
      "minecraft:wildflowers",
      "minecraft:leaf_litter"
    ],
		// This is used when checking the volume the tree is going to be placed on.
    // Dirt around the placement area doesn't block the tree from being created.
    "may_grow_through": [
      {
        "tags": "query.any_tag('dirt')"
      },
			"wypnt_bab:void_turf"
		]
	}
}