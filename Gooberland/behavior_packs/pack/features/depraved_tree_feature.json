
{
	"format_version": "1.13.0",
	"minecraft:tree_feature": {
		"description": {
			"identifier": "wypnt_bab:depraved_tree_feature"
		},
		"base_block": [
			"minecraft:dirt",
			"minecraft:coarse_dirt",
			"wypnt_bab:voidmire"
		],
		// Kinds of blocks the tree can be placed on.
    // We want all kinds of "dirt" blocks: dirt, grass, podzol, mud, etc.
    "may_grow_on": [
      {
        "tags": "query.any_tag('dirt')"
      },
			"wypnt_bab:voidmire"
		],
		"may_replace": [
      "minecraft:air",
      "minecraft:snow_layer",
      // Sadly no tags for vanilla leaves yet
      "minecraft:acacia_leaves",
      "minecraft:azalea_leaves",
      "minecraft:azalea_leaves_flowered",
      "minecraft:birch_leaves",
      "minecraft:cherry_leaves",
      "minecraft:dark_oak_leaves",
      "minecraft:jungle_leaves",
      "minecraft:mangrove_leaves",
      "minecraft:oak_leaves",
      "minecraft:pale_oak_leaves",
      "minecraft:spruce_leaves",
      "wypnt_bab:depraved_shroom",
	// Tag to list all custom leaves		
      {
        "tags": "query.any_tag('wypnt_bab:custom_leaves')"
      },
	// Plants
      "minecraft:wildflowers",
      "minecraft:leaf_litter"
    ],
		// This is used when checking the volume the tree is going to be placed on.
    // Dirt around the placement area doesn't block the tree from being created.
    "may_grow_through": [
      {
        "tags": "query.any_tag('dirt')"
      },
			"wypnt_bab:voidmire",
			"minecraft:water"
		],
		"pine_canopy": {
			"canopy_height": {
				"range_min": 3,
				"range_max": 3
			},
			"base_radius": 2,
			"leaf_block": {
				"name": "wypnt_bab:depraved_wart_block"
			}
		},
		"acacia_trunk": {
			"trunk_height": {
				"base": 10,
				"intervals": [
					1
				]
			},
			"trunk_width": 1,
			"trunk_lean": {
				"allow_diagonal_growth": true,
				"lean_height": {
					"range_min": 3,
					"range_max": 8
				},
				"lean_steps": {
					"range_min": 2,
					"range_max": 3
				}
			},
			"trunk_block": {
				"name": "wypnt_bab:depraved_stem"
			},
			"branches": {
				"branch_length": {
					"range_min": 3,
					"range_max": 5
				},
				"branch_position": {
					"range_min": 3,
					"range_max": 4
				},
				"branch_chance": 100,
				"branch_canopy": {
					"pine_canopy": {
						"canopy_height": {
							"range_min": 3,
							"range_max": 3
						},
						"base_radius": 2,
						"leaf_block": {
							"name": "wypnt_bab:depraved_wart_block"
						}
					}
				}
			},
			"trunk_decoration": {
				"decoration_chance": {
					"numerator": 1,
					"denominator": 700
				},
				"decoration_block": {
					"name": "minecraft:shroomlight"
				},
				"num_steps": 0,
				"step_direction": "up"
			}
		}
	}
}