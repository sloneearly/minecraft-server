{
	"format_version": "1.13.0",
	"minecraft:tree_feature": {
		"description": {
			"identifier": "wypnt_bab:forsaken_tree_feature"
		},
		"mangrove_roots": {
			"max_root_width": 8,
			"max_root_length": 15,
			"y_offset": {
			  "range_min": 5,
			  "range_max": 8
			},
			"root_block": {
			  "name": "wypnt_bab:forsaken_oak_wood"
			},
			"muddy_root_block": {
			  "name": "wypnt_bab:forsaken_oak_wood"
			},
			"mud_block": {
			  "name": "wypnt_bab:forsaken_oak_wood"
			},
			"above_root": {
			  "above_root_block": "minecraft:pale_moss_carpet",
			  "above_root_chance": {
				"numerator": 1,
				"denominator": 2
			  }
			},
			"roots_may_grow_through": [
			  "minecraft:mangrove_propagule",
			  "wypnt_bab:forsaken_oak_sapling",
			  "wypnt_bab:lichen_hanging",
			  "minecraft:mangrove_roots",
			  "minecraft:deepslate",
			  "minecraft:cobbled_deepslate",
			  "minecraft:dripstone_block",
			  "minecraft:pointed_dripstone",
			  "minecraft:moss_carpet",
			  "minecraft:mud",
			  "minecraft:muddy_mangrove_roots",
			  "minecraft:snow_layer",
			  "minecraft:vine"
			]
		  },
		"mangrove_trunk": {
			"trunk_width": 1,
			"trunk_height": {
				"base": 10,
				"height_rand_a": 3,
				"height_rand_b": 5
			},
			"trunk_block": {
				"name": "wypnt_bab:forsaken_oak_log"
			},
			"branches": {
				"branch_chance": 0,
				"branch_length": {
					"range_min": 0,
					"range_max": 0
				},
				"branch_steps": {
					"range_min": 0,
					"range_max": 0
				}
			}
		},
		"canopy": {
			"canopy_offset": {
			  "min": -3,
			  "max": 0
			},
			"variation_chance": [
			  {
				"numerator": 1,
				"denominator": 2
			  },
			  {
				"numerator": 1,
				"denominator": 2
			  },
			  {
				"numerator": 1,
				"denominator": 2
			  },
			  {
				"numerator": 1,
				"denominator": 1
			  }
			],
			"min_width": 1,
			"leaf_block": {
			  "name": "wypnt_bab:forsaken_oak_leaves"
			},
			"canopy_decoration": {
			  "decoration_block": "minecraft:air",
			  "decoration_chance": {
				"numerator": 1,
				"denominator": 4
			  },
			  "num_steps": 4,
			  "step_direction": "down"
			}
		  },
		"base_block": [
      "minecraft:pale_moss_block"
    ],
		"may_replace": [
		"minecraft:air",
		"minecraft:cobbled_deepslate",
      "minecraft:snow_layer",
      // Sadly no tags for vanilla leaves yet
      "minecraft:acacia_leaves",
      "minecraft:azalea_leaves",
      "minecraft:azalea_leaves_flowered",
      "minecraft:birch_leaves",
      "minecraft:cherry_leaves",
      "minecraft:dark_oak_leaves",
      "minecraft:jungle_leaves",
      "minecraft:mangrove_leaves",
      "minecraft:oak_leaves",
      "minecraft:pale_oak_leaves",
      "minecraft:spruce_leaves",
	// Tag to list all custom leaves		
      {
        "tags": "query.any_tag('wypnt_bab:custom_leaves')"
      },
	// Plants
      "minecraft:wildflowers",
      "minecraft:leaf_litter",
      "wypnt_bab:lichen_carpet",
      "wypnt_bab:lichen_hanging",
      "wypnt_bab:whispering_willow",
      "wypnt_bab:forsaken_oak_sapling"
		],
		"may_grow_through": [
			"minecraft:deepslate",
			"minecraft:cobbled_deepslate",
			"wypnt_bab:lichen_hanging",
			"minecraft:deepslate",
			"wypnt_bab:forsaken_oak_sapling",
			{
        "tags": "query.any_tag('dirt')"
      }
		],
		"may_grow_on": [
			"minecraft:cobbled_deepslate",
			"minecraft:deepslate",
			"minecraft:pale_moss_block",
			"minecraft:moss_carpet",
			"wypnt_bab:lichen_carpet",
			"wypnt_bab:lichen_hanging",
			"wypnt_bab:forsaken_oak_sapling",
			{
        "tags": "query.any_tag('dirt')"
      }
		]
	}
}
