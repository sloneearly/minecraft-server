{
	"format_version": "1.13.0",
	"minecraft:tree_feature": {
		"description": {
			"identifier": "wypnt_bab:maple_fancy_tree_feature"
		},
		"fancy_trunk": {
			"trunk_height": {
				"base": 7,
				"variance": 12,
				"scale": 0.618
			},
			"trunk_width": 1,
			"trunk_block": {
				"name": "wypnt_bab:maple_log"
			},
			"branches": {
				"slope": 0.381,
				"density": 1,
				"min_altitude_factor": 0.2
			},
			"width_scale": 1,
			"foliage_altitude_factor": 0.3
		},
		"fancy_canopy": {
			"height": 4,
			"radius": 3,
			"leaf_block": {
				"name": "wypnt_bab:maple_leaves"
			}
		},
		"base_block": [
			"minecraft:dirt",
			"minecraft:coarse_dirt"
		],
		// Kinds of blocks the tree can be placed on.
    // We want all kinds of "dirt" blocks: dirt, grass, podzol, mud, etc.
    "may_grow_on": [
      {
        "tags": "query.any_tag('dirt')"
      }
    ],
		"may_replace": [
      "minecraft:air",
      "minecraft:snow_layer",
      // Sadly no tags for vanilla leaves yet
      "minecraft:acacia_leaves",
      "minecraft:azalea_leaves",
      "minecraft:azalea_leaves_flowered",
      "minecraft:birch_leaves",
      "minecraft:cherry_leaves",
      "minecraft:dark_oak_leaves",
      "minecraft:jungle_leaves",
      "minecraft:mangrove_leaves",
      "minecraft:oak_leaves",
      "minecraft:pale_oak_leaves",
      "minecraft:spruce_leaves",
      "wypnt_bab:autumn_sapling",
	// Tag to list all custom leaves		
      {
        "tags": "query.any_tag('wypnt_bab:custom_leaves')"
      },
	// Plants
      "minecraft:wildflowers",
      "minecraft:leaf_litter"
    ],
		// This is used when checking the volume the tree is going to be placed on.
    // Dirt around the placement area doesn't block the tree from being created.
    "may_grow_through": [
      {
        "tags": "query.any_tag('dirt')"
      }
    ]
	}
}