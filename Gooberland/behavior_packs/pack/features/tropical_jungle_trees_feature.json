{
  "format_version": "1.13.0",
  "minecraft:tree_feature": {
    "description": {
      "identifier": "wypnt_bab:tropical_jungle_trees_feature"
    },
    "acacia_trunk": {
      "trunk_width": 1,
      "trunk_height": {
        "base": 4,
        "intervals": [ 3, 5, 7, 9 ]
      },
      "trunk_block": {
        "name": "minecraft:jungle_log"
      },
      "trunk_lean": {
        "allow_diagonal_growth": true,
        "lean_height": {
          "range_min": 1,
          "range_max": 5
        },
        "lean_steps": {
          "range_min": 1,
          "range_max": 4
        }
      },
      "trunk_decoration": {
        "decoration_block": "minecraft:vine",
        "decoration_chance": {
          "numerator": 6,
          "denominator": 7
        }
      },
      "branches": {
        "branch_chance": 100.0,
        "branch_length": {
          "range_min": 1,
          "range_max": 3
        },
        "branch_position": {
          "range_min": 1,
          "range_max": 2
        },
        "branch_canopy": {
          "canopy": {
            "leaf_block": "minecraft:jungle_leaves",
            "canopy_offset": {
              "min": -2,
              "max": 0
            },
            "canopy_slope": {
              "rise": 1,
              "run": 1
            },
            "canopy_decoration": {
              "decoration_block": "minecraft:vine",
              "decoration_chance": {
                "numerator": 1,
                "denominator": 2
              },
              "num_steps": 4,
              "step_direction": "down"
            },
            "min_width": 1,
            "variation_chance": [
              {
                "numerator": 1,
                "denominator": 1
              }
            ]
          }
        }
      }
    },
    "acacia_canopy": {
      "canopy_size": 3,
      "leaf_block": {
        "name": "minecraft:jungle_leaves"
      }
    },
    // Kinds of blocks the tree can be placed on.
    // We want all kinds of "dirt" blocks: dirt, grass, podzol, mud, etc.
    "may_grow_on": [
      { "tags": "query.any_tag('dirt')" }
    ],
    // Whatever kind of "dirt" the tree gets planted on, it will be replaced
    // by an actual Dirt block if it isn't one already.
    "base_block": [
      "minecraft:dirt",
      "minecraft:coarse_dirt"
    ],
    // This is used when checking the volume the tree is going to be placed on.
    // Dirt around the placement area doesn't block the tree from being created.
    "may_grow_through": [
      { "tags": "query.any_tag('dirt')" }
    ],
    // Blocks that can be replaced by the tree's trunk and canopy.
    "may_replace": [
       "minecraft:air",
      "minecraft:snow_layer",
      // Sadly no tags for vanilla leaves yet
      "minecraft:acacia_leaves",
      "minecraft:azalea_leaves",
      "minecraft:azalea_leaves_flowered",
      "minecraft:birch_leaves",
      "minecraft:cherry_leaves",
      "minecraft:dark_oak_leaves",
      "minecraft:jungle_leaves",
      "minecraft:mangrove_leaves",
      "minecraft:oak_leaves",
      "minecraft:pale_oak_leaves",
      "minecraft:spruce_leaves",
	// Tag to list all custom leaves		
      {
        "tags": "query.any_tag('wypnt_bab:custom_leaves')"
      },
	// Plants
      "minecraft:wildflowers",
      "minecraft:leaf_litter"
    ]
  }
}
