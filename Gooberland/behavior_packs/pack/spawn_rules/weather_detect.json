{
    "format_version": "1.8.0",
    "minecraft:spawn_rules": {
        "description": {
            "identifier": "wypnt_bab:weather_detect",
            "population_control": "animal"
        },
        "conditions": [
            {
                "minecraft:spawns_on_surface": {},
                "minecraft:brightness_filter": {
                    "min": 0,
                    "max": 15,
                    "adjust_for_weather": true
                },
                "minecraft:weight": {
                    "default": 300
                },
                "minecraft:biome_filter": [
                    {
                        "any_of": [
                            {
                                "test": "has_biome_tag",
                                "operator": "==",
                                "value": "desert"
                            },
                            {
                                "test": "has_biome_tag",
                                "operator": "==",
                                "value": "frozen"
                            },
                            {
                                "test": "has_biome_tag",
                                "operator": "==",
                                "value": "cold"
                            }
                        ]
                    }
                ],
                "minecraft:herd": {
                    "min_size": 1,
                    "max_size": 1
                }
            }
        ]
    }
}
