              }
            },
            {
              "image_panel@server_form.custom_toggle_panel": {
                "$name": "toggle5",
                "$text": "book.ancient.entry.image",
                "$index": 2,
                "$padding": [52, 21]
              }
            }
          ]
        }
      },
      {
        "offset": {
          "type": "panel",
          "size": [35, "100%"]
        }
      },
      {
        "pages": {
          "type": "stack_panel",
          "size": ["100%", "100%"],
          "orientation": "vertical",
          "collection_name": "form_buttons",
          "controls": [
            {
              "first_page": {
                "type": "stack_panel",
                "size": ["100%", "100%"],
                "orientation": "vertical",
                "anchor_from": "center",
                "anchor_to": "center",
                "collection_name": "form_buttons",
                "controls": [
                  {
                    "main_label": {
                      "type": "label",
                      "color": [0, 0, 0],
                      "layer": 2,
                      "size": ["100%", "default"],
                      "text": "#text",
                      "bindings": [
                        {
                          "binding_type": "global",
                          "binding_name": "#form_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('§n' + ('%.200s' * #form_text)) - ''",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  },
                  {
                    "offset_button@server_form.arrow_custom_button": {
                      "collection_index": 0
                    }
                  }
                ]
              }
            },
            {
              "second_page": {
                "type": "stack_panel",
                "size": ["100%", "100%"],
                "orientation": "vertical",
                "anchor_from": "center",
                "anchor_to": "center",
                "collection_name": "form_buttons",
                "controls": [
                  {
                    "main_label": {
                      "type": "label",
                      "color": [0, 0, 0],
                      "layer": 2,
                      "size": ["90%", "default"],
                      "text": "#text",
                      "bindings": [
                        {
                          "binding_type": "global",
                          "binding_name": "#form_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('§n' + (('%.400s' * #form_text) - ('%.200s' * #form_text))) - ''",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "custom_toggle_panel": {
    "type": "panel",
    "$toggle_size|default": [82, 21],
    "$padding|default": [52, 21],
    "$index|default": 1,
    "$name|default": "view_toggle",
    "$text|default": "Toggle",
    "size": "$padding",

    "controls": [
      {
        "custom_toggle@common_toggles.light_text_toggle": {
          "$default_texture": "textures/ui/tab_not_selected", //un-toggled toggle normal
          "$hover_texture": "textures/ui/tab_selected", //toggled toggle normal

          "$pressed_texture": "textures/ui/tab_hover", //un-toggled toggle hover
          "$pressed_no_hover_texture": "textures/ui/tab_selected", //toggled toggle hover

          "$hover_checked_text_color": [0.8, 0.8, 0.8], //toggled toggle hover text color
          "$default_checked_text_color": [0, 0, 0], //toggled toggle normal text color
          "$hover_text_color": [0.7, 0.7, 0.7], //un-toggled toggle hover text color
          "$default_text_color": [0, 0, 0], //un-toggled toggle normal text color

          "$default_border_visible": false, //border visibility
          "$hover_border_visible": false, //border hover visibility

          "$toggle_name": "our_toggle",
          "$button_text": "$text",
          "size": "$toggle_size",
          "$toggle_view_binding_name": "$name",
          "$radio_toggle_group": true,
          "$toggle_group_default_selected": 1,
          "$toggle_group_forced_index": "$index",
          "anchor_from": "center",
          "anchor_to": "center"
        }
      }
    ]
  },

  "ancients_custom_button": {
    "$padding|default": [170, 25],
    "$button_size|default": [165, 25],
    "$icon_size|default": [14, 14],
    "type": "panel",
    "size": "$padding",
    

    // button textures
    "$default_button_texture": "textures/ui/button_normal",
    "$hover_button_texture": "textures/ui/button_hover",
    "$pressed_button_texture": "textures/ui/button_active",

    "$border_visible": false, //border visibility

    "controls": [
      {
        "main_ui": {
          "type": "panel",
          "size": "$button_size",
          "controls": [
            {
              "form_button@common_buttons.light_text_button": {
                "$pressed_button_name": "button.form_button_click",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "size": "$button_size",
                "$button_text": "#null",
                "$button_text_binding_type": "collection",
                "$button_text_grid_collection_name": "form_buttons",
                "$button_text_max_size": ["100%", 20],
                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not (#form_button_text = 'book.ancients.notfound'))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "text": {
                "type": "label",
                "text": "#form_button_text",
                "layer": 32,
                "color": [0, 0, 0],
                "offset": [8, 0],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            },
            {
              "image": {
                "type": "image",
                "layer": 32,
                "size": "$icon_size",
                "anchor_from": "right_middle",
                "anchor_to": "right_middle",
                "offset": [-5, 0],
                "bindings": [
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

