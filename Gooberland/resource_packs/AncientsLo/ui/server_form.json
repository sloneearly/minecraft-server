{
  "namespace": "server_form",
  "long_form": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "custom_long_form@common_dialogs.main_panel_no_buttons": {
          "$title_panel": "common_dialogs.standard_title_label",
          "$title_size": ["100% - 14px", 10],
          "size": [225, 200],
          "$text_name": "#title_text",
          "$title_text_binding_type": "none",
          "$child_control": "server_form.long_form_panel",
          "layer": 2,
          "bindings": [
            {
              "binding_name": "#title_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "(((#title_text - 'book.ancients.entry') - 'book.ancients.entry.info') = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      {
        "ancient_book@common_dialogs.main_panel_no_buttons": {
          "$title_panel": "common_dialogs.standard_title_label",
          "$title_size": ["100% - 14px", 10],
          "size": [200, 280],
          "$text_name": "#title_text",
          "$title_text_binding_type": "none",
          "$child_control": "server_form.my_super_custom_ancient_panel_main",

          "$custom_background": "server_form.ancient_custom_form_ui", //custom form ui
          "$show_close_button": false, //hide original close button
          "$use_custom_title_control": true, //hide original title

          "layer": 2,
          "bindings": [
            {
              "binding_name": "#title_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#title_text = 'book.ancients.entry')",
              "target_property_name": "#visible"
              
            }
          ]
        }
      },
      {
        "ancient_chapters@common_dialogs.main_panel_no_buttons": {
          "$title_panel": "common_dialogs.standard_title_label",
          "$title_size": ["100% - 14px", 10],
          "size": [200, 280],
          "$text_name": "#title_text",
          "$title_text_binding_type": "none",
          "$child_control": "server_form.rustic_info_custom_panel_main",

          "$custom_background": "server_form.ancient_custom_form_ui", //custom form ui
          "$show_close_button": false, //hide original close button
          "$use_custom_title_control": true, //hide original title

          "layer": 2,
          "bindings": [
            {
              "binding_name": "#title_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#title_text = 'book.ancients.entry.chapter')",
              "target_property_name": "#visible"
              
            }
          ]
        }
      }
    ]
  },

  "ancient_custom_form_ui": {
    "type": "image",
    "texture": "textures/ui/ancient_book",
    "$fill_alpha": 1,
    "alpha": "$fill_alpha",
    "controls": [
      {
        "close_button_holder": {
          "type": "stack_panel",
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "$close_button_panel_size": [20, 20],
          "offset": [167, 20],
          "controls": [
            {
              "close@common.close_button": {
                "controls": [
                  {
                    "default@common.close_button_panel": {
                      "$close_button_texture": "textures/ui/custom_back_button_default"
                    }
                  },
                  {
                    "hover@common.close_button_panel": {
                      "$close_button_texture": "textures/ui/custom_back_button_hover"
                    }
                  },
                  {
                    "pressed@common.close_button_panel": {
                      "$close_button_texture": "textures/ui/custom_back_button_pressed"
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      //title
      {
        "title_label": {
          "type": "label",
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "color": [255, 215, 0],
          "text": "$text_name",
          "font_size": "normal",
          "font_scale_factor": 1.25,
          "offset": [0, 30],
          "bindings": [
            {
              "binding_type": "$title_text_binding_type",
              "binding_name": "$text_name",
              "binding_name_override": "$text_name"
            }
          ]
        }
      }
    ]
  },

  "my_super_custom_ancient_panel_main": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
    "offset": [-62.5, 10],
    "orientation": "horizontal",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "collection_name": "form_buttons",
    "$top_half_variant": "crafting.survival_panel_top_half",
    "controls": [
      {
        "toggles": {
          "type": "stack_panel",
          "size": ["20%", "100%"],
          "orientation": "vertical",
          "controls": [
            {
              "custom_toggle_panel@server_form.custom_toggle_panel": {
                "$name": "toggle1",
                "$text": "book.ancients.chapter.forest",
                "$index": 1,
                "$padding": [52, 21]
              }
            }
          ]
        }
      },
      {
        "offset": {
          "type": "panel",
          "size": [32, "100%"]
        }
      },
      {
        "pages": {
          "type": "stack_panel",
          "size": ["100%", "100%"],
          "orientation": "vertical",
          "collection_name": "form_buttons",
          "controls": [
            {
              "first_page": {
                "type": "stack_panel",
                "size": ["100%", "100%"],
                "orientation": "vertical",
                "anchor_from": "center",
                "anchor_to": "center",
                "collection_name": "form_buttons",
                "controls": [
                  {
                    "main_label": {
                      "type": "label",
                      "color": [0, 0, 0],
                      "layer": 2,
                      "size": ["90%", "default"],
                      "text": "#text",
                      "bindings": [
                        {
                          "binding_type": "global",
                          "binding_name": "#form_text"
                        },
                        {
                          "binding_type": "view",
                          "source_property_name": "('§n' + ('%.200s' * #form_text)) - ''",
                          "target_property_name": "#text"
                        }
                      ]
                    }
                  },
                  {
                    "forest_chapter1@server_form.ancients_custom_button": {
                      "collection_index": 0
                    }
                  },
                  {
                    "forest_chapter2@server_form.ancients_custom_button": {
                      "collection_index": 1
                    }
                  },
                  {
                    "forest_chapter3@server_form.ancients_custom_button": {
                      "collection_index": 2
                    }
                  },
                  {
                    "forest_chapter4@server_form.ancients_custom_button": {
                      "collection_index": 3
                    }
                  },
                  {
                    "forest_chapter5@server_form.ancients_custom_button": {
                      "collection_index": 4
                    }
                  },
                  {
                    "forest_chapter6@server_form.ancients_custom_button": {
                      "collection_index": 5
                    }
                  },
                  {
                    "forest_chapter7@server_form.ancients_custom_button": {
                      "collection_index": 6
                    }
                  }
                ],
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_control_name": "toggle1",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },

  "rustic_info_custom_panel_main": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
