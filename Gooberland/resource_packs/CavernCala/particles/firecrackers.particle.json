{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "firecrackers",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/solarstorm"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 200,
				"max_particles": 1000
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": 1
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 3,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 0.5
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": 1.5,
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["(0.3 + variable.particle_random_1*0.3) - (0.3 * variable.particle_age)", "(0.3 + variable.particle_random_1*0.3) - (0.3 * variable.particle_age)"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 0],
					"uv_size": [16, 16]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"1.0": "#00FF5900"
					}
				}
			}
		}
	}
}