{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.entity.ntk_corpse_wood.general": {
			"initial_state": "walking",
			"states": {
				"walking": {
					"animations": [
						{
							"walking": "query.modified_move_speed * 1.5"
						}
					],
					"blend_transition": 0.1,
					"transitions": [
					  {
							"attack_melee": "variable.attack_time > 0.0"
						}
					]
				},
				"attack_melee": {
					"animations": [ "attack_melee" ],
					"transitions": [
						{
							"walking": "variable.attack_time <= 0.0"
						}
					]
				}
			}
		}
	}
}
