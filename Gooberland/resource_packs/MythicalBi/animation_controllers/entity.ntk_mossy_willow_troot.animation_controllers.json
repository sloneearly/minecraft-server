{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.entity.ntk_mossy_willow_troot.general": {
			"initial_state": "walking",
			"states": {
				"walking": {
					"animations": [
						{
							"walking": "query.modified_move_speed"
						}
					],
					"blend_transition": 0.1,
					"transitions": [
					  {
							"attack_melee": "variable.attack_time > 0.0"
						},
						{
							"sitting": "query.is_sitting"
						}
					]
				},
				"attack_melee": {
					"animations": [ "attack_melee" ],
					"transitions": [
						{
							"walking": "variable.attack_time <= 0.0"
						}
					]
				},
				"sitting": {
					"animations": [ "sitting" ],
					"blend_transition": 0.1,
					"transitions": [
					  {
					    "walking": "!query.is_sitting"
					  }
					]
				}
			}
		}
	}
}
