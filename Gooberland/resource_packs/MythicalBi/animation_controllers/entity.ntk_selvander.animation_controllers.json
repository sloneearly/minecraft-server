{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.entity.ntk_selvander.general": {
			"initial_state": "walking",
			"states": {
				"walking": {
					"animations": [
						{
							"walking": "query.modified_move_speed * 1.2"
						}
					],
					"blend_transition": 0.1,
					"transitions": [
					  {
							"attack_melee": "variable.attack_time > 0.0"
						},
						{
							"sitting": "query.is_sitting && query.is_on_ground && !query.is_in_water"
						},
						{
							"swimming": "!query.is_on_ground && query.is_in_water"
						}
					]
				},
				"attack_melee": {
					"animations": [ "attack_melee" ],
					"transitions": [
						{
							"walking": "variable.attack_time <= 0.0"
						}
					]
				},
				"sitting": {
					"animations": [ "sitting" ],
					"blend_transition": 0.2,
					"transitions": [
						{
							"walking": "!query.is_sitting || !query.is_on_ground || query.is_in_water"
						}
					]
				},
				"swimming": {
					"animations": [
						{
							"swimming": "query.modified_move_speed * 1.2"
						}
					],
					"blend_transition": 0.1,
					"transitions": [
					  {
							"attack_melee": "variable.attack_time > 0.0"
						},
						{
							"walking": "query.is_on_ground && !query.is_in_water"
						}
					]
				}
			}
		}
	}
}
