{
	"format_version": "1.8.0",
	"render_controllers": {
		"controller.render.creepermagma": {
			"geometry": "geometry.default",
			"materials": [
				{
					"*": "material.default"
				},
				{
					"head": "material.default"
				}
			],
			"textures": ["query.is_angry ? Texture.angry : (query.is_tamed ? Texture.tame : Texture.default)"],
			"overlay_color": {
				"r": "((variable.flash==0)||(query.swelling_dir<0))?this:1",
				"g": "((variable.flash==0)||(query.swelling_dir<0))?this:1",
				"b": "((variable.flash==0)||(query.swelling_dir<0))?this:1",
				"a": "((variable.flash==0)||(query.swelling_dir<0))?this:1"
			}
		}
	}
}