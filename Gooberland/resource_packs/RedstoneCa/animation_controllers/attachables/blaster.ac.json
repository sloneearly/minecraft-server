{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.wan_redcave.blaster.start_use": {
      "states": {
        "default": {
          "animations": [
            "reset_use"
          ],
          "transitions": [
            {
              "using": "q.is_using_item && q.cooldown_time_remaining('slot.weapon.mainhand') == 0"
            }
          ],
          "blend_transition": 0.1
        },
        "using": {
          "animations": [
            "use"
          ],
          "transitions": [
            {
              "default": "!q.is_using_item || q.cooldown_time_remaining('slot.weapon.mainhand') > 0"
            }
          ],
          "blend_transition": 0.1
        }
      }
    }
  }
}