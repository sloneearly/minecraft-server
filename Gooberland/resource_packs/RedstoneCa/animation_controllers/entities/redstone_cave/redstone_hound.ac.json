{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.wan_redcave.redstone_hound.move": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "idle": "!v.stop_walking_anim"
            }
          ],
          "blend_transition": 0.2
        },
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "walk": "q.modified_move_speed > 0.1 && q.mark_variant != 1"
            },
            {
              "walk_hostile": "q.modified_move_speed > 0.1 && q.mark_variant == 1"
            }
          ],
          "blend_transition": 0.2
        },
        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "idle": "q.modified_move_speed <= 0.1"
            }
          ],
          "sound_effects": [
            {
              "effect": "walk"
            }
          ],
          "blend_transition": 0.2
        },
        "walk_hostile": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "idle": "q.modified_move_speed <= 0.1"
            }
          ],
          "sound_effects": [
            {
              "effect": "walk_hostile"
            }
          ],
          "blend_transition": 0.2
        }
      }
    },
    "controller.animation.wan_redcave.redstone_hound.attack": {
      "initial_state": "default",
      "states": {
        "default": {
          "blend_transition": 0.1,
          "transitions": [
            {
              "bite": "q.variant == 2 && q.mark_variant != 1"
            },
            {
              "bite_hostile": "q.variant == 2 && q.mark_variant == 1"
            },
            {
              "saw": "q.variant == 3 && q.mark_variant != 1"
            },
            {
              "saw_hostile": "q.variant == 3 && q.mark_variant == 1"
            },
            {
              "charge": "q.variant == 4 && q.mark_variant != 1"
            },
            {
              "charge_hostile": "q.variant == 4 && q.mark_variant == 1"
            },
            {
              "on": "q.variant == 5"
            },
            {
              "off": "q.variant == 6"
            },
            {
              "sit": "q.variant == 7"
            }
          ]
        },
        "bite": {
          "animations": [
            "bite"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "bite"
            }
          ],
          "blend_transition": 0.1
        },
        "saw": {
          "animations": [
            "saw"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "saw"
            }
          ],
          "blend_transition": 0.1
        },
        "charge": {
          "animations": [
            "charge"
          ],
          "transitions": [
            {
              "laser": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "charge"
            }
          ],
          "blend_transition": 0.1
        },
        "laser": {
          "animations": [
            "laser"
          ],
          "transitions": [
            {
              "cooldown": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "laser"
            }
          ],
          "blend_transition": 0.1
        },
        "cooldown": {
          "animations": [
            "cooldown"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "cooldown"
            }
          ],
          "blend_transition": 0.1
        },
        "on": {
          "animations": [
            "on"
          ],
          "transitions": [
            {
              "default": "query.variant != 5"
            }
          ],
          "sound_effects": [
            {
              "effect": "on"
            }
          ],
          "blend_transition": 0.1
        },
        "off": {
          "on_entry": [
            "v.stop_walking_anim = 1;"
          ],
          "animations": [
            "off",
            {
              "off_post": "query.any_animation_finished"
            }
          ],
          "transitions": [
            {
              "default": "query.variant != 6"
            }
          ],
          "sound_effects": [
            {
              "effect": "off"
            }
          ],
          "on_exit": [
            "v.stop_walking_anim = 0;"
          ],
          "blend_transition": 0.1
        },
        "bite_hostile": {
          "animations": [
            "bite"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "bite_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "saw_hostile": {
          "animations": [
            "saw"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "saw_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "charge_hostile": {
          "animations": [
            "charge"
          ],
          "transitions": [
            {
              "laser_hostile": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "charge_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "laser_hostile": {
          "animations": [
            "laser"
          ],
          "transitions": [
            {
              "cooldown_hostile": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "laser_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "cooldown_hostile": {
          "animations": [
            "cooldown"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "cooldown_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "sit": {
          "animations": [
            "sit"
          ],
          "transitions": [
            {
              "sit_up": "query.variant != 7"
            }
          ],
          "blend_transition": 0
        },
        "sit_up": {
          "animations": [
            "up"
          ],
          "on_exit": [
            "v.stop_walking_anim = 0;"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "blend_transition": 0.1
        }
      }
    }
  }
}