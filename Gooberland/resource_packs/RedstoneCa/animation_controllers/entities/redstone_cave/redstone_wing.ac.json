{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.wan_redcave.redstone_wing.move": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "idle": "!v.stop_walking_anim"
            }
          ],
          "blend_transition": 0.2
        },
        "idle": {
          "animations": [
            "idle",
            "wings"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "walk": "q.modified_move_speed > 0.1"
            }
          ],
          "blend_transition": 0.2
        },
        "walk": {
          "animations": [
            "idle",
            "walk",
            "wings"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "idle": "q.modified_move_speed <= 0.1"
            }
          ],
          "blend_transition": 0.2
        }
      }
    },
    "controller.animation.wan_redcave.redstone_wing.attack": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "shoot": "q.variant == 2 && q.mark_variant != 1"
            },
            {
              "shoot_hostile": "q.variant == 2 && q.mark_variant == 1"
            },
            {
              "laser": "q.variant == 3 && q.mark_variant != 1"
            },
            {
              "laser_hostile": "q.variant == 3 && q.mark_variant == 1"
            },
            {
              "on": "q.variant == 4 && q.mark_variant != 1"
            },
            {
              "on_hostile": "q.variant == 4 && q.mark_variant == 1"
            },
            {
              "off": "q.variant == 5 && q.mark_variant != 1"
            },
            {
              "off_hostile": "q.variant == 5 && q.mark_variant == 1"
            }
          ],
          "blend_transition": 0.1
        },
        "shoot": {
          "animations": [
            "shoot"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "shoot"
            }
          ],
          "blend_transition": 0.1
        },
        "laser": {
          "animations": [
            "shoot"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "shoot"
            }
          ],
          "blend_transition": 0.1
        },
        "on": {
          "animations": [
            "on"
          ],
          "transitions": [
            {
              "default": "query.variant != 4"
            }
          ],
          "sound_effects": [
            {
              "effect": "on"
            }
          ],
          "blend_transition": 0.1
        },
        "off": {
          "on_entry": [
            "v.stop_walking_anim = 1;"
          ],
          "animations": [
            "off",
            {
              "off_post": "query.any_animation_finished"
            }
          ],
          "transitions": [
            {
              "default": "query.variant != 5"
            }
          ],
          "sound_effects": [
            {
              "effect": "off"
            }
          ],
          "on_exit": [
            "v.stop_walking_anim = 0;"
          ],
          "blend_transition": 0.1
        },
        "shoot_hostile": {
          "animations": [
            "shoot"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "shoot_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "laser_hostile": {
          "animations": [
            "shoot"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "shoot_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "on_hostile": {
          "animations": [
            "on"
          ],
          "transitions": [
            {
              "default": "query.variant != 4"
            }
          ],
          "sound_effects": [
            {
              "effect": "on_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "off_hostile": {
          "on_entry": [
            "v.stop_walking_anim = 1;"
          ],
          "animations": [
            "off",
            {
              "off_post": "query.any_animation_finished"
            }
          ],
          "transitions": [
            {
              "default": "query.variant != 5"
            }
          ],
          "sound_effects": [
            {
              "effect": "off_red"
            }
          ],
          "on_exit": [
            "v.stop_walking_anim = 0;"
          ],
          "blend_transition": 0.1
        }
      }
    }
  }
}