{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "chestplate:comet_chestplate.player",
      "item": {
        "chestplate:comet_chestplate": "query.owner_identifier == 'minecraft:player'"
      },
      "materials": {
        "default": "armor",
        "enchanted": "entity_beam_additive"
      },
      "textures": {
        "default": "textures/entity/helmet_comet_helmet",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "geometry": {
        "default": "geometry.ascendant_chestplate"
      },
      "scripts": {
        "parent_setup": "variable.chest_layer_visible = 0.0;"
      },
      "render_controllers": [
        "controller.render.armor"
      ]
    }
  }
}