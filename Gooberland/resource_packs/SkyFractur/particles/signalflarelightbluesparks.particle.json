{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "signalflarelightbluesparks",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/lightcube"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 30,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 20
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 3,
				"direction": ["math.random(-1, 1)", "math.random(-3, -1)", "math.random(-1, 1)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": "math.random(1, 5)",
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["(0.5 + variable.particle_random_1*0.3) - (0.5 * variable.particle_age)", "(0.5 + variable.particle_random_1*0.3) - (0.5 * variable.particle_age)"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 0],
					"uv_size": [16, 16]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#0000ECFF",
						"0.13": "#FF3FFAFF",
						"0.5": "#FF36FAFF",
						"0.87": "#FF3EFAFF",
						"1.0": "#0000F2FF"
					}
				}
			}
		}
	}
