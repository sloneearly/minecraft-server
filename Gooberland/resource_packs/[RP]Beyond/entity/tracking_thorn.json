{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "honkit26113:tracking_thorn",
      "materials": {
        "default": "arrow"
      },
      "textures": {
        "default": "textures/entity/honkit26113_thrown_thorn"
      },
      "geometry": {
        "default": "geometry.arrow"
      },
      "animations": {
        "move": "animation.arrow.move",
        "trail_particles": "animation.tracking_thorn.trail_particles"
      },
      "particle_effects": {
        "trail_particles": "minecraft:witchspell_emitter"
      },
      "scripts": {
        "scale": "1.3",
        "pre_animation": [
          "variable.shake = query.shake_time - query.frame_alpha;",
          "variable.shake_power = variable.shake > 0.0 ? -Math.sin(variable.shake * 200.0) * variable.shake : 0.0;"
        ],
        "animate": [
          "move",
          "trail_particles"
        ]
      },
      "render_controllers": [ "controller.render.arrow" ]
    }
  }
}
