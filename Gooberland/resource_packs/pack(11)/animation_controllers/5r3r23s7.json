{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.cc.eagle": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": ["idle"],
                    "transitions": [
                        {
                            "walk": "query.is_on_ground && query.ground_speed > 0"
                        },
                        {
                            "fly_up": "!query.is_on_ground && query.target_x_rotation >= 0"
                        },
                        {
                            "fly": "!query.is_on_ground && query.target_x_rotation < 0"
                        },
                        {
                            "dive": "query.is_interested && query.target_x_rotation < 0"
                        },
                        {
                            "has_rider": "query.has_rider == 1"
                        }
                    ],
                    "blend_transition": 0.1
                },
                "walk": {
                    "animations": ["walk"],
                    "transitions": [
                        {
                            "idle": "query.is_on_ground && query.ground_speed <= 0"
                        },
                        {
                            "fly_up": "!query.is_on_ground && query.target_x_rotation >= 0"
                        },
                        {
                            "fly": "!query.is_on_ground && query.target_x_rotation < 0"
                        },
                        {
                            "has_rider": "query.has_rider == 1"
                        }
                    ],
                    "blend_transition": 0.1
                },
                "fly_up": {
                    "animations": ["fly_up"],
                    "transitions": [
                        {
                            "idle": "query.is_on_ground && query.ground_speed <= 0"
                        },
                        {
                            "walk": "query.is_on_ground && query.ground_speed > 0"
                        },
                        {
                            "fly": "!query.is_on_ground && query.target_x_rotation < 0"
                        },
                        {
                            "dive": "query.is_interested && query.target_x_rotation < 0"
                        },
                        {
                            "has_rider": "query.has_rider"
                        }
                    ],
                    "blend_transition": 0.3
                },
                "fly": {
                    "animations": ["fly"],
                    "transitions": [
                        {
                            "idle": "query.is_on_ground && query.ground_speed <= 0"
                        },
                        {
                            "walk": "query.is_on_ground && query.ground_speed > 0"
                        },
                        {
                            "fly_up": "!query.is_on_ground && query.target_x_rotation >= 0"
                        },
                        {
                            "dive": "query.is_interested && query.target_x_rotation < 0"
                        },
                        {
                            "has_rider": "query.has_rider == 1"
                        }
                    ],
                    "blend_transition": 0.3
                },
                "dive": {
                    "animations": ["dive"],
                    "transitions": [
                        {
                            "walk": "query.is_on_ground && query.ground_speed > 0"
                        },
                        {
                            "fly_up": "!query.is_on_ground && query.target_x_rotation >= 0"
                        },
                        {
                            "fly": "!query.is_on_ground && query.target_x_rotation < 0"
                        },
                        {
                            "has_rider": "query.has_rider == 1"
                        }
                    ],
                    "blend_transition": 0.3
                },
                "has_rider": {
                    "animations": ["has_rider", "fly_up"],
                    "transitions": [
                        {
                            "idle": "query.has_rider == 0"
                        },
                        {
                            "walk": "query.has_rider == 0"
                        },
                        {
                            "fly_up": "query.has_rider == 0"
                        },
                        {
                            "fly": "query.has_rider == 0"
                        }
                    ],
                    "blend_transition": 0.3
                }
            }
        }
    }
}
