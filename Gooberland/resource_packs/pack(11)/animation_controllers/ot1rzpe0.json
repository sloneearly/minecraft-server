{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.cc.emerge": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "transitions": [
            {
              "emerge": "query.property('cc:is_emerging') == 1"
            }
          ],
          "blend_transition": 0.1
        },
        "emerge": {
          "animations": ["emerge"],
          "transitions": [
            {
              "idle": "query.property('cc:is_emerging') == 0 && q.all_animations_finished"
            }
          ],
          "blend_transition": 0.1
        }
      }
    },
    "controller.animation.cc.vanish": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "transitions": [
            {
              "vanish": "query.property('cc:is_vanishing') == 1"
            }
          ],
          "blend_transition": 0.1
        },
        "vanish": {
          "animations": ["vanish"],
          "transitions": [
            {
              "idle": "query.property('cc:is_vanishing') == 0 && q.all_animations_finished"
            }
          ],
          "blend_transition":  0.1
        }
      }
    }
  }
}
