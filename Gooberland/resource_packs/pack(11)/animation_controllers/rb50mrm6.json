{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.cc.pharaoh.casting": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "casting": "q.is_casting"
            },
            {
              "shooting": "q.is_charged"
            }
          ],
          "blend_transition": 0.25
        },
        "casting": {
          "animations": ["casting"],
          "blend_transition": 0.25,
          "transitions": [
            {
              "default": "!q.is_casting"
            }
          ]
        },
        "shooting": {
          "animations": ["shoot"],
          "blend_transition": 0.25,
          "transitions": [
            {
              "default": "q.all_animations_finished || !q.facing_target_to_range_attack"
            }
          ]
        }
      }
    }
  }
}
