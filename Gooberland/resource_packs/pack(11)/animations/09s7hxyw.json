        },
        "0.374": {
          "effect": "breach_cloud",
          "locator": "blowhole"
        }
      }
    },
    "animation.cc.whale.player.ride": {
      "loop": true,
      "bones": {
        "root": {
          "rotation": [90, 0, 0],
          "position": [0, 6, 13]
        },
        "leftArm": {
          "rotation": [-145, 0, 0]
        },
        "rightArm": {
          "rotation": [-135, 0, 0]
        },
        "leftLeg": {
          "rotation": ["90 + math.sin(query.life_time * 100) * 10", 20, -20]
        },
        "rightLeg": {
          "rotation": ["90 - math.sin(query.life_time * 100) * 10", -20, 20]
        }
