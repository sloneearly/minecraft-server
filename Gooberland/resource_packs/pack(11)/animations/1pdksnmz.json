{
  "format_version": "1.8.0",
  "animations": {
    "animation.cc.player.attack.attachable": {
      "loop": true,
      "animation_length": 1.0,
      "bones": {
        "rightItem": {
          "rotation": [
            "v.is_first_person ? (v.attack_time > 0 ? 45 : 0) : 0",
            "v.is_first_person ? (v.attack_time > 0 ? -45 : 0) : 0",
            "v.is_first_person ? (v.attack_time > 0 ? -45 : 0) : 0"
          ]
        }
      }
    },
    "animation.cc.player.hold_crossbow_item": {
      "loop": true,
      "bones": {
        "rightArm": {
          "rotation": [
            "v.is_first_person ? 0 : (q.head_x_rotation(0) + -72.5) + (v.tcos0 * 0.5) + (q.is_riding ? 15 : 0)",
            "v.is_first_person ? 0 : q.head_y_rotation(0) - q.body_y_rotation(0)",
            0
          ]
        },
        "leftArm": {
          "rotation": [
            "v.is_first_person ? 0 : (q.head_x_rotation(0) + -90) - (v.tcos0 * (q.is_item_equipped(1) ? 0.5 : 1)) + (q.is_riding ? 15 : 0)",
            "v.is_first_person ? 0 : 25 + (q.head_y_rotation(0) - q.body_y_rotation(0))",
            0
          ],
          "position": [
            "v.is_first_person ? 0 : -1",
            0,
            "v.is_first_person ? 0 : -1"
          ]
        }
      }
    }
  }
}