{
  "format_version": "1.8.0",
  "animations": {
    "animation.cc.javelin.rotate": {
      "loop": true,
      "bones": {
        "root": {
          "rotation": ["-q.body_x_rotation - 90", "-q.body_y_rotation", 0]
        },
        "outline": {
          "rotation": ["-q.body_x_rotation - 90", "-q.body_y_rotation", 0]
        }
      }
    },
    "animation.cc.javelin.wield_first_person": {
      "loop": true,
      "bones": {
        "pole": {
          "position": [-7, -3, -2],
          "rotation": [152, -9, 25]
        }
      }
    },
    "animation.cc.javelin.wield_first_person_raise": {
      "loop": true,
      "bones": {
        "pole": {
          "position": [
            "6.0 + (variable.charge_amount <= 0.25 ? math.lerp(0.0, -6.5, variable.charge_amount * 4.0) : -6.5) + (variable.charge_amount > 0.25 ? math.lerp(0.0, -4.0, (variable.charge_amount - 0.25) * 1.33) : 0.0)",
            "-3.0 + (variable.charge_amount <= 0.25 ? math.lerp(0.0, -3.0, variable.charge_amount * 4.0) : -3.0) + (variable.charge_amount > 0.25 ? math.lerp(0.0, 3.0, (variable.charge_amount - 0.25) * 1.33) : 0.0)",
            "8.0 + (variable.charge_amount <= 0.25 ? math.lerp(0.0, -16.5, variable.charge_amount * 4.0) : -16.5) + (variable.charge_amount > 0.25 ? math.lerp(0.0, 0.0, (variable.charge_amount - 0.25) * 1.33) : 0.0)"
          ],
          "rotation": [30, -20, -65]
        }
      }
    },
    "animation.cc.javelin.wield_first_person_raise_shake": {
      "loop": true,
      "bones": {
        "pole": {
          "position": [
            0,
            "variable.charge_amount >= 1.0 ? math.sin(q.life_time * 1000.0 * 1.3) * 0.1 - math.sin(q.life_time * 45.0) * 0.5 : 0.0",
            0
          ],
          "rotation": [0, 0, 0]
        }
      }
    },
    "animation.cc.javelin.wield_first_person_riptide": {
      "loop": true,
      "override_previous_animation": true,
      "bones": {
        "pole": {
          "position": [-2, -7, -10],
          "rotation": [180, 60, -36]
        }
      }
    },
    "animation.cc.javelin.wield_third_person": {
      "loop": true,
      "bones": {
        "pole": {
          "position": [1.5, -2.5, -10.5],
          "rotation": [97, -1.5, -49]
        }
      }
    },
    "animation.cc.javelin.wield_third_person_raise": {
      "loop": true,
      "bones": {
        "pole": {
          "position": [-0.7, 0, 17.5],
          "rotation": [-7, 180, -40]
        }
      }
    }
  }
}
