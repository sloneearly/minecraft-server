{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "cc:wooden_javelin",
      "materials": {
        "default": "entity_alphatest",
        "enchanted": "entity_alphatest_glint"
      },
      "textures": {
        "default": "textures/cc/weapons/items/javelin/wood",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "geometry": {
        "default": "geometry.cc.mesh_attachable"
      },
      "animations": {
        "wield": "controller.animation.trident.wield",
        "wield_first_person": "animation.cc.weapon.wield.first_person",
        "wield_third_person": "animation.cc.weapon.wield.third_person",
        "wield_first_person_raise": "animation.cc.trident.wield_first_person_raise",
        "wield_first_person_raise_shake": "animation.cc.trident.wield_first_person_raise_shake",
        "wield_first_person_riptide": "animation.cc.trident.wield_first_person_riptide",
        "wield_third_person_raise": "animation.cc.trident.wield_third_person_raise",
        "scale": "animation.cc.weapon.scale.20px"
      },
      "scripts": {
        "pre_animation": [
          "variable.charge_amount = math.clamp((query.main_hand_item_max_duration - (query.main_hand_item_use_duration - query.frame_alpha + 1.0)) / 10.0, 0.0, 1.0f);"
        ],
        "animate": ["wield","scale"]
      },
      "render_controllers": ["controller.render.item_default"]
    }
  }
}
