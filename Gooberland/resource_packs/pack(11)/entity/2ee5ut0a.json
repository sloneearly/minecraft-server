{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "cc:deer",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "one": "textures/cc/animals/entities/deer/1",
        "two": "textures/cc/animals/entities/deer/2",
        "three": "textures/cc/animals/entities/deer/3",
        "four": "textures/cc/animals/entities/deer/4"
      },
      "geometry": {
        "default": "geometry.cc.deer"
      },
      "spawn_egg": {
        "texture_index": 0,
        "texture": "cc:deer_spawn_egg"
      },
      "scripts": {
        "initialize": [
          "variable.pitch = 0;",
          "variable.roll = 0;",
          "v.relative_run_speed = 0.6;",
          "v.max_leg_rot = 45;",
          "v.max_leg_pos_h = 1;",
          "v.max_leg_pos_v = 3;",
          "v.body_bump = 1;",
          "v.body_rot = 5;",
          "v.head_bump = 0.5;",
          "v.playback_multiplier = 0.8;"
        ],
        "pre_animation": [
          "variable.pitch = ((math.clamp(q.is_on_ground ? 0 : q.body_x_rotation, -20, 20) - (math.clamp(q.vertical_speed * 1, -90, 5)) + ( 3 * variable.pitch)) / 4);",
          "variable.roll = ((q.is_on_ground ? 0 : (-q.yaw_speed) / 4) + (4 * v.roll)) / 5;"
        ],
        "animate": [
          "look_at_target",
          "root",
          "move_controller",
          "attack_controller",
          "graze_controller",
          "lay_down_controller",
          "rotate_controller",
          { "baby_transform": "query.is_baby" }
        ]
      },
      "animations": {
        "move_controller": "controller.animation.cc.move",
        "attack_controller": "controller.animation.cc.delayed_attack",
        "graze_controller": "controller.animation.cc.graze",
        "lay_down_controller": "controller.animation.cc.lay_down",

        "look_at_target": "animation.common.look_at_target",
        "baby_transform": "animation.cc.baby_transform.half",

        "root": "animation.cc.common.root",

        "idle": "animation.cc.deer.idle",
        "walk": "animation.cc.quadruped.walk",
        "run": "animation.cc.deer.run",
        "swim": "animation.cc.deer.walk",
        "swim_idle": "animation.cc.deer.walk",
        "swim_run": "animation.cc.deer.walk",
        "sit": "animation.cc.crocodile.walk",
        "fly": "animation.cc.deer.walk",
        "delayed_attack": "animation.cc.deer.walk",
        "graze": "animation.cc.deer.graze",
        "rotate": "animation.cc.quadruped.rotation",
        "rotate_controller": "controller.animation.cc.quadruped.rotation"
      },
      "render_controllers": ["controller.render.cc.deer"],
      "enable_attachables": true
    }
  }
}
