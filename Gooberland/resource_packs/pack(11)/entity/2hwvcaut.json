{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "cc:siren",
      "materials": {
        "default": "entity_alphatest"
      },
      "geometry": {
        "default": "geometry.cc.siren"
      },
      "render_controllers": ["controller.render.cc.common"],
      "textures": {
        "default": "textures/cc/mermaids/entities/siren"
      },
      "animations": {
        "move_controller": "controller.animation.cc.mermaid.move",
        "idle": "animation.cc.mermaid.idle",
        "swim": "animation.cc.mermaid.swim",
        "look_at_target": "animation.common.look_at_target",
        "casting": "animation.cc.pharaoh.casting",
        "casting_controller": "controller.animation.cc.pharaoh.casting",
        "shoot": "animation.cc.pharaoh.shoot"
      },
      "scripts": {
        "initialize": [
          "v.relative_run_speed = 0.6;",
          "variable.pitch = 0;",
          "variable.roll = 0;"
        ],
        "pre_animation": [
          "variable.pitch = ((math.clamp(q.is_on_ground ? 0 : q.body_x_rotation, -20, 20) - (math.clamp(q.vertical_speed * 1, -90, 5)) + ( 3 * variable.pitch)) / 4);",
          // plane only rolls in the air
          "variable.roll = ((q.is_on_ground ? 0 : (-q.yaw_speed) / 4) + (4 * v.roll)) / 5;"
        ],
        "animate": ["move_controller", "look_at_target", "casting_controller"]
      },
      "spawn_egg": {
        "texture_index": 0,
        "texture": "cc:siren_spawn_egg"
      }
    }
  }
}
