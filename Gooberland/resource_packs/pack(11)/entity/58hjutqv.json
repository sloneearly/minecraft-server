{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "cc:spear_illager",
      "min_engine_version": "1.8.0",
      "materials": {
        "default": "pillager"
      },
      "textures": {
        "default": "textures/cc/village/entities/illager/spear"
      },
      "geometry": {
        "default": "geometry.cc.pillager"
      },
      "spawn_egg": {
        "texture": "cc:spear_illager_spawn_egg"
      },
      "scripts": {
        "pre_animation": [
          "variable.tcos0 = (Math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;",
          "variable.riding_y_offset_baby_scaling = query.is_baby ? -3.5 : 0.0;",
          "variable.riding_y_offset_with_respect_to_player = 1.0;",
          "variable.riding_y_offset_on_vehicle_where_other_entites_can_stand = query.is_riding_any_entity_of_type('minecraft:minecart', 'minecraft:boat', 'minecraft:chest_boat') ? -3.0 : 0.0;",
          "variable.unscaled_riding_y_offset = variable.riding_y_offset_with_respect_to_player + variable.riding_y_offset_on_vehicle_where_other_entites_can_stand;",
          "variable.riding_y_offset = variable.riding_y_offset_baby_scaling * math.abs(variable.unscaled_riding_y_offset) + variable.unscaled_riding_y_offset + variable.riding_y_offset_baby_scaling * 0.2f;",
          "v.melee_spear_equipped = query.is_item_name_any('slot.weapon.mainhand', 0, 'minecraft:wooden_spear', 'minecraft:golden_spear', 'minecraft:stone_spear', 'minecraft:copper_spear', 'minecraft:iron_spear', 'minecraft:diamond_spear', 'minecraft:netherite_spear');"
        ],
        "variables": {
          "variable.item_use_normalized": "public",
          "variable.tp_melee_spear_use_attachable_rotation_z": "public",
          "variable.tp_melee_spear_use_arm_rotation_x": "public",
          "variable.tp_melee_spear_use_arm_rotation_y": "public",
          "variable.tp_melee_spear_use_arm_rotation_z": "public"
        },
        "initialize": [
          "v.tp_melee_spear_base_arm_rotation_x = -25.0;",
          "v.tp_melee_spear_use_arm_rotation_x = -15;",
          "v.tp_melee_spear_use_item_rotation_x = 40.0;"
        ],
        "animate": [
          "look_at_target_controller",
          "move_controller",
          "riding_controller",
          "damage_nearby_mobs_controller",
          "swimming_controller",
          "melee_spear_controller",
          {"disable_body_overlay": "q.has_armor_slot(1) || q.has_armor_slot(2)"},
          {"riding_offset": "q.is_riding" }
        ],
        "should_update_effects_offscreen": "1.0"
      },
      "animations": {
        "look_at_target_default": "animation.humanoid.look_at_target.default",
        "look_at_target_gliding": "animation.humanoid.look_at_target.gliding",
        "look_at_target_swimming": "animation.humanoid.look_at_target.swimming",
        "move": "animation.humanoid.move",
        "riding.arms": "animation.humanoid.riding.arms",
        "riding.legs": "animation.humanoid.riding.legs",
        "riding_offset": "animation.cc.illager.riding_offset",
        "damage_nearby_mobs": "animation.humanoid.damage_nearby_mobs",
        "swimming": "animation.zombie.swimming",
        "look_at_target_controller": "controller.animation.humanoid.look_at_target",
        "move_controller": "controller.animation.humanoid.move",
        "riding.body": "animation.humanoid.riding.body",
        "riding_controller": "controller.animation.humanoid.riding",
        "damage_nearby_mobs_controller": "controller.animation.humanoid.damage_nearby_mobs",
        "swimming_controller": "controller.animation.zombie.swimming",
        "melee_spear_use": "animation.humanoid.melee_spear_use",
        "melee_spear_hold": "animation.humanoid.melee_spear_hold",
        "melee_spear_controller": "controller.animation.cc.melee_spear",
        "disable_body_overlay": "animation.cc.villager.disable_body_overlay"
      },
      "render_controllers": ["controller.render.default"],
      "enable_attachables": true
    }
  }
}
