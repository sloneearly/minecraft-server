{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "cc:capybara",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/cc/animals/entities/capybara",
        "muddy": "textures/cc/animals/entities/capybara.muddy"
      },
      "geometry": {
        "default": "geometry.cc.capybara"
      },
      "spawn_egg": {
        "texture_index": 0,
        "texture": "cc:capybara_spawn_egg"
      },
      "scripts": {
        "initialize": [
          "v.relative_run_speed = 0.6;",
          "variable.pitch = 0;",
          "variable.roll = 0;",
          "v.max_leg_rot = 45;",
          "v.max_leg_pos_h = 1;",
          "v.max_leg_pos_v = 3;",
          "v.body_bump = 2;",
          "v.body_rot = 5;",
          "v.head_bump = 1;",
          "v.playback_multiplier = 0.8;"
        ],
        "pre_animation": [
          "variable.pitch = ((math.clamp(q.is_on_ground ? 0 : q.body_x_rotation, -20, 20) - (math.clamp(q.vertical_speed * 1, -90, 5)) + ( 3 * variable.pitch)) / 4);",
          "variable.roll = ((q.is_on_ground ? 0 : (-q.yaw_speed) / 4) + (4 * v.roll)) / 5;"
        ],
        "animate": [
          "root",
          "move_controller",
          "lay_down_controller",
          "look_at_target",
          "bath_controller",
          "rotate_controller",
          { "baby_transform": "query.is_baby" }
        ]
      },
      "animations": {
        // Controllers
        "move_controller": "controller.animation.cc.move",
        "lay_down_controller": "controller.animation.cc.lay_down",

        "look_at_target": "animation.common.look_at_target",
        "baby_transform": "animation.cc.baby_transform.half",
        "bath_controller": "controller.animation.cc.bath",

        "root": "animation.cc.common.root",

        "idle": "animation.cc.capybara.idle",
        "walk": "animation.cc.capybara.walk",
        "fly": "animation.cc.quadruped.walk",
        "run": "animation.cc.quadruped.walk",
        "swim": "animation.cc.quadruped.walk",
        "swim_idle": "animation.cc.quadruped.walk",
        "swim_run": "animation.cc.quadruped.walk",
        "bath": "animation.cc.capybara.bath",
        "sit": "animation.cc.quadruped.walk",
        "rotate": "animation.cc.quadruped.rotation",
        "rotate_controller": "controller.animation.cc.quadruped.rotation"
      },
      "particle_effects": {
        "digging": "cc:scorpion_dig"
      },
      "sound_effects": {
        "digging": "cc:capybara_bath"
      },
      "render_controllers": [
        {
          "controller.render.cc.common": "q.property('cc:is_muddy') == 0"
        },
        {
          "controller.render.cc.muddy": "q.property('cc:is_muddy') == 1"
        }
      ],
      "enable_attachables": true
    }
  }
}
