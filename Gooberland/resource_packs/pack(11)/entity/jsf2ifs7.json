{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "cc:forgotten_miner",
      "materials": {
        "default": "entity_alphablend",
        "outline": "cc_outline"
      },
      "textures": {
        "default": "textures/cc/monsters/entities/forgotten_miner/default",
        "one": "textures/cc/monsters/entities/forgotten_miner/1",
        "two": "textures/cc/monsters/entities/forgotten_miner/2",
        "three": "textures/cc/monsters/entities/forgotten_miner/3",
        "four": "textures/cc/monsters/entities/forgotten_miner/4",
        "five": "textures/cc/monsters/entities/forgotten_miner/5",
        "six": "textures/cc/monsters/entities/forgotten_miner/6",
        "seven": "textures/cc/monsters/entities/forgotten_miner/7"
      },
      "geometry": {
        "default": "geometry.cc.forgotten_miner"
      },
      "spawn_egg": {
        "texture_index": 0,
        "texture": "cc:forgotten_miner_spawn_egg"
      },
      "scripts": {
        "initialize": ["v.tcos0 = 0;", "v.attack_state = 0;"],
        "pre_animation": [
          "variable.tcos0 = (Math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed / variable.gliding_speed_value) * 57.3;"
        ],
        "animate": [
          "pillager_root_controller",
          "delayed_attack_controller",
          { "cancel_death_anim": "!q.is_alive" }
        ]
      },
      "animations": {
        "humanoid_base_pose": "animation.humanoid.base_pose",
        "look_at_target_default": "animation.humanoid.look_at_target.default",
        "look_at_target_gliding": "animation.humanoid.look_at_target.gliding",
        "look_at_target_swimming": "animation.humanoid.look_at_target.swimming",
        "move": "animation.humanoid.move",
        "riding.arms": "animation.humanoid.riding.arms",
        "riding.legs": "animation.humanoid.riding.legs",
        "holding": "animation.humanoid.holding",
        "bob": "animation.humanoid.bob",
        "crossbow_hold": "animation.pillager.crossbow.hold",
        "crossbow_charge": "animation.pillager.crossbow.charge",
        "celebrating": "animation.humanoid.celebrating",
        "controller_humanoid_base_pose": "controller.animation.humanoid.base_pose",
        "controller_look_at_target": "controller.animation.humanoid.look_at_target",
        "controller_move": "controller.animation.humanoid.move",
        "controller_riding": "controller.animation.humanoid.riding",
        "controller_attack": "controller.animation.humanoid.attack",
        "controller_bob": "controller.animation.humanoid.bob",
        "controller_pillager_attack": "controller.animation.pillager.attack",
        "pillager_root_controller": "controller.animation.pillager.root",
        "attack.rotations": "animation.cc.filler",
        "delayed_attack": "animation.cc.forgotten_miner.attack",

        "delayed_attack_controller": "controller.animation.cc.delayed_attack",
        "cancel_death_anim": "animation.cc.cancel_death_animation"
      },
      "render_controllers": [
        "controller.render.cc.forgotten_miner",
        "controller.render.cc.forgotten_miner.outline"
      ],
      "enable_attachables": true,
      "hide_armor": true
    }
  }
}
