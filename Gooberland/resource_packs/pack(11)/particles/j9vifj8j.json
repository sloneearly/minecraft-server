{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "cc:summon_villager_smoke",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/cc/common/particles/smoke"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.size = math.random(0.4,0.6);v.rotation = math.random_integer(0.0,0.3);",
				"per_update_expression": "v.age = math.random(1,3);"
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 50,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.2
			},
			"minecraft:emitter_shape_box": {
				"offset": [0, 0.3, 0],
				"half_dimensions": [0.5, 0.5, 0.5],
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "v.age"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-45,45)",
				"rotation_rate": "math.random(0,100)"
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 1, 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.size", "v.size"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 144,
					"flipbook": {
						"base_UV": [0, 0],
						"size_UV": [16, 16],
						"step_UV": [0, 16],
						"frames_per_second": 16,
						"max_frame": 16,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"0.25": "#FFFFFFFF",
						"0.75": "#FFFFFFFF",
						"1.0": "#FFFFFFFF"
					}
				}
			}
		}
	}
}