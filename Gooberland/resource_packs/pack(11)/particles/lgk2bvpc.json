				"material": "particles_blend",
				"texture": "textures/cc/ritual/particles/fire_web"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.rotation = math.random_integer(0,2) * 90;v.size = 0.02;v.variant = math.random_integer(0,2) * 6;"
			},
			"minecraft:emitter_rate_instant": {
