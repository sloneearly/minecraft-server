{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "cc:hay_dust",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/cc/common/particles/hay_dust"
			}
		},
		"curves": {
			"variable.size": {
				"type": "linear",
				"input": "v.particle_age",
