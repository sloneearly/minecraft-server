				"nodes": [0, 1, 1, 1, 0]
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.fall_acc = -0.3; v.wind_acc = 10; v.curve_len = 15;"
			},
			"minecraft:emitter_rate_instant": {
