{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "cc:fire_sword_charged",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/cc/common/particles/fire.orange"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.age = math.random(0.5,0.8);"
			},
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 5
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_box": {
				"offset": [0.5, 0.3, 0.5],
				"half_dimensions": [0.5, 0.5, 0.5]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "v.age"
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 5, 0]
			},
			"minecraft:particle_motion_parametric": {
				"rotation": "1 * v.particle_age * 50"
			},
			"minecraft:particle_appearance_billboard": {
				"size": [0.2, 0.2],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 64,
					"texture_height": 576,
					"flipbook": {
						"base_UV": [0, 0],
						"size_UV": [64, 64],
						"step_UV": [0, 64],
						"frames_per_second": 15,
						"max_frame": 10,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"0.16": "#FFD5793B",
						"0.41": "#FF797A85"
					}
				}
			}
		}
	}
}