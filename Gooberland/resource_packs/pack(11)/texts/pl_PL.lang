entity.cc:bear.name=Niedźwiedź
item.spawn_egg.entity.cc:bear.name=Niedźwiedzie jajo lęgowe
entity.cc:bear.desc=§7To neutralne zwierzę można spotkać w lasach. Gdzie różne biomy mają różne warianty. Zachowaj dystans, gdy niedźwiedź ma w pobliżu młode, bo zaatakuje, jeśli uzna Cię za zagrożenie. Niedźwiedzie można tymczasowo oswoić za pomocą łososia lub plastra miodu. Będą strzec twojej straży, dopóki znowu nie poczują głodu. §r
entity.cc:capybara.name=Kapibara
item.spawn_egg.entity.cc:capybara.name=Jajko lęgowe kapibary
entity.cc:capybara.desc=§7Największy gryzoń na świecie. Uwielbiają błoto! Kiedy je nakarmisz ryżem, znajdą ładny basen błotny, w którym mogą pływać. Ich magia przekształca basen błotny w spa regeneracyjne, do którego możesz wrzucić jedzenie, aby się zregenerować!
tile.cc:capybara_mud.name=Błoto Kapibary
item.cc:capybara_mud=Błoto Kapibary
item.cc:capybara_mud.desc=§7Błoto powstało w miejscu, gdzie kapibary lubią odpoczywać.
entity.cc:cassowary.name=Kazuar
item.spawn_egg.entity.cc:cassowary.name=Jajo Spawnujące Kazuara
entity.cc:cassowary.desc=§7Kazuar to jeden z największych ptaków świata. Wędruje po dżungli i słynie z efektownych niebiesko-czarnych piór. Można go oswoić za pomocą nasion.
tile.cc:cassowary_egg.name=Jajko Kazuara
item.cc:cassowary_egg=Jajko Kazuara
item.cc:cassowary_feather=Pióro Kazuara
entity.cc:crocodile.name=Krokodyl
item.spawn_egg.entity.cc:crocodile.name=Jajo lęgowe krokodyla
entity.cc:crocodile.desc=§7Duży gad, często widywany na Bagnach. Zachowaj dystans, bo nie waha się przed atakiem.
item.cc:crocodile_scute=Krokodyl Łuk
item.cc:crocodile_scute.desc=§7Crocodile Scute spada, gdy mały Krokodyl staje się dorosły. Zrzuci łuski i dlatego spadnie na ziemię. Łuski można wykorzystać do zrobienia Krokodylich Butów.
tile.cc:crocodile_egg.name=Jajko Krokodyla
item.cc:crocodile_egg=Jajko Krokodyla
item.cc:crocodile_egg.desc=§7Duże jajo złożone przez krokodyla. Poczekaj wystarczająco długo, a urodzi się pisklę.
item.cc:crocodile_boots=Krokodyle Buty
item.cc:crocodile_boots.desc=§7Wytrzymałe buty wykonane z 4 łusek krokodyla. Sprawia, że ​​użytkownik jest szybszy w wodzie lub na mokrych blokach.
entity.cc:deer.name=Jeleń
item.spawn_egg.entity.cc:deer.name=Jajko lęgowe jelenia
entity.cc:deer.desc=§7Duży ssak żyjący w lesie. Łatwo go przestraszyć, więc pamiętaj, aby skradać się bardzo cicho, jeśli chcesz się zbliżyć. Jelenie można hodować z jabłkami. Poroże można obciąć za pomocą nożyc.
item.cc:deer_antler=Poroże Jelenia
item.cc:deer_antler.desc=§7Poroże jelenia, które można wykorzystać do stworzenia hełmu z poroża jelenia lub zamienić w mączkę kostną.
item.cc:deer_antler_helmet=Hełm z poroża jelenia
item.cc:deer_antler_helmet.desc=§7Hełm wykonany z poroża jelenia. Daje siłę odrzutu podczas noszenia.
entity.cc:eagle.name=Orzeł
item.spawn_egg.entity.cc:eagle.name=Jajo Spawnujące Orła
entity.cc:eagle.desc=§7Duży ptak żyjący w suchych biomach. Będzie atakował wrogie moby w nocy. Ale utrzymuj wysoki pasek zdrowia, w przeciwnym razie on też cię zaatakuje!
action.hint.exit.cc:eagle=Naciśnij :_input_key.sneak:, aby spróbować uciec przed Orłem
entity.cc:elephant.name=Słoń
item.spawn_egg.entity.cc:elephant.name=Jajko składane przez słonia
entity.cc:elephant.desc=§7Słoń to duży ssak żyjący na sawannie. Można je oswoić za pomocą orzeszków ziemnych i można na nich jeździć. Możesz strzelać do orzeszków ziemnych, jadąc na słoniu, trzymając orzeszka i wchodząc w interakcję.
action.hint.exit.cc:elephant=Naciśnij :_input_key.sneak:, aby zejść ze słonia
entity.cc:hermit.name=Pustelnik
item.spawn_egg.entity.cc:hermit.name=Jajko Przyzywające Pustelnika
entity.cc:hermit.desc=§7Szczęśliwy właściciel domu, ale zawsze chętny na handel domowy. Kraby Pustelniki zamienią Muszlę Nautilusa na upuszczony kokos.
entity.cc:meerkat.name=Surykatka
item.spawn_egg.entity.cc:meerkat.name=Jajko Spawnujące Surykatki
entity.cc:meerkat.desc=§7Mały ssak żyjący na sawannie. Można je rozmnażać, dając im Ogony Skorpiona. Jeśli Surykatka zostanie nakarmiona Pajęczym Okiem, gdy będzie kucać, przyniesie ci nagrodę ze swojej nory.
tile.cc:meerkat_burrow.name=Nora Surykatki
tile.cc:meerkat_burrow.desc=§7Nora znajdująca się na sawannie. Surykatki przyniosą ci nagrodę, jeśli zostaną nakarmione Pajęczym Okiem.
entity.cc:moose.name=Łoś
item.spawn_egg.entity.cc:moose.name=Jajko lęgowe łosia
entity.cc:moose.desc=§7Duży ssak żyjący w lesie. Łatwo go przestraszyć, więc pamiętaj, aby skradać się bardzo cicho, jeśli chcesz się zbliżyć. Łoś można rozmnażać z szyszkami. Poroże można obciąć za pomocą nożyc.
item.cc:moose_antler=Poroże łosia
item.cc:moose_antler.desc=§7Poroże łosia, które można wykorzystać do stworzenia hełmu z poroża łosia lub zamienić w mączkę kostną.
item.cc:moose_antler_helmet=Hełm z poroża łosia
item.cc:moose_antler_helmet.desc=§7Hełm wykonany z poroża łosia. Daje ci premię do odrzutu, gdy go nosisz.\n\n§r+ Ten przedmiot można wytworzyć na stole kowalskim przy użyciu poroża łosia, diamentowego hełmu i sztabki netheritu.
entity.cc:orangutan.name=Orangutan
item.spawn_egg.entity.cc:orangutan.name=Jajo rozrodcze orangutana
entity.cc:orangutan.desc=§7Mądry orangutan powiedział kiedyś: Ooh ooh aah aah! To prawdopodobnie oznaczało, że chciał banana. \n\nOrangutany mogą wymieniać różne owoce na banana. Ale nie handluj zbyt wieloma na raz, w przeciwnym razie zdenerwuje się i zacznie je odrzucać.
entity.cc:owl.name=Sowa
item.spawn_egg.entity.cc:owl.name=Jajo lęgowe sowy
entity.cc:owl.desc=§7Sowa jest Twoim przyjacielem w harcerstwie. Kiedy jest oswojony, może podążać za tobą, a kiedy wskoczy na twoje ramię, zapewni ci widzenie w nocy i wyda dźwięk, gdy niebezpieczeństwo będzie blisko. Skradnij się i skacz jednocześnie, aby zdjąć Sowę z ramienia.
entity.cc:pearl_clam.name=Perłowy Małż
item.spawn_egg.entity.cc:pearl_clam.name=Jajko Spawnujące Małży Perłowej
entity.cc:pearl_clam.desc=§7Prawdziwy pogromca pereł.~LINEBREAK~~LINEBREAK~Wejdź w interakcję, aby ją otworzyć.
item.cc:pearl=Perła
item.cc:pearl.desc=§7Perła, waluta morska. Można go używać do handlu z Syrenami.
entity.cc:penguin.name=Pingwin
item.spawn_egg.entity.cc:penguin.name=Jajo rozrodcze pingwina
entity.cc:penguin.desc=§7Przyjaciel Twojego rybaka. Pingwiny często polują na ryby. Kiedy złowią rybę, możesz ją zdobyć, wchodząc z nią w interakcję.
tile.cc:penguin_egg.name=Jajko Pingwina
item.cc:penguin_egg=Jajko Pingwina
item.cc:penguin_egg.desc=§7Ciaste jajo złożone przez pingwina. Poczekaj wystarczająco długo, a urodzi się pisklę.
entity.cc:raven.name=Kruk
item.spawn_egg.entity.cc:raven.name=Jajo Spawnujące Kruka
entity.cc:raven.desc=§7Kruk to prawdziwy poszukiwacz skarbów na lądzie. Krążą wokół struktur lochów, służąc jako naturalna latarnia morska dla towarów.
action.hint.exit.cc:raven=Naciśnij :_input_key.sneak:, aby wyjść z Kruka
entity.cc:scorpion.name=Skorpion
item.spawn_egg.entity.cc:scorpion.name=Jajo Spawnujące Skorpiona
entity.cc:scorpion.desc=§7Niebezpieczne zwierzę o ośmiu nogach żyjące w piasku. Nie podchodź za blisko, bo użądli cię swoim trującym ogonem..
item.scorpion_tail.name=Ogon Skorpiona
item.cc:scorpion_tail=Ogon Skorpiona
item.cc:scorpion_tail.desc=§7Ogon skorpiona, którym można kusić surykatki.
entity.cc:seagull.name=Mewa
item.spawn_egg.entity.cc:seagull.name=Jajko Spawnujące Mewy
entity.cc:seagull.desc=§7Mewa to prawdziwy poszukiwacz skarbów w oceanie. Krążą wokół zatopionych struktur lochów, służąc jako naturalna latarnia morska dla towarów. Trzymaj swoje przedmioty blisko siebie, ponieważ wiadomo, że kradną każdy przedmiot, jaki tylko znajdą. Możesz oddać skradziony przedmiot z powrotem, upuszczając ryby, tylko wtedy zamienią go.
entity.cc:shark.name=Rekin
item.spawn_egg.entity.cc:shark.name=Jajko lęgowe rekina
entity.cc:shark.desc=§7Duża ryba żyjąca w oceanie. Czasami te ryby mogą być zbyt zainteresowane twoją obecnością. Uderzając rekina w nos, odejdzie, a czasami upuści ząb.
item.cc:shark_tooth=Ząb Rekina
item.cc:shark_tooth.desc=§7Ząb rekina, którego można użyć do stworzenia napierśnika z zębami rekina.
item.cc:shark_tooth_chestplate=Napierśnik z Zębem Rekina
item.cc:shark_tooth_chestplate.desc=§7Napierśnik wykonany z zębów rekina. Ochroni Cię przed rekinami, ponieważ nie będą Cię atakować, gdy będziesz go nosić.
entity.cc:whale.name=Wieloryb
item.spawn_egg.entity.cc:whale.name=Jajko składane przez wieloryba
entity.cc:whale.desc=§7Największy ssak żyjący w oceanie. Wieloryby często mają pąkle, które podrażniają ich skórę. Za pomocą nożyc możesz usunąć pąkle, dzięki czemu wieloryb będzie postrzegał Cię jako przyjaciela. Tylko wtedy będziesz mógł wrócić na jego powrót i odkrywać morza szybciej niż kiedykolwiek wcześniej.
action.hint.exit.cc:whale=Naciśnij :_input_key.sneak:, aby wyjść z Wieloryba
entity.cc:big_foot.name=Wielka Stopa
item.spawn_egg.entity.cc:big_foot.name=Jajko Spawnowe Wielkiej Stopy
entity.cc:big_foot.desc=§7 Dziwnie trudna do znalezienia bestia. Bądź nim zmęczony, wiadomo, że jest wrogi i atakuje wszystko, co go prowokuje.
item.cc:big_foot_head=Głowa Wielkiej Stopy
item.cc:big_foot_head.desc=§7Głowa Wielkiej Stopy, znana ze swoich dużych rozmiarów i charakterystycznych cech. To rzadkie trofeum potwierdzające pokonanie tego nieuchwytnego stworzenia.
tile.cc:big_foot_head.name=Głowa Wielkiej Stopy
cc.big_foot_quest_name=Polowanie na Wielką Stopę
cc.big_foot_quest_rarity=§dLegendarny
item.cc:big_foot_hint_1.desc=§7Tajemnicza wskazówka pozostawiona przez nieuchwytną Wielką Stopę.
item.cc:big_foot_hint_2.desc=§7Kolejny trop na tropie Wielkiej Stopy.
item.cc:big_foot_hint_3.desc=§7Ostatnia wskazówka prowadząca do Wielkiej Stopy.
item.cc:big_foot_quest=Tajemnica Wielkiej Stopy
item.cc:big_foot_quest_completed=Tajemnica Wielkiej Stopy §a[Ukończono]§r
item.cc:big_foot_quest.desc=§7Tajemnicza wyprawa w celu odnalezienia legendarnej Wielkiej Stopy.
item.cc:big_foot_quest_completed.desc=§7Ukończone zadanie Wielkiej Stopy z dowodem.
