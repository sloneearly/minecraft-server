{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.wypnt_bab.chimp": {
			"initial_state": "default",
			"states": {
				"default": {
					"animations": [
						{
							"idle": "query.is_alive"
						}
					],
					"transitions": [
						{
							"swim": "query.is_in_water&&!query.is_on_ground"
						}
					]
				},
				"swim": {
					"animations": [
						"swimming"
					],
					"transitions": [
						{
							"default": "!query.is_in_water&&query.is_on_ground"
						}
					]
				}
			}
		},
		"controller.animation.wypnt_bab.chimp.walk": {
			"initial_state": "default",
			"states": {
				"default": {
					"animations": [
						{
							"walk": "query.modified_move_speed"
						},
						{
							"attacking": "query.has_target"
						}
					],
					"transitions": [
						{
							"swim": "query.is_in_water&&!query.is_on_ground&&!query.is_riding"
						},
						{
							"run": "query.has_target"
						}
					]
				},
				"swim": {
					"animations": [
						"swimming"
					],
					"transitions": [
						{
							"default": "!query.is_in_water&&query.is_on_ground"
						}
					]
				},
				"run": {
					"animations": [
						{
							"walk_target": "query.modified_move_speed"
						}
					],
					"transitions": [
						{
							"default": "!query.has_target"
						}
					]
				}
			}
		},
		"controller.animation.wypnt_bab.chimp.attack": {
			"states": {
				"default": {
					"transitions": [
						{
							"attack": "variable.attack_time > 0.1"
						}
					],
					"blend_transition": 0.05
				},
				"attack": {
					"animations": [
						"attack"
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.05
				}
			}
		},
		"controller.animation.wypnt_bab.chimp.eat": {
			"states": {
				"default": {
					"animations": [
						{
							"eat": "query.is_eating"
						}
					]
				}
			}
		}
	}
}