{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.wypnt_bab.sigiling.walk": {
			"states": {
				"default": {
					"animations": [
						{
							"walk": "query.modified_move_speed"
						},
						{
							"bob": "query.is_alive"
						}
					],
					"blend_transition": 0.1
				}
			}
		},
		"controller.animation.wypnt_bab.sigiling.attack": {
			"states": {
				"default": {
					"transitions": [
						{
							"attack": "variable.attack_time > 0.1"
						}
					],
					"blend_transition": 0.05
				},
				"attack": {
					"animations": [
						"attack"
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.05
				}
			}
		},
		"controller.animation.wypnt_bab.sigiling.shoot": {
			"states": {
				"default": {
					"transitions": [
						{
							"shoot": "query.is_charged&&q.has_target"
						}
					],
					"blend_transition": 0.05
				},
				"shoot": {
					"animations": [
						"shoot"
					],
					"transitions": [
						{
							"default": "query.all_animations_finished"
						}
					],
					"blend_transition": 0.05
				}
			}
		}
	}
}