{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "wypnt_bab:sigiling_shot",
			"materials": {
				"default": "spider"
			},
			"textures": {
				"default": "textures/coreblockstudios/biomesandbeyond/entity/endermen/sigiling_shot"
			},
			"geometry": {
				"default": "geometry.wypnt_bab.sigiling_shot"
			},
			"particle_effects": {
				"goo_trail": "wypnt_bab:sigiling_shot"
			},
			"sound_effects": {
				"shoot_sound": "mob.shulker.shoot"
			},
			"animations": {
				"move": "animation.arrow.move",
				"idle": "animation.wypnt_bab.sigiling_shot.idle"
			},
			"scripts": {
				"pre_animation": [
					"variable.shake = query.shake_time - query.frame_alpha;",
					"variable.shake_power = variable.shake > 0.0 ? -Math.sin(variable.shake * 200.0) * variable.shake : 0.0;"
				],
				"animate": [
					"move",
					{
						"idle": "query.is_alive&&query.is_moving"
					}
				]
			},
			"render_controllers": [
				"controller.render.arrow"
			]
		}
	}
}