{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "wypnt_bab:jacaranda_leaf",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/coreblockstudios/biomesandbeyond/particles/jacaranda_leaves"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.fall_acc = -0.15; v.wind_strength = math.random(0.8, 1.2); v.wind_dir = math.random(-1, 1);"
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": "Math.random(1, 4)",
				"max_particles": "Math.random(6, 12)"
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": "Math.random(7, 12)"
			},
			"minecraft:emitter_shape_box": {
				"offset": [0, 0.5, 0],
				"half_dimensions": [0.5, 0.1, 0.5],
				"surface_only": true,
				"direction": [0, -0.1, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "Math.random(8.0, 15.0)"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(0, 360)",
				"rotation_rate": "math.random(-45, 45)"
			},
			"minecraft:particle_initial_speed": "math.random(0.1, 0.3)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [
					"v.wind_dir * v.wind_strength * math.sin(v.particle_age * 2) * (v.particle_age / v.particle_lifetime)",
					"v.fall_acc + math.sin(v.particle_age * 3) * 0.05",
					"math.cos(v.particle_age * 1.5) * v.wind_strength * 0.5 * (v.particle_age / v.particle_lifetime)"
				],
				"rotation_acceleration": "math.sin(v.particle_age) * 20"
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["math.lerp(0.08, 0.12, v.particle_random_1)", "math.lerp(0.08, 0.12, v.particle_random_1)"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 28,
					"texture_height": 21,
					"uv": ["math.floor(v.particle_random_1 * 4) * 7", "math.floor(v.particle_random_2 * 3) * 7"],
					"uv_size": [7, 7]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_drag": 15,
				"collision_radius": 0.05,
				"expire_on_contact": true
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {}
				}
			}
		}
	}
}