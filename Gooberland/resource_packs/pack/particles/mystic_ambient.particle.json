{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "wypnt_bab:mystic_ambient",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/coreblockstudios/biomesandbeyond/particles/mystic_amb"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": "math.random(100,250)",
				"max_particles": 300
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 8
			},
			"minecraft:emitter_shape_box": {
				"half_dimensions": [32, 10, 32],
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(2,3)"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": "math.random(1,3)",
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": [0.1, 0.1],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 128,
					"flipbook": {
						"base_UV": ["Math.floor(v.particle_random_3 * 2) * 8", "Math.floor(v.particle_random_4 * 2) * 8"],
						"size_UV": [8, 8],
						"step_UV": [0, 16],
						"frames_per_second": 12,
						"max_frame": 8,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.07": "#00FEFF00",
						"0.24": "#96FFED00",
						"0.76": "#9CDDCF00",
						"0.91": "#00FFFFFF"
					}
				}
			}
		}
	}
