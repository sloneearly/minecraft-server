      },
      "minecraft:can_fly": {},
      "minecraft:navigation.fly": {
        "can_path_over_water": true,
        "can_path_from_air": true,
        "avoid_damage_blocks": false,
        "avoid_portals": false,
        "avoid_sun": false,
        "avoid_water": false,
        "blocks_to_avoid": [],
        "can_breach": false,
        "can_break_doors": false,
        "can_jump": true,
        "can_open_doors": false,
        "can_open_iron_doors": false,
        "can_pass_doors": true,
        "can_path_over_lava": false,
        "can_sink": true,
        "can_swim": false,
        "can_walk": true,
        "can_walk_in_lava": false,
        "is_amphibious": false
      },
      "minecraft:movement.fly": {
        "max_turn": 30.0
      },
      "minecraft:physics": {
        "has_collision": true,
        "has_gravity": true,
        "push_towards_closest_space": false
      },
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:game_event_movement_tracking": {
        "emit_flap": false,
        "emit_move": true,
        "emit_swim": true
      },
      "minecraft:healable": {
        "force_use": true,
        "filters": {
          "test": "is_riding",
          "operator": "!=",
          "value": true
        },
        "items": [
          {
            "item": "cookie",
            "heal_amount": 0,
            "effects": [
              {
                "name": "fatal_poison",
                "chance": 1,
                "duration": 1000,
                "amplifier": 0
              }
            ]
          }
        ]
      },
      "minecraft:leashable": {},
      "minecraft:balloonable": {
        "mass": 1.0,
        "max_distance": 10.0,
        "soft_distance": 2.0
      },
      "minecraft:behavior.float": {
