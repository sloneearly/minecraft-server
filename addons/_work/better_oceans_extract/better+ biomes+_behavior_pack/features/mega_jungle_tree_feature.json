{
  "format_version": "1.13.0",
  "minecraft:tree_feature": {
    "description": {
      "identifier": "minecraft:mega_jungle_tree_feature"
    },
    "mega_trunk": {
      "trunk_width": 3,
      "trunk_height": {
        "base": 16,
        "intervals": [
          3,
          20
        ]
      },
      "trunk_block": "minecraft:jungle_log",
      "trunk_decoration": {
        "decoration_chance": {
          "numerator": 1,
          "denominator": 3
        },
        "decoration_block": "minecraft:vine"
      },
      "branches": {
        "branch_length": 5,
        "branch_slope": 0,
        "branch_interval": {
          "range_min": 2,
          "range_max": 6
        },
        "branch_altitude_factor": {
          "min": 0,
          "max": 1
        },
        "branch_canopy": {
          "mega_canopy": {
            "canopy_height": {
              "range_min": 2,
              "range_max": 4
            },
            "base_radius": 1,
            "simplify_canopy": true,
            "leaf_block": "minecraft:jungle_leaves"
          }
        }
      }
    },
    "mega_canopy": {
      "canopy_height": {
        "range_min": 3,
        "range_max": 5
      },
      "base_radius": 4,
      "core_width": 3,
      "leaf_block": "minecraft:jungle_leaves"
    },
    "may_grow_on": [
      "minecraft:clay",
      "minecraft:coarse_dirt",
      "minecraft:dirt",
      "minecraft:dirt_with_roots",
      "minecraft:farmland",
      "minecraft:grass_block",
      "minecraft:moss_block",
      "minecraft:mud",
      "minecraft:muddy_mangrove_roots",
      "minecraft:mycelium",
      "minecraft:pale_moss_block",
      "minecraft:podzol"
    ],
    "base_block": [
      "minecraft:dirt",
      "minecraft:coarse_dirt"
    ],
    "may_grow_through": [
      "minecraft:coarse_dirt",
      "minecraft:dirt",
      "minecraft:dirt_with_roots",
      "minecraft:farmland",
      "minecraft:grass_block",
      "minecraft:moss_block",
      "minecraft:mud",
      "minecraft:muddy_mangrove_roots",
      "minecraft:mycelium",
      "minecraft:pale_moss_block",
      "minecraft:podzol"
    ],
    "may_replace": [
      "minecraft:air",
      "minecraft:snow_layer",
      "minecraft:acacia_leaves",
      "minecraft:azalea_leaves",
      "minecraft:azalea_leaves_flowered",
      "minecraft:birch_leaves",
      "minecraft:cherry_leaves",
      "minecraft:dark_oak_leaves",
      "minecraft:jungle_leaves",
      "minecraft:mangrove_leaves",
      "minecraft:oak_leaves",
      "minecraft:pale_oak_leaves",
      "minecraft:spruce_leaves",
      "minecraft:wildflowers",
      "minecraft:leaf_litter"
    ]
  }
}