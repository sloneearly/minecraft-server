{
  "format_version": "1.19.0",
  "animation_controllers": {
    "controller.animation.pa_no_no.baby": {
      "initial_state": "baby",
      "states": {
        "baby": {
          "animations": [
            {
              "baby_transform": "query.is_baby"
            }
          ]
        }
      }
    },
    "controller.animation.pa_no_no.move": {
      "states": {
        "default": {
          "animations": [
            {
              "walk": "query.modified_move_speed"
            },
            "move",
            "look_at_target"
          ]
        }
      }
    }
  }
}