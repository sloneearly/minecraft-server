{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "pa:red_robin",
      "materials": {
        "default": "parrot"
      },
      "textures": {
        "blue": "textures/entity/pamobile/pa_red_robin",
        "green": "textures/entity/pamobile/pa_red_robin",
        "red_blue": "textures/entity/pamobile/pa_red_robin",
        "yellow_blue": "textures/entity/pamobile/pa_red_robin",
        "grey": "textures/entity/pamobile/pa_red_robin"
      },
      "geometry": {
        "default": "geometry.pa_red_robin_default"
      },
      "scripts": {
        "pre_animation": [
          "variable.state = query.is_dancing ? 3 : (query.is_sitting ? 2 : (!query.is_on_ground && !query.is_jumping && !query.is_riding ? 0 : 1));",
          "variable.dance.x = Math.cos(query.life_time * 57.3 * 20.0);",
          "variable.dance.y = -Math.sin(query.life_time * 57.3 * 20.0);",
          "variable.wing_flap = ((math.sin(query.wing_flap_position * 57.3) + 1) * query.wing_flap_speed);"
        ],
        "animate": [
          "look_at_target",
          "move"
        ]
      },
      "animations": {
        "moving": "animation.pa_red_robin.moving",
        "base": "animation.pa_red_robin.base",
        "dance": "animation.pa_red_robin.dance",
        "sitting": "animation.pa_red_robin.sitting",
        "flying": "animation.pa_red_robin.flying",
        "standing": "animation.pa_red_robin.standing",
        "look_at_target": "animation.pa_red_robin.look_at_target",
        "setup": "controller.animation.pa_red_robin.setup",
        "move": "controller.animation.pa_red_robin.move"
      },
      "render_controllers": [
        "controller.render.parrot"
      ],
      "spawn_egg": {
        "base_color": "#EA9A51",
        "overlay_color": "#FF0909"
      }
    }
  }
}