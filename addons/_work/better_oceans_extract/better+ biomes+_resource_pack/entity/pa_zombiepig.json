{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "pa:zombiepig",
      "min_engine_version": "1.8.0",
      "materials": {
        "default": "pig_v3"
      },
      "textures": {
        "default": "textures/entity/pamobile/pa_zombiepig",
        "saddled": "textures/entity/pamobile/pa_zombiepig_saddled",
        "warm": "textures/entity/pamobile/pa_zombiepig_warm",
        "cold": "textures/entity/pamobile/pa_zombiepig_cold",
        "saddle": "textures/entity/pamobile/pa_zombiepig_saddle",
        "baby_default": "textures/entity/pamobile/pa_zombiepig_baby_default",
        "baby_warm": "textures/entity/pamobile/pa_zombiepig_baby_warm",
        "baby_cold": "textures/entity/pamobile/pa_zombiepig_baby_cold"
      },
      "geometry": {
        "default": "geometry.pa_zombiepig_default",
        "baby": "geometry.pa_zombiepig_baby"
      },
      "animations": {
        "setup": "animation.pig.setup",
        "walk": "animation.quadruped.walk",
        "look_at_target": "animation.common.look_at_target",
        "baby_transform": "animation.pig.baby_transform"
      },
      "scripts": {
        "animate": [
          "setup",
          {
            "walk": "query.modified_move_speed"
          },
          "look_at_target"
        ],
        "pre_animation": [
          "t.variant = query.property('minecraft:climate_variant');",
          "v.index = (t.variant == 'temperate') ? 0 : ((t.variant == 'warm') ? 1 : 2);"
        ],
        "scale": "query.is_baby ? 2.0 : 1.0"
      },
      "render_controllers": [
        "controller.render.saddle",
        "controller.render.pig.v4"
      ],
      "spawn_egg": {
        "base_color": "#EA9A51",
        "overlay_color": "#FF0909"
      }
    }
  }
}