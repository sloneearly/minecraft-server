{
	"format_version": "1.13.0",
	"minecraft:feature_rules": {
		"description": {
			"identifier": "shapescape:forest_sparse_desert",
			"places_feature": "shapescape:forest_sparse_desert_scatter"
		},
		"conditions": {
			"placement_pass": "surface_pass",
			"minecraft:biome_filter": {
				"test": "has_biome_tag",
				"value": "desert"
			}
		},
		"distribution": {
			"scatter_chance": {
				"numerator": 99,
				"denominator": 100
			},
			"iterations": "t.forest_sparce_noise = math.abs(q.noise(v.originx/400, v.originz/400)); return (1) * (t.forest_sparce_noise > 0.3 && t.forest_sparce_noise < 0.45);",
			"coordinate_eval_order": "zxy",
			"x": {
				"distribution": "fixed_grid",
				"extent": [0, 15]
			},
			"y": "q.above_top_solid(v.worldx, v.worldz)",
			"z": {
				"distribution": "fixed_grid",
				"extent": [0, 15]
			}
		}
	}
}