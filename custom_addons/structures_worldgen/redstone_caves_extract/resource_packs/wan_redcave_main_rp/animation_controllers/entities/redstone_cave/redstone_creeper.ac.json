{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.wan_redcave.redstone_creeper.move": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "idle": "!v.stop_walking_anim"
            }
          ],
          "blend_transition": 0.2
        },
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "walk": "q.modified_move_speed > 0.1 && q.mark_variant != 1"
            },
            {
              "walk_hostile": "q.modified_move_speed > 0.1 && q.mark_variant == 1"
            }
          ],
          "blend_transition": 0.2
        },
        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "idle": "q.modified_move_speed <= 0.1"
            }
          ],
          "sound_effects": [
            {
              "effect": "walk"
            }
          ],
          "blend_transition": 0.2
        },
        "walk_hostile": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "idle": "q.modified_move_speed <= 0.1"
            }
          ],
          "sound_effects": [
            {
              "effect": "walk_hostile"
            }
          ],
          "blend_transition": 0.2
        }
      }
    },
    "controller.animation.wan_redcave.redstone_creeper.attack": {
      "initial_state": "default",
      "states": {
        "default": {
          "blend_transition": 0.1,
          "transitions": [
            {
              "melee": "q.variant == 2 && q.mark_variant != 1"
            },
            {
              "melee_hostile": "q.variant == 2 && q.mark_variant == 1"
            },
            {
              "explode": "q.variant == 3 && q.mark_variant != 1"
            },
            {
              "explod_hostile": "q.variant == 3 && q.mark_variant == 1"
            },
            {
              "on": "q.variant == 4"
            },
            {
              "off": "q.variant == 5"
            }
          ]
        },
        "melee": {
          "animations": [
            "melee"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "blend_transition": 0.1,
          "sound_effects": [
            {
              "effect": "melee"
            }
          ]
        },
        "melee_hostile": {
          "animations": [
            "melee"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "melee_hostile"
            }
          ],
          "blend_transition": 0.1
        },
        "explode": {
          "animations": [
            "explode"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "explode"
            }
          ],
          "blend_transition": 1
        },
        "explod_hostile": {
          "animations": [
            "explode"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "explod_hostile"
            }
          ],
          "blend_transition": 1
        },
        "on": {
          "animations": [
            "on"
          ],
          "transitions": [
            {
              "default": "query.variant != 4"
            }
          ],
          "sound_effects": [
            {
              "effect": "on"
            }
          ],
          "blend_transition": 0.1
        },
        "off": {
          "on_entry": [
            "v.stop_walking_anim = 1;"
          ],
          "animations": [
            "off",
            {
              "off_post": "query.any_animation_finished"
            }
          ],
          "transitions": [
            {
              "default": "query.variant != 5"
            }
          ],
          "sound_effects": [
            {
              "effect": "off"
            }
          ],
          "on_exit": [
            "v.stop_walking_anim = 0;"
          ],
          "blend_transition": 0
        }
      }
    }
  }
}