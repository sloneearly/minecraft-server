{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.wan_redcave.redstone_longleg.move": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "idle": "!v.stop_walking_anim"
            }
          ],
          "blend_transition": 0.2
        },
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "walk": "q.modified_move_speed > 0.1"
            }
          ],
          "blend_transition": 0.2
        },
        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "default": "v.stop_walking_anim"
            },
            {
              "idle": "q.modified_move_speed <= 0.1"
            }
          ],
          "blend_transition": 0.2
        }
      }
    },
    "controller.animation.wan_redcave.redstone_longleg.attack": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "charge": "q.variant == 2"
            },
            {
              "on": "q.variant == 5"
            },
            {
              "off": "q.variant == 6"
            },
            {
              "sit": "q.variant == 7"
            }
          ],
          "blend_transition": 0.1
        },
        "charge": {
          "animations": [
            "charge"
          ],
          "transitions": [
            {
              "roll": "query.any_animation_finished"
            }
          ],
          "blend_transition": 0.1
        },
        "roll": {
          "animations": [
            "roll"
          ],
          "transitions": [
            {
              "getup": "q.variant != 2"
            }
          ],
          "blend_transition": 0.1
        },
        "getup": {
          "animations": [
            "getup"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "blend_transition": 0.1
        },
        "on": {
          "animations": [
            "on"
          ],
          "transitions": [
            {
              "default": "query.variant != 5"
            }
          ],
          "sound_effects": [
            {
              "effect": "on"
            }
          ],
          "blend_transition": 0.1
        },
        "off": {
          "on_entry": [
            "v.stop_walking_anim = 1;"
          ],
          "animations": [
            "off",
            {
              "off_post": "query.any_animation_finished"
            }
          ],
          "transitions": [
            {
              "default": "query.variant != 6"
            }
          ],
          "sound_effects": [
            {
              "effect": "off"
            }
          ],
          "on_exit": [
            "v.stop_walking_anim = 0;"
          ],
          "blend_transition": 0.1
        },
        "sit": {
          "blend_transition": 0,
          "animations": [
            "sit"
          ],
          "transitions": [
            {
              "sit_up": "query.variant != 7"
            }
          ]
        },
        "sit_up": {
          "animations": [
            "up"
          ],
          "on_exit": [
            "v.stop_walking_anim = 0;"
          ],
          "transitions": [
            {
              "default": "query.any_animation_finished"
            }
          ],
          "blend_transition": 0.1
        }
      }
    }
  }
}